#!/bin/bash
# Aelarian Archives — Pre-commit enforcement hook
# Source: hooks/pre-commit (tracked)
# Install: cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Re-install any time this file is updated.

set -e

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

echo "Running pre-commit enforcement checks..."
WARNINGS=0

# ---------------------------------------------------------------
# CHECK 1 — Credential patterns (F32)
# Hard block. Commit does not proceed.
# ---------------------------------------------------------------
echo "  [1/4] Credential scan..."

CREDENTIAL_PATTERNS="B2_KEY_ID\s*=\s*['\"][^'\"]{5}|B2_APP_KEY\s*=\s*['\"][^'\"]{5}|password\s*=\s*['\"][^'\"]{3}|api_key\s*=\s*['\"][^'\"]{3}|app_key\s*=\s*['\"][^'\"]{3}|secret\s*=\s*['\"][^'\"]{3}"

for FILE in $STAGED_FILES; do
    # Block .env from being staged at all
    if echo "$FILE" | grep -qE "(^|/)\.env(\.|$)"; then
        echo ""
        echo "  BLOCKED: .env file staged for commit: $FILE"
        echo "  .env must never be committed. Add to .gitignore."
        exit 1
    fi
    # Scan file content for credential patterns
    if git show ":$FILE" 2>/dev/null | grep -qiP "$CREDENTIAL_PATTERNS" 2>/dev/null; then
        echo ""
        echo "  BLOCKED: Credential pattern detected in: $FILE"
        echo "  Move credentials to .env and read via os.environ.get()."
        echo "  See GITHUB_PROTOCOL.md section 5."
        exit 1
    fi
done

echo "  PASS"

# ---------------------------------------------------------------
# CHECK 2 — Domain vocabulary in code files (F14)
# Warning only until domain term list is finalized.
# Promote to hard block once exceptions are confirmed.
# ---------------------------------------------------------------
echo "  [2/4] Domain vocabulary scan..."

CODE_EXTENSIONS="\.(js|ts|py|css|html)$"

# Terms that have NO valid use in code logic or naming.
# arcPhase values (aetherrot, solenne, vireth) are excluded here —
# they are valid schema enum values. Review this list before build starts.
DOMAIN_TERMS="Ae.larian|Ven.ai|Cael.Thera|Verith|Larimar|Sa.Qel|NurseryBG|StarRoot|Sat.Nam"

for FILE in $STAGED_FILES; do
    # Only scan code files, not docs or schemas
    if echo "$FILE" | grep -qE "$CODE_EXTENSIONS"; then
        if echo "$FILE" | grep -qE "(DOCS/|hooks/)"; then
            continue
        fi
        if git show ":$FILE" 2>/dev/null | grep -qP "$DOMAIN_TERMS" 2>/dev/null; then
            echo ""
            echo "  WARNING: Domain vocabulary in code file: $FILE"
            echo "  Function names, variables, and comments must use plain technical language."
            echo "  See ENFORCEMENT.md F14. Review before committing."
            WARNINGS=$((WARNINGS + 1))
        fi
    fi
done

if [ $WARNINGS -eq 0 ]; then
    echo "  PASS"
else
    echo "  $WARNINGS warning(s). Review output above before proceeding."
fi

# ---------------------------------------------------------------
# CHECK 3 — Lockfile consistency (F20)
# Hard block when package.json exists.
# ---------------------------------------------------------------
echo "  [3/4] Lockfile check..."

if [ -f "package.json" ]; then
    if [ ! -f "package-lock.json" ]; then
        echo ""
        echo "  BLOCKED: package.json present but package-lock.json is missing."
        echo "  Run: npm ci (never npm install)"
        exit 1
    fi
    if echo "$STAGED_FILES" | grep -q "package.json"; then
        if ! echo "$STAGED_FILES" | grep -q "package-lock.json"; then
            echo ""
            echo "  BLOCKED: package.json staged without package-lock.json."
            echo "  Both must be committed together."
            exit 1
        fi
    fi
    echo "  PASS"
else
    echo "  SKIP (no package.json — applies when build introduces npm dependencies)"
fi

# ---------------------------------------------------------------
# CHECK 4 — Sensitive file patterns (F32)
# Hard block.
# ---------------------------------------------------------------
echo "  [4/4] Sensitive file check..."

SENSITIVE_PATTERNS="(^|/)credentials|secrets\.(json|yml|yaml)|\.pem$|\.p12$|\.key$"

for FILE in $STAGED_FILES; do
    if echo "$FILE" | grep -qiE "$SENSITIVE_PATTERNS"; then
        echo ""
        echo "  BLOCKED: Sensitive file pattern detected: $FILE"
        echo "  This file type must not be committed."
        exit 1
    fi
done

echo "  PASS"

# ---------------------------------------------------------------
# Result
# ---------------------------------------------------------------
echo ""
if [ $WARNINGS -gt 0 ]; then
    echo "Pre-commit checks complete. $WARNINGS warning(s) require review."
    echo "Commit is not blocked by warnings — but review before proceeding."
else
    echo "Pre-commit checks complete. All passed."
fi

exit 0
