# Credentials and environment
.env
*.env
.env.*

# Logs
*.log
backup.log

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
.Trash-*

# Editor swap and backup files
*.swp
*.swo
*.bak
*~

# Editor / IDE settings
# VS Code: blanket-ignore, but preserve shared project-level config files
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# JetBrains (IntelliJ, PyCharm, WebStorm)
.idea/
*.iml

# Claude Code local user settings (NOT the project-shared settings.json)
.claude/settings.local.json

# Gemini Antigravity: stores state in user home (~/.gemini/antigravity),
# not in the repo. Listed defensively in case a future version drops
# state inside the project folder.
# .gemini/

# Python
__pycache__/
*.pyc
.venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.tox/
*.egg-info/
.coverage
htmlcov/

# Node / Svelte / Vite
node_modules/
npm-debug.log*
.pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
.svelte-kit/
.vite/

# SQLite databases
*.db
*.db-shm
*.db-wal

# Build artifacts
dist/
build/

# Large binaries
*.exe
*.dmg
*.pkg
*.msi

# Database dumps and backup operational state
db-dumps/
backup_manifest.json
backblaze_state.json

# Audio and media assets - runtime static assets curated locally,
# not versioned in Git. See README for sync procedure.
# Source of truth: project-root Audio/Nodes/{nodeId}.wav
# Build target:    frontend/static/Audio/Nodes/{nodeId}.wav (bridged at build time, method TBD)
Audio/
BackGround/
backups/
frontend/static/Audio/
