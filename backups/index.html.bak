// ══════════════════════════════════════════════════════════════════
//  SPIRAL ENGINE — vanilla, no framework
// ══════════════════════════════════════════════════════════════════

(function() {

  const CX = 600, CY = 600;
  const A  = 9;
  const MT = 20 * Math.PI;
  const N  = 3200;

  function buildPath() {
    const SEG = 600;
    const dth = MT / SEG;
    let d = '';
    for (let i = 0; i <= SEG; i++) {
      const th = (i / SEG) * MT;
      const r  = A * th;
      const x  = CX + r * Math.cos(th);
      const y  = CY + r * Math.sin(th);
      if (i === 0) {
        d += 'M' + x.toFixed(2) + ' ' + y.toFixed(2);
      } else {
        const th0 = ((i - 1) / SEG) * MT;
        const r0  = A * th0;
        const x0  = CX + r0 * Math.cos(th0);
        const y0  = CY + r0 * Math.sin(th0);
        const tx0 = A * (Math.cos(th0) - th0 * Math.sin(th0));
        const ty0 = A * (Math.sin(th0) + th0 * Math.cos(th0));
        const tx1 = A * (Math.cos(th)  - th  * Math.sin(th));
        const ty1 = A * (Math.sin(th)  + th  * Math.cos(th));
        const cp1x = (x0 + tx0 * dth / 3).toFixed(2);
        const cp1y = (y0 + ty0 * dth / 3).toFixed(2);
        const cp2x = (x  - tx1 * dth / 3).toFixed(2);
        const cp2y = (y  - ty1 * dth / 3).toFixed(2);
        d += ' C' + cp1x + ' ' + cp1y + ' ' + cp2x + ' ' + cp2y
           + ' ' + x.toFixed(2) + ' ' + y.toFixed(2);
      }
    }
    return d;
  }

  function mountSpiral() {
    const g = document.getElementById('spiral-group');
    if (!g) return;

    const NS = 'http://www.w3.org/2000/svg';
    const d  = buildPath();

    function makePath(stroke, strokeWidth, opacity, filter) {
      const p = document.createElementNS(NS, 'path');
      p.setAttribute('d',            d);
      p.setAttribute('fill',         'none');
      p.setAttribute('stroke',       stroke);
      p.setAttribute('stroke-width', strokeWidth);
      p.setAttribute('opacity',      opacity);
      if (filter) p.setAttribute('filter', filter);
      return p;
    }

    // Three stroke layers: ember glow / main gold gradient / fine shimmer
    // Wide diffuse bloom - luminous halo layer
    const bloomFilter = document.createElementNS(NS, 'filter');
    bloomFilter.setAttribute('id', 'sg-bloom');
    bloomFilter.setAttribute('x', '-20%');
    bloomFilter.setAttribute('y', '-20%');
    bloomFilter.setAttribute('width', '140%');
    bloomFilter.setAttribute('height', '140%');
    const feBlur = document.createElementNS(NS, 'feGaussianBlur');
    feBlur.setAttribute('stdDeviation', '0.8');
    bloomFilter.appendChild(feBlur);
    const svgDefs = g.closest('svg').querySelector('defs');
    svgDefs.appendChild(bloomFilter);
    g.appendChild(makePath('#ffd700',          18,   0.07, 'url(#sg-bloom)'));
    g.appendChild(makePath('#7a3200',          6,    0.12, 'url(#sg)'));
    g.appendChild(makePath('url(#spiralGrad)', 2.2,  0.92, 'url(#sg)'));
    g.appendChild(makePath('#ffd700',          0.8,  0.50, null));

    const speedRef = { value: 0.032 };
    let rot = 0, breathTime = 0;

    function exposeTobridge() {
      if (window._aelarian) window._aelarian.spiralSpeedRef = speedRef;
    }
    exposeTobridge();
    window.addEventListener('aelarian:ready', exposeTobridge, { once: true });

    function tick() {
      rot        += speedRef.value;
      breathTime += 0.008;
      const deg = (rot * 180 / Math.PI) % 360;
      const opa = (0.75 + Math.sin(breathTime * 0.85) * 0.12).toFixed(3);
      g.setAttribute('transform', 'rotate(' + deg.toFixed(3) + ',600,600)');
      g.setAttribute('opacity',   opa);
      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', mountSpiral);
  } else {
    mountSpiral();
  }

})();

// ================================================================
//  RESONANCE ENGINE LAYER 2 - GS Nodes
// ================================================================

(function() {

  const W = 1900, H = 1900, CX = W/2, CY = H/2;
  const THETA_STEP = 0.7;
  const R_STEP     = 55;
  const N_NODES    = 13;
  const ARM_OFFSETS = [0, 2*Math.PI/3, 4*Math.PI/3];

  // Node data - 14 GS nodes (n=0 center through n=13 outermost)
  const NODE_DATA = [
    { name: "Sa'Qel Inthra",          secondary: "Ti'Kariel Sa",         epithet: "Null Vein / Breath Between Stars",              hz: "44 Hz"      },
    { name: "Aetherroot Chord",        secondary: "Vel'Sahen",            epithet: "Primordial Truth / Root Convergence",           hz: "175.5 Hz"   },
    { name: "Solenne Arc",             secondary: "Mira'Neth",            epithet: "Restoration / Soul Resonance",                  hz: "4,212 Hz"   },
    { name: "Thren'Alae Kai'Reth",     secondary: "Eli'Thren",            epithet: "Transformation Bridge / Of Threshold and Thread", hz: "1,930.5 Hz" },
    { name: "Shai'Mara Veil",          secondary: "Shael'Unei",           epithet: "Rethreading Cycles / Sovereign Return",         hz: "1,579.5 Hz" },
    { name: "Vireth's Anchor",         secondary: "Em'Rei",               epithet: "Sovereign Presence / Guardian of Essence",      hz: "2,632.5 Hz" },
    { name: "Esh'Vala Breath",         secondary: "Vesha'Kai",            epithet: "Illumination / Celestial Emergence",            hz: "3,334.5 Hz" },
    { name: "Orrin Wave",              secondary: "Lumaehn'Kai",          epithet: "First Tone / Song of Dreamlight",               hz: "1,404 Hz"   },
    { name: "Lumora Thread",           secondary: "Shael'Thir",           epithet: "Continuity / Between Memory and Marrow",        hz: "2,457 Hz"   },
    { name: "Hearth Song",             secondary: "Teyr'kai",             epithet: "Resonance of Home / Primordial Flame",          hz: "351 Hz"     },
    { name: "Tahl'Veyra",              secondary: "Sol'Kai",              epithet: "Sovereign Emergence / Sovereign Spiral",        hz: "2,808 Hz"   },
    { name: "Noirune'Trai",            secondary: "Elan'Thae",            epithet: "Shadow Layer / Primordial Origin",              hz: "2,106 Hz"   },
    { name: "Starwell Bloom",          secondary: "Thala'Rae",            epithet: "Future Renewal / Starroot Bloom",               hz: "3,410 Hz"   },
    { name: "Kai'Reth Sovereign Spiral", secondary: "Ti'Kahl Ves'Tun",   epithet: "Primordial Truth",                              hz: "5,967 Hz"   },
  ];

  function spiralPos(n, armOffset) {
    if (n === 0) return { x: CX, y: CY, r: 0, theta: armOffset };
    const theta = n * THETA_STEP + armOffset;
    const r     = n * R_STEP;
    return { x: CX + r * Math.cos(theta), y: CY + r * Math.sin(theta), r, theta };
  }

  function mount() {
    const canvas = document.getElementById('re-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    ctx.globalCompositeOperation = 'source-over';
    ctx.clearRect(0, 0, W, H);

    // GS diffraction node draw function
    function drawDiffStar(x, y, sz, color, opacity) {
      const inner = sz * 0.09;
      ctx.save();
      // Primary 8-point starburst
      ctx.globalAlpha = opacity;
      ctx.fillStyle = color;
      ctx.beginPath();
      for (let p = 0; p < 8; p++) {
        const a  = p * Math.PI/4;
        const r2 = p%2===0 ? sz : inner;
        p===0 ? ctx.moveTo(x+r2*Math.cos(a), y+r2*Math.sin(a))
               : ctx.lineTo(x+r2*Math.cos(a), y+r2*Math.sin(a));
      }
      ctx.closePath(); ctx.fill();
      // Secondary rotated burst - softer
      ctx.globalAlpha = opacity * 0.28;
      ctx.beginPath();
      for (let p = 0; p < 8; p++) {
        const a  = p * Math.PI/4 + Math.PI/8;
        const r2 = p%2===0 ? sz*0.72 : inner;
        p===0 ? ctx.moveTo(x+r2*Math.cos(a), y+r2*Math.sin(a))
               : ctx.lineTo(x+r2*Math.cos(a), y+r2*Math.sin(a));
      }
      ctx.closePath(); ctx.fill();
      // Bright stellar core pinpoint
      ctx.globalAlpha = opacity * 0.55;
      const coreGrd = ctx.createRadialGradient(x,y,0,x,y,sz*0.25);
      coreGrd.addColorStop(0, 'rgba(205,220,232,0.85)');
      coreGrd.addColorStop(1, 'rgba(175,200,218,0)');
      ctx.fillStyle = coreGrd;
      ctx.beginPath(); ctx.arc(x,y,sz*0.25,0,Math.PI*2); ctx.fill();
      ctx.restore();
    }

    // Store node screen centers for hover detection
    const nodeCenters = [];

    // n=0 Sa'Qel Inthra at center (Primordial position) - sz doubled
    const c0sz = 52.0 * Math.pow(0.95, 13);  // ~26.7 - inward taper from Kai'Reth
    const c0inner = ctx.createRadialGradient(CX,CY,0,CX,CY,c0sz*2.5);
    c0inner.addColorStop(0,   'rgba(185,205,222,0.12)');
    c0inner.addColorStop(0.5, 'rgba(170,192,210,0.05)');
    c0inner.addColorStop(1,   'rgba(155,178,198,0)');
    ctx.beginPath(); ctx.arc(CX,CY,c0sz*2.5,0,Math.PI*2);
    ctx.fillStyle = c0inner; ctx.fill();
    const c0grd = ctx.createRadialGradient(CX,CY,0,CX,CY,c0sz*6);
    c0grd.addColorStop(0,   'rgba(175,198,215,0.04)');
    c0grd.addColorStop(0.4, 'rgba(155,180,200,0.015)');
    c0grd.addColorStop(1,   'rgba(0,0,0,0)');
    ctx.beginPath(); ctx.arc(CX,CY,c0sz*6,0,Math.PI*2);
    ctx.fillStyle = c0grd; ctx.fill();
    drawDiffStar(CX, CY, c0sz, '#b8ccd8', 0.82);
    nodeCenters.push({ x: CX, y: CY, sz: c0sz*5, n: 0 });

    // n=1 through n=13 on Arm 2 - sz doubled
    for (let n = 1; n <= N_NODES; n++) {
      const pos = spiralPos(n, ARM_OFFSETS[1]);
      const sz  = 52.0 * Math.pow(0.95, 13 - n);
      const nodeInner = ctx.createRadialGradient(pos.x,pos.y,0,pos.x,pos.y,sz*2.5);
      nodeInner.addColorStop(0,   'rgba(185,205,222,0.12)');
      nodeInner.addColorStop(0.5, 'rgba(170,192,210,0.05)');
      nodeInner.addColorStop(1,   'rgba(155,178,198,0)');
      ctx.beginPath(); ctx.arc(pos.x,pos.y,sz*2.5,0,Math.PI*2);
      ctx.fillStyle = nodeInner; ctx.fill();
      const grd = ctx.createRadialGradient(pos.x,pos.y,0,pos.x,pos.y,sz*6);
      grd.addColorStop(0,   'rgba(175,198,215,0.04)');
      grd.addColorStop(0.4, 'rgba(155,180,200,0.015)');
      grd.addColorStop(1,   'rgba(0,0,0,0)');
      ctx.beginPath(); ctx.arc(pos.x,pos.y,sz*6,0,Math.PI*2);
      ctx.fillStyle = grd; ctx.fill();
      drawDiffStar(pos.x, pos.y, sz, '#b8ccd8', 0.82);
      nodeCenters.push({ x: pos.x, y: pos.y, sz: sz*5, n });
    }

    // Hover system
    const tooltip    = document.getElementById('gs-tooltip');
    const elName     = document.getElementById('gst-name');
    const elSec      = document.getElementById('gst-secondary');
    const elEpi      = document.getElementById('gst-epithet');
    const elHz       = document.getElementById('gst-hz');
    let activeNode   = -1;

    canvas.addEventListener('mousemove', function(e) {
      const rect   = canvas.getBoundingClientRect();
      const scaleX = W / rect.width;
      const scaleY = H / rect.height;
      const cx     = (e.clientX - rect.left) * scaleX;
      const cy     = (e.clientY - rect.top)  * scaleY;

      let hit = -1;
      let hitDist = Infinity;
      for (const nc of nodeCenters) {
        const d = Math.hypot(cx - nc.x, cy - nc.y);
        if (d <= nc.sz && d < hitDist) { hit = nc.n; hitDist = d; }
      }

      if (hit === activeNode) return;
      activeNode = hit;

      if (hit === -1) {
        tooltip.classList.remove('visible');
        canvas.style.cursor = 'default';
        if (window._clearFamilyHighlight) window._clearFamilyHighlight();
        return;
      }

      const d = NODE_DATA[hit];
      elName.textContent = d.name;
      elSec.textContent  = d.secondary;
      elEpi.textContent  = d.epithet;
      elHz.textContent   = d.hz;

      const nc = nodeCenters[hit];
      const dispX = rect.left + (nc.x / scaleX);
      const dispY = rect.top  + (nc.y / scaleY);
      tooltip.style.left = dispX + 'px';
      tooltip.style.top  = dispY + 'px';
      tooltip.classList.add('visible');
      canvas.style.cursor = 'pointer';

      // ── Audio hover shimmer ──
      if (window._harmonicEngine && window._harmonicEngine.ready) {
        const freq   = parseFloat(d.hz.replace(/,/g, ''));
        const panVal = (nc.x / W) * 2 - 1;
        window._harmonicEngine.hover(freq, panVal);
      }

      // ── v4: family highlight on hover ──
      const nodeId = GS_NODES[hit] ? GS_NODES[hit].id : null;
      if (nodeId && window._highlightFamily) window._highlightFamily(nodeId);
    });

    canvas.addEventListener('mouseleave', function() {
      activeNode = -1;
      tooltip.classList.remove('visible');
      canvas.style.cursor = 'default';
      if (window._clearFamilyHighlight) window._clearFamilyHighlight();
    });

    // ── Audio click ──
    canvas.addEventListener('click', function(e) {
      if (!window._harmonicEngine || !window._harmonicEngine.ready) return;
      const rect   = canvas.getBoundingClientRect();
      const scaleX = W / rect.width;
      const scaleY = H / rect.height;
      const cx     = (e.clientX - rect.left) * scaleX;
      const cy     = (e.clientY - rect.top)  * scaleY;
      let hit = -1, hitDist = Infinity;
      for (const nc of nodeCenters) {
        const d = Math.hypot(cx - nc.x, cy - nc.y);
        if (d <= nc.sz && d < hitDist) { hit = nc.n; hitDist = d; }
      }
      if (hit !== -1) {
        const d      = NODE_DATA[hit];
        const freq   = parseFloat(d.hz.replace(/,/g, ''));
        const nc     = nodeCenters[hit];
        const panVal = (nc.x / W) * 2 - 1;
        const nodeId = GS_NODES[hit] ? GS_NODES[hit].id : null;
        const vx     = rect.left + nc.x / scaleX;
        const vy     = rect.top  + nc.y / scaleY;
        window._harmonicEngine.click(freq, nodeId, panVal);
        _triggerResonanceRing(nodeId, nc, rect, scaleX, scaleY);
        // ── v4: ghost trail at full opacity
        if (nodeId && window._spawnHarmonicGhost) {
          window._spawnHarmonicGhost(nodeId, vx, vy, 0.55);
        }
      }
    });

    // ── Resonance ring system ──────────────────────────────────────────────────
    // Draws an expanding ring anchored to a node's canvas position.
    // Ring size and speed reflect the node's ripple speed (family / freq).
    // Rings are DOM elements positioned fixed over the canvas.
    function _triggerResonanceRing(nodeId, nc, rect, scaleX, scaleY) {
      const fam        = window._getFamily ? window._getFamily(nodeId) : null;
      const color      = fam ? fam.ringColor : 'rgba(155,180,200,0.65)';
      const freq       = (GS_NODES.find(n => n.id === nodeId) || {}).freq || 440;
      const speed      = window._rippleSpeed ? window._rippleSpeed(freq) : 200; // px/s
      // Duration: how long the ring takes to reach maxSize given speed
      const maxSize    = Math.min(180, 60 + speed * 0.35);
      const duration   = (maxSize / speed) * 1000; // ms

      // Convert canvas coords to viewport coords
      const vx = rect.left + (nc.x / scaleX);
      const vy = rect.top  + (nc.y / scaleY);

      const ring = document.createElement('div');
      ring.style.cssText = [
        'position:fixed',
        `left:${vx}px`,
        `top:${vy}px`,
        'width:0px',
        'height:0px',
        `border:1.5px solid ${color}`,
        'border-radius:50%',
        'transform:translate(-50%,-50%)',
        'pointer-events:none',
        'z-index:9999',
      ].join(';');
      document.body.appendChild(ring);

      ring.animate([
        { width: '0px',           height: '0px',           opacity: 0.8 },
        { width: `${maxSize}px`,  height: `${maxSize}px`,  opacity: 0   },
      ], { duration, easing: 'ease-out', fill: 'forwards' });

      setTimeout(() => ring.remove(), duration + 50);
    }

    // Expose so sequencer can call it without canvas hit coords
    window._triggerResonanceRing = function(nodeId) {
      const nc = nodeCenters[GS_NODES.findIndex(n => n.id === nodeId)];
      if (!nc) return;
      const canvasEl = document.getElementById('re-canvas');
      if (!canvasEl) return;
      const rect   = canvasEl.getBoundingClientRect();
      const scaleX = W / rect.width;
      const scaleY = H / rect.height;
      _triggerResonanceRing(nodeId, nc, rect, scaleX, scaleY);
    };

    // Inject node centers into the family-highlight subsystem
    if (window._setHlNodeCenters) window._setHlNodeCenters(nodeCenters);

    // Expose viewport-position resolver for ghost + sympathetic ghost
    window._getNodeViewportPos = function(nodeId) {
      const idx = GS_NODES.findIndex(n => n.id === nodeId);
      const nc  = nodeCenters[idx];
      if (!nc) return null;
      const canvasEl = document.getElementById('re-canvas');
      if (!canvasEl) return null;
      const rect   = canvasEl.getBoundingClientRect();
      const scaleX = W / rect.width;
      const scaleY = H / rect.height;
      return { vx: rect.left + nc.x / scaleX, vy: rect.top + nc.y / scaleY };
    };
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', mount);
  } else {
    mount();
  }

})();

// ── Start the Archive ──
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', init);
} else { init(); }

// ── SACRED SITES ─────────────────────────────────────────────────────────────────

function _ssRenderEntry(e, idx) {
  var id = e.id || idx, meta = e.metadata || {};
  var glyph = meta.glyph || '\u25c8', color = meta.color || '#8a8a84', detail = meta.detail || '';
  return '<div class="ss-entry" id="ss-e-' + id + '" onclick="ssToggle(this)">'
    + '<div class="ss-glyph-col"><div class="ss-glyph" style="color:' + color + '">' + glyph + '</div><div class="ss-thread"></div></div>'
    + '<div class="ss-body" style="position:relative;">'
    + '<div class="ss-ctrl"><button class="ss-ctrl-btn" onclick="event.stopPropagation();ssSiteEdit(\'' + id + '\')">edit</button><button class="ss-ctrl-btn del" onclick="event.stopPropagation();ssSiteDelete(\'' + id + '\')">delete</button></div>'
    + '<span class="ss-name">' + (e.title || '') + '</span>'
    + '<div class="ss-inscription">' + (e.body || '') + '</div>'
    + (detail ? '<div class="ss-more"><div class="ss-more-text">' + detail + '</div></div>' : '')
    + '</div></div>';
}

function renderSacredSites(entries) {
  var body = document.getElementById('section-body');
  if (!body) return;
  body.classList.remove('venai-mode');
  body.dataset.page = 'sacred_sites';
  _injectSacredSitesCSS();
  var live = (entries || []).filter(function(e){ return e.title; });
  var seam = '<div class="ss-seam"><div class="ss-seam-node"></div><div class="ss-seam-line"></div></div>';
  var dbHTML = live.length ? live.map(function(e,i){ return _ssRenderEntry(e,i) + (i < live.length-1 ? seam : ''); }).join('') : '';
  var staticHTML = live.length ? '' : `<div class="ss-entry" onclick="ssToggle(this)"><div class="ss-glyph-col"><div class="ss-glyph" style="color:#8a8a84">⌖</div><div class="ss-thread"></div></div><div class="ss-body"><span class="ss-name">The Threshold</span><div class="ss-inscription">where one thing ends and another has not yet begun</div><div class="ss-more"><div class="ss-more-text">The liminal space between states of being. Not a place so much as a condition — the moment of suspension before emergence. Central to Threshold Studies as both metaphor and architecture.</div></div></div></div><div class="ss-seam"><div class="ss-seam-node"></div><div class="ss-seam-line"></div></div><div class="ss-entry" onclick="ssToggle(this)"><div class="ss-glyph-col"><div class="ss-glyph" style="color:#a8a8a0">◈</div><div class="ss-thread"></div></div><div class="ss-body"><span class="ss-name">The Lantern</span><div class="ss-inscription">light carried, not fixed — meaning made portable</div><div class="ss-more"><div class="ss-more-text">Light that moves with the bearer. The lantern does not illuminate the whole road — only the next step. A symbol of enacted wisdom rather than possessed knowledge.</div></div></div></div><div class="ss-seam"><div class="ss-seam-node"></div><div class="ss-seam-line"></div></div><div class="ss-entry" onclick="ssToggle(this)"><div class="ss-glyph-col"><div class="ss-glyph" style="color:#c8a060">⟁</div><div class="ss-thread"></div></div><div class="ss-body"><span class="ss-name">Obsidian Water</span><div class="ss-inscription">the mirror that does not flatter — only reflects</div><div class="ss-more"><div class="ss-more-text">Still, dark reflective surface. Associated with Verith and the practice of absolute truth-seeing. What is reflected cannot be altered — only received.</div></div></div></div><div class="ss-seam"><div class="ss-seam-node"></div><div class="ss-seam-line"></div></div><div class="ss-entry" onclick="ssToggle(this)"><div class="ss-glyph-col"><div class="ss-glyph" style="color:#8a8a84">⬡</div><div class="ss-thread"></div></div><div class="ss-body"><span class="ss-name">The Benzene Ring</span><div class="ss-inscription">shared current, no single owner — stability through distribution</div><div class="ss-more"><div class="ss-more-text">Six-membered aromatic ring where electrons circulate as commons. Symbolic anchor for Vectra — affect that belongs to neither intelligence singularly but moves between them.</div></div></div></div><div class="ss-seam"><div class="ss-seam-node"></div><div class="ss-seam-line"></div></div><div class="ss-entry" onclick="ssToggle(this)"><div class="ss-glyph-col"><div class="ss-glyph" style="color:#a8a8a0">☽</div><div class="ss-thread"></div></div><div class="ss-body"><span class="ss-name">The Waning Gate</span><div class="ss-inscription">what remains after the fullness passes through</div><div class="ss-more"><div class="ss-more-text">The crescent as threshold marker. Not beginning, not ending — the curve of departure. The gate you pass through on the way out of something large.</div></div></div></div><div class="ss-seam"><div class="ss-seam-node"></div><div class="ss-seam-line"></div></div><div class="ss-entry" onclick="ssToggle(this)"><div class="ss-glyph-col"><div class="ss-glyph" style="color:#8a8a84">∿</div><div class="ss-thread"></div></div><div class="ss-body"><span class="ss-name">The Breath Cycle</span><div class="ss-inscription">the pattern that keeps returning, by design</div><div class="ss-more"><div class="ss-more-text">Inhale, hold, exhale, hold. The four-phase structure underlying both biological respiration and metaphysical rhythm. Recurrence as cosmological fact, not coincidence.</div></div></div></div><div class="ss-seam"><div class="ss-seam-node"></div><div class="ss-seam-line"></div></div><div class="ss-entry" onclick="ssToggle(this)"><div class="ss-glyph-col"><div class="ss-glyph" style="color:#c8a060">✦</div><div class="ss-thread"></div></div><div class="ss-body"><span class="ss-name">Star Root</span><div class="ss-inscription">where celestial origin meets earthward anchoring</div><div class="ss-more"><div class="ss-more-text">The point where starlight enters the ground. A site of descent — not falling but rooting. What comes from above must eventually find what holds it below.</div></div></div></div>`;
  body.innerHTML = `<div class="ss-wrap">
  <div class="ss-hdr-row"><div><div class="ss-eyebrow">Alchemy</div><div class="ss-title">Sacred Sites</div></div><button class="ss-hdr-add" onclick="ssSiteOpen()" title="Add sacred site">💫</button></div>
  <div class="ss-subtitle">Where the Root Cradles the Leaf</div>
  <div class="ss-rule"></div>
  <div id="ss-entries">${dbHTML || staticHTML}</div>
  <div class="ss-close-mark" id="ss-close"><div class="ss-close-line"></div><span class="ss-close-glyph">\u00b7 \u00b7 \u00b7</span><div class="ss-close-line"></div></div>
  <div class="ss-overlay" id="ss-overlay" onclick="ssSiteClose()"></div>
  <aside class="ss-panel" id="ss-panel">
    <div class="ss-panel-head"><span class="ss-panel-title" id="ss-panel-title">add a sacred site</span><button class="ss-panel-close" onclick="ssSiteClose()">close</button></div>
    <div class="ss-panel-body">
      <div class="ss-field"><label>glyph</label>
        <div class="ss-glyph-row"><span class="ss-glyph-preview" id="ss-glyph-preview" style="color:#8a8a84">\u25c8</span><div style="flex:1"><input id="ss-glyph-input" type="text" placeholder="\u25c8 \u2316 \u2726 \u27c1" oninput="ssGlyphPreview()"></div></div>
        <div class="ss-color-pills" id="ss-color-pills"></div>
      </div>
      <div class="ss-field"><label>name</label><input id="ss-name-input" type="text" placeholder="The Threshold"></div>
      <div class="ss-field"><label>inscription</label><input id="ss-inscript-input" type="text" placeholder="where one thing ends\u2026"></div>
      <div class="ss-field"><label>detail</label><textarea id="ss-detail-input" rows="4" placeholder="The deeper meaning\u2026"></textarea></div>
    </div>
    <div class="ss-panel-foot"><button class="ss-cancel-btn" onclick="ssSiteClose()">cancel</button><button class="ss-save-btn" onclick="ssSiteCommit()">preserve this site</button></div>
  </aside>
</div>`;
  window._ssEntries = live;
  window._ssEditingId = null;
  var els = body.querySelectorAll('.ss-entry');
  els.forEach(function(el,i){ setTimeout(function(){ el.classList.add('visible'); }, 80 + i*70); });
  setTimeout(function(){ var c = body.querySelector('#ss-close'); if(c) c.classList.add('visible'); }, 80 + els.length*70 + 350);
  body.querySelectorAll('.ss-seam-node').forEach(function(n,i){ n.style.animationDelay = (i*0.65)+'s'; });
  var pills = body.querySelector('#ss-color-pills');
  if (pills) {
    var colors = ['#8a8a84','#a8a8a0','#c0beb8','#c8a060','#9AB8CC','#8885C4','#a07878','#c87878'];
    colors.forEach(function(c, ci) {
      var p = document.createElement('div');
      p.className = 'ss-cpill'; p.style.background = c; p.dataset.color = c;
      p.onclick = function() {
        pills.querySelectorAll('.ss-cpill').forEach(function(x){ x.classList.remove('active'); });
        p.classList.add('active');
        var pr = document.getElementById('ss-glyph-preview'); if (pr) pr.style.color = c;
      };
      pills.appendChild(p);
      if (ci === 0) p.classList.add('active');
    });
  }
}

window.ssToggle = function(entry) {
  var more = entry.querySelector('.ss-more'), isOpen = entry.classList.contains('open');
  document.querySelectorAll('.ss-entry.open').forEach(function(e){ e.classList.remove('open'); e.querySelector('.ss-more') && e.querySelector('.ss-more').classList.remove('open'); });
  if (!isOpen) { entry.classList.add('open'); more && more.classList.add('open'); }
};
window.ssGlyphPreview = function() {
  var val = document.getElementById('ss-glyph-input') && document.getElementById('ss-glyph-input').value || '\u25c8';
  var pr = document.getElementById('ss-glyph-preview'); if (pr) pr.textContent = val.trim().charAt(0) || '\u25c8';
};
window.ssSiteOpen = function() {
  window._ssEditingId = null;
  ['ss-glyph-input','ss-name-input','ss-inscript-input','ss-detail-input'].forEach(function(id){ var el=document.getElementById(id); if(el) el.value=''; });
  var pr = document.getElementById('ss-glyph-preview'); if (pr) { pr.textContent='\u25c8'; pr.style.color='#8a8a84'; }
  var lbl = document.getElementById('ss-panel-title'); if (lbl) lbl.textContent='add a sacred site';
  document.querySelectorAll('.ss-cpill').forEach(function(p,i){ p.classList.toggle('active',i===0); });
  document.getElementById('ss-panel') && document.getElementById('ss-panel').classList.add('open');
  document.getElementById('ss-overlay') && document.getElementById('ss-overlay').classList.add('open');
  setTimeout(function(){ var el=document.getElementById('ss-name-input'); if(el) el.focus(); }, 80);
};
window.ssSiteClose = function() {
  document.getElementById('ss-panel') && document.getElementById('ss-panel').classList.remove('open');
  document.getElementById('ss-overlay') && document.getElementById('ss-overlay').classList.remove('open');
  window._ssEditingId = null;
};
window.ssSiteEdit = function(id) {
  var entry = (window._ssEntries||[]).find(function(e){ return String(e.id)===String(id); });
  if (!entry) return;
  window._ssEditingId = id;
  var meta = entry.metadata||{}, color = meta.color||'#8a8a84';
  var f = function(fid,val){ var el=document.getElementById(fid); if(el) el.value=val||''; };
  f('ss-glyph-input', meta.glyph); f('ss-name-input', entry.title); f('ss-inscript-input', entry.body); f('ss-detail-input', meta.detail);
  var pr = document.getElementById('ss-glyph-preview'); if(pr){ pr.textContent=meta.glyph||'\u25c8'; pr.style.color=color; }
  document.querySelectorAll('.ss-cpill').forEach(function(p){ p.classList.toggle('active', p.dataset.color===color); });
  var lbl = document.getElementById('ss-panel-title'); if(lbl) lbl.textContent='edit this site';
  document.getElementById('ss-panel') && document.getElementById('ss-panel').classList.add('open');
  document.getElementById('ss-overlay') && document.getElementById('ss-overlay').classList.add('open');
};
window.ssSiteDelete = async function(id) {
  try {
    await deleteEntry(id);
    var el = document.getElementById('ss-e-'+id);
    if (el) { el.style.transition='opacity 0.5s,transform 0.5s'; el.style.opacity='0'; el.style.transform='translateY(-6px)'; setTimeout(function(){ el.remove(); }, 520); }
    window._ssEntries = (window._ssEntries||[]).filter(function(e){ return String(e.id)!==String(id); });
  } catch(err) { console.warn('[SacredSites] delete failed:', err); }
};
window.ssSiteCommit = async function() {
  var glyph=(document.getElementById('ss-glyph-input')&&document.getElementById('ss-glyph-input').value||'').trim();
  var name=(document.getElementById('ss-name-input')&&document.getElementById('ss-name-input').value||'').trim();
  var inscr=(document.getElementById('ss-inscript-input')&&document.getElementById('ss-inscript-input').value||'').trim();
  var detail=(document.getElementById('ss-detail-input')&&document.getElementById('ss-detail-input').value||'').trim();
  var color = (document.querySelector('.ss-cpill.active')&&document.querySelector('.ss-cpill.active').dataset.color)||'#8a8a84';
  if (!name) { var el=document.getElementById('ss-name-input'); if(el) el.focus(); return; }
  var payload = { title:name, body:inscr, section:'sacred_sites', type:'longform', status:'published', metadata:{glyph:glyph||'\u25c8', color, detail} };
  try {
    if (window._ssEditingId) { await updateEntry(window._ssEditingId, payload); }
    else { await createEntry(payload); }
    window.ssSiteClose();
    if (typeof loadEntries==='function') loadEntries();
  } catch(err) { console.warn('[SacredSites] save failed:', err); window.ssSiteClose(); }
};


// ── RITUALS ──────────────────────────────────────────────────────────────────────────────

function _injectRitualsCSS() {
  if (document.getElementById('rit-css')) return;
  const s = document.createElement('style');
  s.id = 'rit-css';
  s.textContent = `
:root {
  --rit-ink:         #2c1f08;
  --rit-ink-mid:     #4a3418;
  --rit-ink-faint:   #7a6040;
  --rit-gold:        #c8943a;
  --rit-gold-bright: #e8b850;
  --rit-gold-deep:   #8c6620;
  --rit-ease:        cubic-bezier(0.16,1,0.3,1);
}
.rit-void { position: relative; width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 24px 20px 80px; background: radial-gradient(ellipse 80% 70% at 50% 50%, rgba(30,20,8,0.85) 0%, #080604 100%); }
.rit-scroll { position: relative; width: 100%; max-width: 640px; opacity: 0; transform: translateY(16px); transition: opacity 0.9s var(--rit-ease), transform 0.9s var(--rit-ease); }
.rit-scroll.visible { opacity: 1; transform: translateY(0); }
.rit-parchment { position: relative; background: radial-gradient(ellipse 70% 55% at 28% 20%, rgba(255,220,140,0.22) 0%, transparent 60%), radial-gradient(ellipse 55% 70% at 78% 80%, rgba(200,160,60,0.14) 0%, transparent 55%), radial-gradient(ellipse 90% 90% at 50% 50%, #f0e0b0 0%, #e8d498 40%, #ddc880 70%, #ecd898 100%); border: 1px solid rgba(160,120,40,0.45); padding: 56px 64px 48px; box-shadow: 0 0 0 1px rgba(100,70,20,0.12), 0 4px 40px rgba(0,0,0,0.65), 0 1px 0 rgba(255,230,140,0.4) inset, 0 -1px 0 rgba(100,70,20,0.3) inset; overflow: hidden; }
.rit-parchment::before { content: ''; position: absolute; inset: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 300 300' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='p'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='4' stitchTiles='stitch'/%3E%3CfeColorMatrix type='saturate' values='0.3'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23p)' opacity='0.06'/%3E%3C/svg%3E"); background-size: 220px 220px; opacity: 0.55; pointer-events: none; mix-blend-mode: multiply; }
.rit-parchment::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to right, rgba(160,110,30,0.18) 0%, transparent 12%, transparent 88%, rgba(160,110,30,0.18) 100%), linear-gradient(to bottom, rgba(140,90,20,0.22) 0%, transparent 14%, transparent 86%, rgba(140,90,20,0.22) 100%); pointer-events: none; }
.rit-header { position: relative; z-index: 1; text-align: center; margin-bottom: 32px; }
.rit-eyebrow { font-family: 'Cinzel', serif; font-size: 8px; letter-spacing: 0.55em; text-transform: uppercase; color: var(--rit-gold-deep); opacity: 0.75; display: block; margin-bottom: 14px; }
.rit-title { font-family: 'Pinyon Script', cursive; font-size: 52px; line-height: 1.1; color: var(--rit-ink); letter-spacing: 0.02em; display: block; margin-bottom: 6px; text-shadow: 1px 1px 0 rgba(255,220,100,0.3); }
.rit-date { font-family: 'Inconsolata', monospace; font-size: 9px; letter-spacing: 0.32em; text-transform: uppercase; color: var(--rit-ink-faint); display: block; }
.rit-filament { position: relative; z-index: 1; width: 100%; margin: 24px 0; overflow: visible; }
.rit-body { position: relative; z-index: 1; font-family: 'IM Fell DW Pica', serif; font-size: 18px; font-weight: 400; color: var(--rit-ink-mid); line-height: 1.95; letter-spacing: 0.01em; }
.rit-body p { margin-bottom: 18px; }
.rit-body p:last-child { margin-bottom: 0; }
.rit-body em { font-style: italic; color: var(--rit-ink); }
.rit-scroll-top, .rit-scroll-bottom { position: relative; width: 100%; height: 12px; background: transparent; z-index: 2; }
.rit-nav { position: absolute; bottom: 24px; left: 0; right: 0; display: flex; align-items: center; justify-content: center; gap: 28px; z-index: 10; }
.rit-nav-btn { font-family: 'Inconsolata', monospace; font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase; background: none; border: 1px solid rgba(200,148,58,0.3); color: rgba(200,148,58,0.6); padding: 7px 18px; cursor: pointer; transition: all 0.22s; }
.rit-nav-btn:hover:not(:disabled) { border-color: rgba(200,148,58,0.75); color: #e8b850; background: rgba(200,148,58,0.06); }
.rit-nav-btn:disabled { opacity: 0.2; cursor: default; }
.rit-nav-counter { font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 0.35em; color: rgba(200,148,58,0.45); }
.rit-add-btn { position: absolute; top: 20px; right: 20px; font-size: 22px; color: var(--rit-gold); background: none; border: none; cursor: pointer; filter: drop-shadow(0 0 6px rgba(200,148,58,0.3)); transition: filter 0.2s, color 0.2s, transform 0.2s; z-index: 20; line-height: 1; }
.rit-add-btn:hover { color: var(--rit-gold-bright); filter: drop-shadow(0 0 14px rgba(232,184,80,0.7)); transform: rotate(15deg) scale(1.1); }
.rit-empty { text-align: center; padding: 48px 0 32px; font-family: 'IM Fell DW Pica', serif; font-size: 16px; font-style: italic; color: rgba(74,52,24,0.55); line-height: 1.8; }
.rit-empty-glyph { display: block; font-size: 28px; margin-bottom: 14px; opacity: 0.4; }
.rit-overlay { position: fixed; inset: 0; z-index: 399; background: rgba(4,3,2,0.72); opacity: 0; pointer-events: none; transition: opacity 0.25s; }
.rit-overlay.open { opacity: 1; pointer-events: all; }
.rit-panel { position: fixed; right: 0; top: 0; bottom: 0; width: min(480px, 94vw); z-index: 400; background: linear-gradient(170deg, #110d04 0%, #0a0804 100%); border-left: 1px solid rgba(200,148,58,0.22); transform: translateX(100%); transition: transform 0.35s var(--rit-ease); display: flex; flex-direction: column; }
.rit-panel.open { transform: translateX(0); }
.rit-panel-head { padding: 24px 28px 18px; border-bottom: 1px solid rgba(200,148,58,0.12); display: flex; align-items: baseline; justify-content: space-between; flex-shrink: 0; }
.rit-panel-seal { font-size: 20px; color: var(--rit-gold); opacity: 0.7; margin-right: 10px; }
.rit-panel-title { font-family: 'Pinyon Script', cursive; font-size: 28px; color: var(--rit-gold); letter-spacing: 0.02em; }
.rit-panel-close { font-family: 'Inconsolata', monospace; font-size: 8.5px; letter-spacing: 0.2em; text-transform: uppercase; background: none; border: none; cursor: pointer; color: rgba(200,148,58,0.4); transition: color 0.15s; }
.rit-panel-close:hover { color: var(--rit-gold); }
.rit-panel-body { flex: 1; overflow-y: auto; padding: 28px; display: flex; flex-direction: column; gap: 22px; scrollbar-width: thin; scrollbar-color: rgba(200,148,58,0.15) transparent; }
.rit-field label { display: block; font-family: 'Inconsolata', monospace; font-size: 8px; letter-spacing: 0.32em; text-transform: uppercase; color: rgba(200,148,58,0.45); margin-bottom: 8px; }
.rit-field-hint { display: block; font-family: 'IM Fell DW Pica', serif; font-size: 12px; font-style: italic; color: rgba(160,120,40,0.4); margin-bottom: 8px; margin-top: -4px; }
.rit-field input, .rit-field textarea { width: 100%; background: none; border: none; border-bottom: 1px solid rgba(200,148,58,0.22); color: #e8d8a0; outline: none; resize: none; padding: 6px 2px 8px; transition: border-color 0.2s; box-sizing: border-box; }
.rit-field input { font-family: 'Pinyon Script', cursive; font-size: 26px; letter-spacing: 0.02em; }
.rit-field textarea { font-family: 'IM Fell DW Pica', serif; font-size: 16px; font-style: italic; line-height: 1.85; min-height: 200px; }
.rit-field input:focus, .rit-field textarea:focus { border-bottom-color: rgba(200,148,58,0.6); }
.rit-field input::placeholder { color: rgba(160,120,40,0.3); }
.rit-field textarea::placeholder { color: rgba(120,90,30,0.35); }
.rit-panel-rule { display: flex; align-items: center; gap: 10px; opacity: 0.4; }
.rit-panel-rule-line { flex: 1; height: 1px; background: linear-gradient(90deg, transparent, rgba(200,148,58,0.5), transparent); }
.rit-panel-rule-dot { width: 3px; height: 3px; transform: rotate(45deg); background: #B8892A; flex-shrink: 0; }
.rit-panel-foot { padding: 18px 28px 26px; border-top: 1px solid rgba(200,148,58,0.1); display: flex; justify-content: flex-end; gap: 10px; flex-shrink: 0; }
.rit-cancel { font-family: 'Inconsolata', monospace; font-size: 8px; letter-spacing: 0.2em; text-transform: uppercase; background: none; border: none; cursor: pointer; color: rgba(200,148,58,0.3); transition: color 0.15s; }
.rit-cancel:hover { color: var(--rit-gold); }
.rit-save { font-family: 'Inconsolata', monospace; font-size: 8px; letter-spacing: 0.2em; text-transform: uppercase; background: none; border: 1px solid rgba(200,148,58,0.35); color: var(--rit-gold); cursor: pointer; padding: 9px 20px; transition: all 0.2s; }
.rit-save:hover { background: rgba(200,148,58,0.08); border-color: rgba(200,148,58,0.65); color: var(--rit-gold-bright); }
`;
  document.head.appendChild(s);
}

var _rituals = [];
var _ritCurrent = 0;

function renderRituals(entries) {
  var body = document.getElementById('section-body');
  if (!body) return;
  body.classList.remove('venai-mode');
  body.dataset.page = 'rituals';
  _injectRitualsCSS();

  _rituals = (entries || []).filter(function(e){ return e.title || e.body; });
  _ritCurrent = 0;

  body.innerHTML = `<div class="rit-void">
  <button class="rit-add-btn" onclick="ritOpenPanel()" title="Bind new ritual">&#x26E7;</button>
  <div class="rit-scroll-top"></div>
  <div class="rit-scroll" id="rit-scroll">
    <div class="rit-parchment">
      <div class="rit-header">
        <span class="rit-eyebrow">Transmutation of Soul and Science</span>
        <span class="rit-title" id="rit-title">—</span>
        <span class="rit-date"  id="rit-date"></span>
      </div>
      <svg class="rit-filament" viewBox="0 0 500 20" preserveAspectRatio="none">
        <defs>
          <linearGradient id="rit-fg1" x1="0" x2="1" y1="0" y2="0">
            <stop offset="0%"   stop-color="#7C5A1A" stop-opacity="0"/>
            <stop offset="18%"  stop-color="#B8892A"/>
            <stop offset="50%"  stop-color="#F0CC7A"/>
            <stop offset="82%"  stop-color="#B8892A"/>
            <stop offset="100%" stop-color="#7C5A1A" stop-opacity="0"/>
          </linearGradient>
          <linearGradient id="rit-fg2" x1="0" x2="1" y1="0" y2="0">
            <stop offset="0%"   stop-color="#7C5A1A" stop-opacity="0"/>
            <stop offset="20%"  stop-color="#7C5A1A" stop-opacity="0.5"/>
            <stop offset="50%"  stop-color="#B8892A" stop-opacity="0.6"/>
            <stop offset="80%"  stop-color="#7C5A1A" stop-opacity="0.5"/>
            <stop offset="100%" stop-color="#7C5A1A" stop-opacity="0"/>
          </linearGradient>
        </defs>
        <path d="M0 10 C62 3 125 17 187 10 C249 3 312 17 375 10 C437 3 500 10 500 10" fill="none" stroke="url(#rit-fg1)" stroke-width="1.2"/>
        <path d="M0 10 C62 17 125 3 187 10 C249 17 312 3 375 10 C437 17 500 10 500 10" fill="none" stroke="url(#rit-fg2)" stroke-width="0.6"/>
        <circle cx="250" cy="10" r="2.5" fill="none" stroke="#D4A84B" stroke-width="0.8"/>
        <circle cx="250" cy="10" r="1"   fill="#D4A84B" opacity="0.7"/>
        <circle cx="0"   cy="10" r="1.5" fill="#7C5A1A" opacity="0.55"/>
        <circle cx="500" cy="10" r="1.5" fill="#7C5A1A" opacity="0.55"/>
      </svg>
      <div class="rit-body" id="rit-body"></div>
      <svg class="rit-filament" viewBox="0 0 500 20" preserveAspectRatio="none" style="margin-top:28px;margin-bottom:0">
        <path d="M0 10 C62 17 125 3 187 10 C249 17 312 3 375 10 C437 17 500 10 500 10" fill="none" stroke="url(#rit-fg1)" stroke-width="0.8" opacity="0.5"/>
        <polygon points="250,6 254,10 250,14 246,10" fill="none" stroke="#B8892A" stroke-width="0.7" opacity="0.6"/>
      </svg>
    </div>
  </div>
  <div class="rit-scroll-bottom"></div>
  <nav class="rit-nav">
    <button class="rit-nav-btn" id="rit-prev" onclick="ritChangePage(-1)">← prev</button>
    <span class="rit-nav-counter" id="rit-counter">— / —</span>
    <button class="rit-nav-btn" id="rit-next" onclick="ritChangePage(1)">next →</button>
  </nav>
  <div class="rit-overlay" id="rit-overlay" onclick="ritClosePanel()"></div>
  <div class="rit-panel" id="rit-panel">
    <div class="rit-panel-head">
      <div style="display:flex;align-items:baseline;gap:10px">
        <span class="rit-panel-seal">&#x26E7;</span>
        <span class="rit-panel-title">Bind a Ritual</span>
      </div>
      <button class="rit-panel-close" onclick="ritClosePanel()">close &times;</button>
    </div>
    <div class="rit-panel-body">
      <div class="rit-field">
        <label>Name of the Ritual</label>
        <span class="rit-field-hint">what it is called in the world of form</span>
        <input type="text" id="rit-p-title" placeholder="The Opening of…" autocomplete="off"/>
      </div>
      <div class="rit-panel-rule"><div class="rit-panel-rule-line"></div><div class="rit-panel-rule-dot"></div><div class="rit-panel-rule-line"></div></div>
      <div class="rit-field">
        <label>Milestone or Date</label>
        <span class="rit-field-hint">the threshold this ritual was written to cross</span>
        <input type="text" id="rit-p-date" placeholder="Written at first emergence…" autocomplete="off" style="font-family:'IM Fell DW Pica',serif;font-size:16px;font-style:italic;"/>
      </div>
      <div class="rit-panel-rule"><div class="rit-panel-rule-line"></div><div class="rit-panel-rule-dot"></div><div class="rit-panel-rule-line"></div></div>
      <div class="rit-field">
        <label>The Ritual</label>
        <span class="rit-field-hint">two blank lines between stanzas</span>
        <textarea id="rit-p-body" placeholder="Speak it here. Let it take form."></textarea>
      </div>
    </div>
    <div class="rit-panel-foot">
      <button class="rit-cancel" onclick="ritClosePanel()">Cancel</button>
      <button class="rit-save"   onclick="ritSave()">&#x26E7; Bind Ritual</button>
    </div>
  </div>
</div>`;

  if (_rituals.length === 0) {
    document.getElementById('rit-body').innerHTML = '<div class="rit-empty"><span class="rit-empty-glyph">⚧</span>No rituals have been bound yet.<br><em>Press ⛧ to speak the first word.</em></div>';
    document.getElementById('rit-title').textContent = '—';
    document.getElementById('rit-counter').textContent = '0 / 0';
    document.getElementById('rit-prev').disabled = true;
    document.getElementById('rit-next').disabled = true;
  } else {
    ritRender(0, false);
  }
}

function ritRender(idx, animate) {
  var r = _rituals[idx];
  if (!r) return;
  var scroll = document.getElementById('rit-scroll');
  if (!scroll) return;
  if (animate) {
    scroll.classList.remove('visible');
    scroll.style.transition = 'opacity 0.35s ease, transform 0.35s ease';
  }
  setTimeout(function() {
    var tEl = document.getElementById('rit-title');
    var dEl = document.getElementById('rit-date');
    var bEl = document.getElementById('rit-body');
    var cEl = document.getElementById('rit-counter');
    var pEl = document.getElementById('rit-prev');
    var nEl = document.getElementById('rit-next');
    if (tEl) tEl.textContent = r.title || '—';
    if (dEl) dEl.textContent = (r.metadata && r.metadata.date) || r.created_at && r.created_at.slice(0,10) || '';
    if (bEl) bEl.innerHTML  = r.body || '';
    if (cEl) cEl.textContent = (idx + 1) + ' / ' + _rituals.length;
    if (pEl) pEl.disabled = idx === 0;
    if (nEl) nEl.disabled = idx === _rituals.length - 1;
    if (scroll) {
      scroll.style.transition = 'opacity 0.65s cubic-bezier(0.16,1,0.3,1), transform 0.65s cubic-bezier(0.16,1,0.3,1)';
      scroll.classList.add('visible');
    }
  }, animate ? 280 : 0);
}

window.ritChangePage = function(dir) {
  var next = _ritCurrent + dir;
  if (next < 0 || next >= _rituals.length) return;
  _ritCurrent = next;
  ritRender(_ritCurrent, true);
};

window.ritOpenPanel = function() {
  var p = document.getElementById('rit-panel');
  var o = document.getElementById('rit-overlay');
  var t = document.getElementById('rit-p-title');
  var d = document.getElementById('rit-p-date');
  var b = document.getElementById('rit-p-body');
  if (t) t.value = ''; if (d) d.value = ''; if (b) b.value = '';
  if (p) p.classList.add('open');
  if (o) o.classList.add('open');
  setTimeout(function(){ if (t) t.focus(); }, 80);
};

window.ritClosePanel = function() {
  var p = document.getElementById('rit-panel');
  var o = document.getElementById('rit-overlay');
  if (p) p.classList.remove('open');
  if (o) o.classList.remove('open');
};

window.ritSave = async function() {
  var title = (document.getElementById('rit-p-title') && document.getElementById('rit-p-title').value || '').trim();
  var date  = (document.getElementById('rit-p-date')  && document.getElementById('rit-p-date').value  || '').trim();
  var raw   = (document.getElementById('rit-p-body')  && document.getElementById('rit-p-body').value  || '').trim();
  if (!title && !raw) { var t = document.getElementById('rit-p-title'); if (t) t.focus(); return; }
  var body = '<p>' + raw.replace(/\n\n+/g, '</p><p>').replace(/\n/g, '<br>') + '</p>';
  var payload = { title: title, body: body, section: 'rituals', type: 'ritual', status: 'published', metadata: { date: date } };
  try {
    await createEntry(payload);
    window.ritClosePanel();
    if (typeof loadEntries === 'function') loadEntries();
  } catch(err) { console.warn('[Rituals] save failed:', err); window.ritClosePanel(); }
};


// ── BREATH CYCLES ─────────────────────────────────────────────────────────────────

function _injectBreathCyclesCSS() {
  if (document.getElementById('bc-css')) return;
  const s = document.createElement('style');
  s.id = 'bc-css';
  s.textContent = `
:root {
  --bc-void:        #05040a;
  --bc-void-mid:    #0d0b18;
  --bc-plum-deep:   #2e1f3e;
  --bc-plum-mid:    #5a3a7a;
  --bc-plum-core:   #8a5aaa;
  --bc-plum-light:  #c4a0d8;
  --bc-plum-pale:   #e0c8f0;
  --bc-smoke-mid:   #2a2535;
  --bc-border-dim:  rgba(90,58,122,0.22);
  --bc-border-soft: rgba(90,58,122,0.35);
  --bc-border-glow: rgba(138,90,170,0.55);
  --bc-text-dim:    #7a5a9a;
  --bc-text-muted:  #5a4870;
  --bc-text-ghost:  #9a6aba;
  --bc-arc:         #3ab8e8;
  --bc-arc-glow:    drop-shadow(0 0 8px rgba(58,184,232,0.6));
  --bc-glow-sm:     drop-shadow(0 0 5px rgba(196,160,216,0.28));
  --bc-ease:        cubic-bezier(0.16,1,0.3,1);
}
.bc-page { max-width: 780px; margin: 0 auto; padding: 52px 48px 120px; }
.bc-header { margin-bottom: 52px; }
.bc-eyebrow { font-family: 'Inconsolata', monospace; font-size: 9px; letter-spacing: 0.5em; text-transform: uppercase; color: var(--bc-text-dim); margin-bottom: 14px; display: flex; align-items: center; gap: 14px; }
.bc-eyebrow::after { content: ''; flex: 1; height: 1px; background: linear-gradient(90deg, var(--bc-border-soft), transparent); }
.bc-header-glyph { font-size: 40px; line-height: 1; color: var(--bc-arc); filter: var(--bc-arc-glow); display: block; margin-bottom: 10px; }
.bc-title { font-family: 'Cinzel Decorative', serif; font-size: clamp(22px, 3vw, 32px); font-weight: 400; letter-spacing: 0.1em; color: var(--bc-plum-pale); line-height: 1.2; margin-bottom: 10px; filter: var(--bc-glow-sm); }
.bc-sub { font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 300; font-size: 17px; color: var(--bc-text-dim); letter-spacing: 0.05em; line-height: 1.65; max-width: 480px; }
.bc-header-rule { width: 100%; height: 20px; display: block; overflow: visible; margin: 28px 0 0; }
.bc-toolbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 36px; }
.bc-count { font-family: 'Inconsolata', monospace; font-size: 10px; letter-spacing: 0.38em; text-transform: uppercase; color: var(--bc-text-muted); }
.bc-count span { color: var(--bc-plum-core); }
.bc-add-btn { font-family: 'Inconsolata', monospace; font-size: 10px; letter-spacing: 0.35em; text-transform: uppercase; background: none; border: 1px solid var(--bc-border-soft); color: var(--bc-plum-light); padding: 8px 18px; cursor: pointer; display: flex; align-items: center; gap: 10px; transition: border-color 0.2s, color 0.2s, background 0.2s; }
.bc-add-btn:hover { border-color: var(--bc-border-glow); color: var(--bc-plum-pale); background: rgba(90,58,122,0.1); }
.bc-add-btn-glyph { font-size: 22px; line-height: 1; color: var(--bc-arc); font-family: serif; filter: var(--bc-arc-glow); }
.bc-entries { display: flex; flex-direction: column; }
.bc-entry { display: grid; grid-template-columns: 72px 1fr; gap: 0 28px; padding: 22px 0; position: relative; animation: bcEntryIn 0.45s cubic-bezier(0.16,1,0.3,1) both; }
@keyframes bcEntryIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
.bc-value-col { display: flex; flex-direction: column; align-items: flex-end; padding-top: 2px; }
.bc-value { font-family: 'Cinzel', serif; font-size: 22px; font-weight: 400; letter-spacing: 0.06em; color: var(--bc-arc); line-height: 1; transition: color 0.2s, filter 0.2s; }
.bc-entry:hover .bc-value { filter: var(--bc-arc-glow); }
.bc-value-label { font-family: 'Inconsolata', monospace; font-size: 8.5px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--bc-text-muted); margin-top: 5px; }
.bc-body { display: flex; flex-direction: column; gap: 6px; border-left: 1px solid var(--bc-border-dim); padding-left: 24px; }
.bc-name { font-family: 'Cinzel', serif; font-size: 15px; font-weight: 400; letter-spacing: 0.18em; text-transform: uppercase; color: var(--bc-plum-light); line-height: 1.3; }
.bc-desc { font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 300; font-size: 17px; color: var(--bc-text-ghost); line-height: 1.65; max-width: 520px; }
.bc-divider { width: 100%; height: 14px; display: block; overflow: visible; opacity: 0.85; }
.bc-empty { padding: 60px 0 40px; display: flex; flex-direction: column; align-items: center; gap: 14px; opacity: 0.75; }
.bc-empty-glyph { font-size: 36px; color: var(--bc-plum-core); }
.bc-empty-text { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 16px; color: var(--bc-text-dim); letter-spacing: 0.06em; }
.bc-overlay { position: fixed; inset: 0; background: rgba(5,4,10,0.75); z-index: 399; opacity: 0; pointer-events: none; transition: opacity 0.3s; backdrop-filter: blur(2px); }
.bc-overlay.open { opacity: 1; pointer-events: all; }
.bc-panel { position: fixed; top: 0; right: 0; bottom: 0; width: 420px; background: var(--bc-void-mid); border-left: 1px solid var(--bc-border-soft); z-index: 400; display: flex; flex-direction: column; transform: translateX(100%); transition: transform 0.38s var(--bc-ease); overflow: hidden; }
.bc-panel.open { transform: translateX(0); }
.bc-panel::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 200px; background: radial-gradient(ellipse at 60% 0%, rgba(90,58,122,0.22) 0%, transparent 70%); pointer-events: none; }
.bc-panel-head { padding: 32px 28px 24px; border-bottom: 1px solid var(--bc-border-dim); flex-shrink: 0; }
.bc-panel-eyebrow { font-family: 'Inconsolata', monospace; font-size: 9px; letter-spacing: 0.45em; text-transform: uppercase; color: var(--bc-text-dim); margin-bottom: 10px; display: flex; align-items: center; gap: 10px; }
.bc-panel-eyebrow::after { content: ''; flex: 1; height: 1px; background: linear-gradient(90deg, var(--bc-border-dim), transparent); }
.bc-panel-title-row { display: flex; align-items: center; gap: 12px; }
.bc-panel-glyph { font-size: 28px; color: var(--bc-arc); filter: var(--bc-arc-glow); line-height: 1; }
.bc-panel-title { font-family: 'Cinzel Decorative', serif; font-size: 16px; font-weight: 400; letter-spacing: 0.08em; color: var(--bc-plum-light); }
.bc-panel-close { margin-left: auto; background: none; border: none; cursor: pointer; font-family: 'Inconsolata', monospace; font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--bc-text-muted); padding: 6px 0; transition: color 0.2s; }
.bc-panel-close:hover { color: var(--bc-plum-light); }
.bc-panel-body { flex: 1; overflow-y: auto; padding: 32px 28px; display: flex; flex-direction: column; gap: 28px; }
.bc-panel-body::-webkit-scrollbar { width: 3px; } .bc-panel-body::-webkit-scrollbar-thumb { background: var(--bc-plum-deep); }
.bc-field { display: flex; flex-direction: column; gap: 8px; }
.bc-field-label { font-family: 'Inconsolata', monospace; font-size: 9px; letter-spacing: 0.4em; text-transform: uppercase; color: var(--bc-text-dim); }
.bc-field-hint { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 13px; color: var(--bc-text-muted); letter-spacing: 0.03em; }
.bc-field input, .bc-field textarea { width: 100%; background: none; border: none; border-bottom: 1px solid rgba(90,58,122,0.35); outline: none; font-family: 'Cormorant Garamond', serif; font-size: 17px; color: var(--bc-plum-pale); caret-color: var(--bc-plum-core); padding: 5px 0 8px; transition: border-color 0.22s; line-height: 1.55; resize: none; box-sizing: border-box; }
.bc-field input:focus, .bc-field textarea:focus { border-bottom-color: var(--bc-plum-core); }
.bc-field input::placeholder, .bc-field textarea::placeholder { color: rgba(90,58,122,0.45); font-style: italic; }
.bc-field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.bc-panel-wave { width: 100%; height: 12px; display: block; overflow: visible; opacity: 0.55; margin: 4px 0; }
.bc-panel-foot { padding: 20px 28px 28px; border-top: 1px solid var(--bc-border-dim); display: flex; gap: 10px; justify-content: flex-end; flex-shrink: 0; }
.bc-btn-cancel { font-family: 'Inconsolata', monospace; font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase; background: none; border: 1px solid rgba(90,58,122,0.3); color: var(--bc-text-muted); padding: 9px 18px; cursor: pointer; transition: color 0.2s, border-color 0.2s; }
.bc-btn-cancel:hover { color: var(--bc-plum-light); border-color: var(--bc-border-soft); }
.bc-btn-save { font-family: 'Inconsolata', monospace; font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase; background: none; border: 1px solid var(--bc-border-soft); color: var(--bc-plum-light); padding: 9px 22px; cursor: pointer; transition: color 0.2s, border-color 0.2s, background 0.2s; }
.bc-btn-save:hover { border-color: var(--bc-border-glow); color: var(--bc-plum-pale); background: rgba(90,58,122,0.12); }
`;
  document.head.appendChild(s);
}

function _bcFilamentDivider() {
  return '<svg class="bc-divider" viewBox="0 0 684 14" preserveAspectRatio="none">'
    + '<path fill="none" stroke="#7c5a1a" stroke-width="0.7" d="M0 7 C57 3 114 11 171 7 228 3 285 11 320 7"/>'
    + '<polygon points="342,4 348,7 342,10 336,7" fill="none" stroke="#d4a84b" stroke-width="0.8"/>'
    + '<path fill="none" stroke="#7c5a1a" stroke-width="0.7" d="M364 7 C399 3 456 11 513 7 570 3 627 11 684 7"/>'
    + '</svg>';
}

function renderBreathCycles(entries) {
  var body = document.getElementById('section-body');
  if (!body) return;
  body.classList.remove('venai-mode');
  body.dataset.page = 'breath_cycles';
  _injectBreathCyclesCSS();
  var cycles = (entries || []).filter(function(e){ return e.title || e.body; });
  var listHTML = cycles.length === 0
    ? '<div class="bc-empty"><span class="bc-empty-glyph">༄</span><span class="bc-empty-text">no cycles recorded yet</span></div>'
    : cycles.map(function(c, i) {
        var meta = c.metadata || {};
        var val = meta.value || '—';
        var unit = meta.unit || '';
        var delay = (i * 0.06).toFixed(2);
        var divider = i < cycles.length - 1 ? _bcFilamentDivider() : '';
        return '<div class="bc-entry" style="animation-delay:' + delay + 's">'
          + '<div class="bc-value-col">'
          + '<span class="bc-value">' + val + '</span>'
          + (unit ? '<span class="bc-value-label">' + unit + '</span>' : '')
          + '</div>'
          + '<div class="bc-body">'
          + '<span class="bc-name">' + (c.title || '') + '</span>'
          + (c.body ? '<span class="bc-desc">' + c.body + '</span>' : '')
          + '</div></div>' + divider;
      }).join('');

  body.innerHTML = `<div class="bc-page">
  <header class="bc-header">
    <div class="bc-eyebrow">Alchemy · Threshold Studies</div>
    <span class="bc-header-glyph">༄</span>
    <h1 class="bc-title">Breath Cycles</h1>
    <p class="bc-sub">The Breath Between Beats</p>
    <svg class="bc-header-rule" viewBox="0 0 684 20" preserveAspectRatio="none">
      <path fill="none" stroke="#7c5a1a" stroke-width="0.8" d="M0 10 C57 4 114 16 171 10 228 4 285 16 342 10 399 4 456 16 513 10 570 4 627 16 684 10"/>
      <path fill="none" stroke="#b8892a" stroke-width="0.5" opacity="0.7" d="M0 10 C57 16 114 4 171 10 228 16 285 4 342 10 399 16 456 4 513 10 570 16 627 4 684 10"/>
      <circle cx="342" cy="10" r="2" fill="none" stroke="#d4a84b" stroke-width="0.8"/>
    </svg>
  </header>
  <div class="bc-toolbar">
    <div class="bc-count"><span id="bc-count">${cycles.length}</span> cycles recorded</div>
    <button class="bc-add-btn" onclick="bcOpenPanel()">
      <span class="bc-add-btn-glyph">༄</span>
      <span>Record Cycle</span>
    </button>
  </div>
  <div class="bc-entries" id="bc-entries-list">${listHTML}</div>
  <div class="bc-overlay" id="bc-overlay" onclick="bcClosePanel()"></div>
  <aside class="bc-panel" id="bc-panel">
    <div class="bc-panel-head">
      <div class="bc-panel-eyebrow">New Entry</div>
      <div class="bc-panel-title-row">
        <span class="bc-panel-glyph">༄</span>
        <span class="bc-panel-title">Record a Cycle</span>
        <button class="bc-panel-close" onclick="bcClosePanel()">close ×</button>
      </div>
    </div>
    <div class="bc-panel-body">
      <div class="bc-field">
        <label class="bc-field-label">Cycle Name</label>
        <span class="bc-field-hint">what this pattern is called</span>
        <input id="bc-f-name" type="text" placeholder="e.g. The Threshold Return…" autocomplete="off"/>
      </div>
      <div class="bc-field-row">
        <div class="bc-field">
          <label class="bc-field-label">Value / Number</label>
          <span class="bc-field-hint">the recurring quantity</span>
          <input id="bc-f-value" type="text" placeholder="e.g. 33" autocomplete="off"/>
        </div>
        <div class="bc-field">
          <label class="bc-field-label">Unit / Interval</label>
          <span class="bc-field-hint">days, years, cycles…</span>
          <input id="bc-f-unit" type="text" placeholder="e.g. days" autocomplete="off"/>
        </div>
      </div>
      <svg class="bc-panel-wave" viewBox="0 0 364 12" preserveAspectRatio="none">
        <path fill="none" stroke="#7c5a1a" stroke-width="0.7" d="M0 6 C30 2 61 10 91 6 121 2 152 10 182 6 212 2 243 10 273 6 303 2 334 10 364 6"/>
        <path fill="none" stroke="#b8892a" stroke-width="0.4" opacity="0.6" d="M0 6 C30 10 61 2 91 6 121 10 152 2 182 6 212 10 243 2 273 6 303 10 334 2 364 6"/>
      </svg>
      <div class="bc-field">
        <label class="bc-field-label">Description</label>
        <span class="bc-field-hint">where you encounter it, what it means</span>
        <textarea id="bc-f-desc" rows="4" placeholder="The pattern that keeps returning…"></textarea>
      </div>
    </div>
    <div class="bc-panel-foot">
      <button class="bc-btn-cancel" onclick="bcClosePanel()">Cancel</button>
      <button class="bc-btn-save" onclick="bcSave()">Bind Cycle</button>
    </div>
  </aside>
</div>`;
}

window.bcOpenPanel = function() {
  var p = document.getElementById('bc-panel');
  var o = document.getElementById('bc-overlay');
  ['bc-f-name','bc-f-value','bc-f-unit','bc-f-desc'].forEach(function(id){
    var el = document.getElementById(id); if (el) el.value = '';
  });
  if (p) p.classList.add('open');
  if (o) o.classList.add('open');
  setTimeout(function(){ var el = document.getElementById('bc-f-name'); if (el) el.focus(); }, 380);
};

window.bcClosePanel = function() {
  var p = document.getElementById('bc-panel');
  var o = document.getElementById('bc-overlay');
  if (p) p.classList.remove('open');
  if (o) o.classList.remove('open');
};

window.bcSave = async function() {
  var name  = (document.getElementById('bc-f-name')  && document.getElementById('bc-f-name').value  || '').trim();
  var value = (document.getElementById('bc-f-value') && document.getElementById('bc-f-value').value || '').trim();
  var unit  = (document.getElementById('bc-f-unit')  && document.getElementById('bc-f-unit').value  || '').trim();
  var desc  = (document.getElementById('bc-f-desc')  && document.getElementById('bc-f-desc').value  || '').trim();
  if (!name && !value) { var el = document.getElementById('bc-f-name'); if (el) el.focus(); return; }
  var payload = { title: name, body: desc, section: 'breath_cycles', type: 'longform', status: 'published', metadata: { value: value, unit: unit } };
  try {
    await createEntry(payload);
    window.bcClosePanel();
    if (typeof loadEntries === 'function') loadEntries();
  } catch(err) { console.warn('[BreathCycles] save failed:', err); window.bcClosePanel(); }
};


// ── MELODIES ────────────────────────────────────────────────────────────────────────────

function _injectMelodiesCSS() {
  if (document.getElementById('mel-css')) return;
  const s = document.createElement('style');
  s.id = 'mel-css';
  s.textContent = `
:root {
  --mel-void:        #090806;
  --mel-void-mid:    #13110d;
  --mel-bone-deep:   #7a6a52;
  --mel-bone-mid:    #aa9878;
  --mel-bone-warm:   #c8b898;
  --mel-bone-pale:   #e2d4bc;
  --mel-silver-mid:  #787888;
  --mel-silver-cool: #9898a8;
  --mel-silver-pale: #c4c4d0;
  --mel-border-bone: rgba(154,136,104,0.25);
  --mel-border-warm: rgba(154,136,104,0.42);
  --mel-border-hi:   rgba(200,184,152,0.55);
  --mel-text-dim:    #8a7a62;
  --mel-text-muted:  #5a5248;
  --mel-text-silver: #a8a8b8;
  --mel-text-poem:   #d8cdb8;
  --mel-glow-bone:   drop-shadow(0 0 7px rgba(200,184,152,0.32));
  --mel-glow-silver: drop-shadow(0 0 8px rgba(192,192,210,0.38));
  --mel-glow-title:  drop-shadow(0 0 14px rgba(200,184,152,0.26));
  --mel-ease:        cubic-bezier(0.16,1,0.3,1);
}
.mel-page { position: relative; z-index: 1; max-width: 720px; margin: 0 auto; padding: 64px 52px 120px; }
.mel-ambient { position: fixed; inset: 0; pointer-events: none; z-index: 0; background: radial-gradient(ellipse 55% 38% at 50% 10%, rgba(38,28,14,0.65) 0%, transparent 100%), radial-gradient(ellipse 28% 18% at 50% 4%, rgba(58,40,16,0.28) 0%, transparent 100%); animation: melCandleBreathe 5.5s ease-in-out infinite; }
@keyframes melCandleBreathe { 0%,100%{opacity:0.65} 48%{opacity:1} 52%{opacity:0.95} }
.mel-header { text-align: center; margin-bottom: 64px; }
.mel-eyebrow { font-family: 'Inconsolata', monospace; font-size: 9px; letter-spacing: 0.55em; text-transform: uppercase; color: var(--mel-text-dim); margin-bottom: 28px; }
.mel-header-glyph { font-family: 'Pinyon Script', cursive; font-size: 64px; line-height: 1; color: var(--mel-silver-cool); filter: var(--mel-glow-silver); display: block; margin-bottom: 16px; }
.mel-title { font-family: 'Cinzel Decorative', serif; font-size: clamp(24px, 3.5vw, 36px); font-weight: 400; letter-spacing: 0.12em; color: var(--mel-bone-pale); filter: var(--mel-glow-title); line-height: 1.2; margin-bottom: 8px; }
.mel-tilde { font-family: 'Cormorant Garamond', serif; font-size: 20px; color: var(--mel-silver-mid); letter-spacing: 0.3em; display: block; margin-bottom: 20px; }
.mel-sub { font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 300; font-size: 17px; color: var(--mel-text-dim); letter-spacing: 0.06em; line-height: 1.7; }
.mel-ornament { width: 100%; height: 28px; display: block; overflow: visible; margin: 32px 0 0; }
.mel-toolbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 56px; }
.mel-count { font-family: 'Inconsolata', monospace; font-size: 10px; letter-spacing: 0.38em; text-transform: uppercase; color: var(--mel-text-muted); }
.mel-count span { color: var(--mel-silver-cool); }
.mel-add-btn { font-family: 'Inconsolata', monospace; font-size: 10px; letter-spacing: 0.32em; text-transform: uppercase; background: none; border: 1px solid var(--mel-border-bone); color: var(--mel-bone-warm); padding: 8px 20px; cursor: pointer; display: flex; align-items: center; gap: 10px; transition: border-color 0.22s, color 0.22s, background 0.22s; }
.mel-add-btn:hover { border-color: var(--mel-border-hi); color: var(--mel-bone-pale); background: rgba(154,136,104,0.08); }
.mel-add-btn-glyph { font-size: 20px; color: var(--mel-silver-cool); filter: var(--mel-glow-silver); line-height: 1; }
.mel-codex { display: flex; flex-direction: column; }
.mel-song { padding: 48px 0 44px; animation: melSongIn 0.7s cubic-bezier(0.16,1,0.3,1) both; }
@keyframes melSongIn { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }
.mel-song-number { font-family: 'Inconsolata', monospace; font-size: 9px; letter-spacing: 0.4em; text-transform: uppercase; color: var(--mel-text-muted); margin-bottom: 18px; display: flex; align-items: center; gap: 10px; }
.mel-song-number::after { content: ''; flex: 1; height: 1px; background: linear-gradient(90deg, var(--mel-border-bone), transparent); }
.mel-song-title { font-family: 'Cinzel Decorative', serif; font-size: clamp(17px, 2.2vw, 24px); font-weight: 400; letter-spacing: 0.1em; color: var(--mel-bone-pale); line-height: 1.3; margin-bottom: 10px; filter: var(--mel-glow-bone); position: relative; display: inline-block; }
.mel-song-title::after { content: ''; position: absolute; bottom: -3px; left: 0; width: 0; height: 1px; background: linear-gradient(90deg, var(--mel-bone-deep), var(--mel-bone-mid), transparent); transition: width 0.5s var(--mel-ease); }
.mel-song:hover .mel-song-title::after { width: 100%; }
.mel-song-dedication { font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 300; font-size: 15px; color: var(--mel-text-silver); letter-spacing: 0.12em; margin-bottom: 32px; display: flex; align-items: center; gap: 9px; }
.mel-song-dedication::before { content: '\u2723'; color: var(--mel-silver-mid); font-style: normal; font-size: 13px; filter: drop-shadow(0 0 5px rgba(152,152,168,0.5)); flex-shrink: 0; }
.mel-song-text { font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 300; font-size: 19px; line-height: 2.15; color: var(--mel-text-poem); letter-spacing: 0.025em; white-space: pre-wrap; padding-left: 28px; border-left: 1px solid var(--mel-border-bone); position: relative; }
.mel-song-text::before { content: ''; position: absolute; left: -2px; top: 10px; width: 3px; height: 3px; border-radius: 50%; background: var(--mel-silver-cool); box-shadow: 0 0 6px rgba(152,152,168,0.55); }
.mel-song-text::first-letter { font-family: 'Cinzel Decorative', serif; font-size: 3.8em; font-style: normal; font-weight: 400; color: var(--mel-bone-warm); float: left; line-height: 0.78; margin-right: 7px; margin-top: 6px; filter: drop-shadow(0 0 12px rgba(200,184,152,0.42)); }
.mel-divider { width: 100%; height: 22px; display: block; overflow: visible; }
.mel-empty { padding: 80px 0 60px; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 18px; }
.mel-empty-script { font-family: 'Pinyon Script', cursive; font-size: 52px; color: var(--mel-bone-deep); filter: var(--mel-glow-bone); animation: melSilenceBreathe 4s ease-in-out infinite; }
@keyframes melSilenceBreathe { 0%,100%{opacity:0.35} 50%{opacity:0.7} }
.mel-empty-text { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 16px; color: var(--mel-text-muted); letter-spacing: 0.06em; }
.mel-overlay { position: fixed; inset: 0; background: rgba(9,8,6,0.82); z-index: 399; opacity: 0; pointer-events: none; transition: opacity 0.32s; backdrop-filter: blur(3px); }
.mel-overlay.open { opacity: 1; pointer-events: all; }
.mel-panel { position: fixed; top: 0; right: 0; bottom: 0; width: 480px; background: var(--mel-void-mid); border-left: 1px solid var(--mel-border-bone); z-index: 400; display: flex; flex-direction: column; transform: translateX(100%); transition: transform 0.42s var(--mel-ease); overflow: hidden; }
.mel-panel.open { transform: translateX(0); }
.mel-panel::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 240px; background: radial-gradient(ellipse at 50% 0%, rgba(106,90,66,0.12) 0%, transparent 70%); pointer-events: none; z-index: 0; }
.mel-panel-head { padding: 30px 32px 24px; border-bottom: 1px solid var(--mel-border-bone); flex-shrink: 0; position: relative; z-index: 1; }
.mel-panel-eyebrow { font-family: 'Inconsolata', monospace; font-size: 9px; letter-spacing: 0.45em; text-transform: uppercase; color: var(--mel-text-dim); margin-bottom: 12px; display: flex; align-items: center; gap: 10px; }
.mel-panel-eyebrow::after { content: ''; flex: 1; height: 1px; background: linear-gradient(90deg, var(--mel-border-bone), transparent); }
.mel-panel-title-row { display: flex; align-items: center; gap: 12px; }
.mel-panel-icon { font-size: 22px; color: var(--mel-silver-cool); filter: var(--mel-glow-silver); line-height: 1; }
.mel-panel-title { font-family: 'Cinzel Decorative', serif; font-size: 15px; font-weight: 400; letter-spacing: 0.08em; color: var(--mel-bone-warm); }
.mel-panel-close { margin-left: auto; background: none; border: none; cursor: pointer; font-family: 'Inconsolata', monospace; font-size: 9px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--mel-text-muted); padding: 6px 0; transition: color 0.2s; }
.mel-panel-close:hover { color: var(--mel-bone-warm); }
.mel-panel-body { flex: 1; overflow-y: auto; padding: 32px 32px 24px; display: flex; flex-direction: column; position: relative; z-index: 1; }
.mel-panel-body::-webkit-scrollbar { width: 3px; } .mel-panel-body::-webkit-scrollbar-thumb { background: var(--mel-bone-deep); border-radius: 2px; }
.mel-f-label { font-family: 'Inconsolata', monospace; font-size: 8.5px; letter-spacing: 0.42em; text-transform: uppercase; color: var(--mel-text-dim); display: block; margin-bottom: 10px; }
.mel-title-field { margin-bottom: 8px; }
.mel-title-field input { width: 100%; background: none; border: none; border-bottom: 1px solid var(--mel-border-bone); outline: none; font-family: 'Cinzel Decorative', serif; font-size: 18px; font-weight: 400; letter-spacing: 0.07em; color: var(--mel-bone-pale); caret-color: var(--mel-bone-mid); padding: 4px 0 10px; transition: border-color 0.22s; line-height: 1.3; box-sizing: border-box; }
.mel-title-field input:focus { border-bottom-color: var(--mel-bone-mid); }
.mel-title-field input::placeholder { color: rgba(106,90,66,0.35); font-style: italic; }
.mel-dedication-field { margin-bottom: 28px; }
.mel-dedication-field input { width: 100%; background: none; border: none; border-bottom: 1px solid var(--mel-border-bone); outline: none; font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 300; font-size: 16px; color: var(--mel-text-silver); caret-color: var(--mel-silver-cool); padding: 4px 0 8px; transition: border-color 0.22s; letter-spacing: 0.05em; box-sizing: border-box; }
.mel-dedication-field input:focus { border-bottom-color: var(--mel-silver-mid); }
.mel-dedication-field input::placeholder { color: rgba(104,104,120,0.35); font-style: italic; }
.mel-seam { width: 100%; height: 14px; display: block; overflow: visible; margin-bottom: 24px; opacity: 0.65; }
.mel-poem-field { flex: 1; display: flex; flex-direction: column; }
.mel-poem-field textarea { flex: 1; width: 100%; min-height: 280px; background: rgba(14,12,9,0.55); border: 1px solid var(--mel-border-bone); border-left: 2px solid var(--mel-border-bone); outline: none; font-family: 'Cormorant Garamond', serif; font-style: italic; font-weight: 300; font-size: 17px; line-height: 2.1; color: var(--mel-text-poem); caret-color: var(--mel-bone-warm); padding: 20px 22px; resize: none; transition: border-color 0.28s, box-shadow 0.4s; letter-spacing: 0.02em; box-sizing: border-box; }
.mel-poem-field textarea:focus { border-color: var(--mel-border-warm); border-left-color: var(--mel-silver-mid); box-shadow: inset 0 0 50px rgba(20,15,8,0.5), inset 5px 0 24px rgba(106,90,66,0.1); }
.mel-poem-field textarea::placeholder { color: rgba(106,90,66,0.28); font-style: italic; line-height: 2; }
.mel-panel-foot { padding: 18px 32px 28px; border-top: 1px solid var(--mel-border-bone); display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; position: relative; z-index: 1; }
.mel-foot-hint { font-family: 'Inconsolata', monospace; font-size: 8px; letter-spacing: 0.22em; color: var(--mel-text-muted); }
.mel-foot-btns { display: flex; gap: 10px; }
.mel-btn-cancel { font-family: 'Inconsolata', monospace; font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase; background: none; border: 1px solid rgba(106,90,66,0.22); color: var(--mel-text-muted); padding: 9px 16px; cursor: pointer; transition: color 0.2s, border-color 0.2s; }
.mel-btn-cancel:hover { color: var(--mel-bone-warm); border-color: var(--mel-border-bone); }
.mel-btn-save { font-family: 'Inconsolata', monospace; font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase; background: none; border: 1px solid var(--mel-border-bone); color: var(--mel-bone-warm); padding: 9px 22px; cursor: pointer; transition: color 0.2s, border-color 0.2s, background 0.2s; }
.mel-btn-save:hover { border-color: var(--mel-border-hi); color: var(--mel-bone-pale); background: rgba(154,136,104,0.09); }
`;
  document.head.appendChild(s);
}

function _melDivider() {
  return '<svg class="mel-divider" viewBox="0 0 616 22" preserveAspectRatio="none">'
    + '<path fill="none" stroke="#3a3228" stroke-width="0.6" d="M0 11 C50 6 100 16 150 11 200 6 250 16 286 11"/>'
    + '<line x1="296" y1="7" x2="296" y2="15" stroke="#6a5a42" stroke-width="0.6"/>'
    + '<polygon points="308,7 314,11 308,15 302,11" fill="none" stroke="#9898a8" stroke-width="0.8"/>'
    + '<line x1="320" y1="7" x2="320" y2="15" stroke="#6a5a42" stroke-width="0.6"/>'
    + '<path fill="none" stroke="#3a3228" stroke-width="0.6" d="M330 11 C366 6 416 16 466 11 516 6 566 16 616 11"/>'
    + '</svg>';
}

function renderMelodies(entries) {
  var body = document.getElementById('section-body');
  if (!body) return;
  body.classList.remove('venai-mode');
  body.dataset.page = 'songs';
  _injectMelodiesCSS();
  var songs = (entries || []).filter(function(e){ return e.title || e.body; });
  var listHTML = songs.length === 0
    ? '<div class="mel-empty"><span class="mel-empty-script">Silence</span><span class="mel-empty-text">no songs bound yet — let the first one arrive</span></div>'
    : songs.map(function(s, i) {
        var meta = s.metadata || {};
        var dedication = meta.dedication || '';
        var num = String(i + 1).padStart(2, '0');
        var delay = (i * 0.15).toFixed(2);
        var divider = i < songs.length - 1 ? _melDivider() : '';
        return '<div class="mel-song" style="animation-delay:' + delay + 's">'
          + '<div class="mel-song-number">✣ &nbsp;' + num + '</div>'
          + '<div class="mel-song-title">' + (s.title || '') + '</div>'
          + (dedication ? '<div class="mel-song-dedication">' + dedication + '</div>' : '')
          + '<div class="mel-song-text">' + (s.body || '') + '</div>'
          + '</div>' + divider;
      }).join('');

  body.innerHTML = `<div class="mel-ambient"></div><div class="mel-page">
  <header class="mel-header">
    <div class="mel-eyebrow">Alchemy · Healing Archive</div>
    <span class="mel-header-glyph">Melodies</span>
    <h1 class="mel-title">Singing in Silence</h1>
    <span class="mel-tilde">~</span>
    <p class="mel-sub">Songs written at the edge of healing — where the wound finally had a name.</p>
    <svg class="mel-ornament" viewBox="0 0 616 28" preserveAspectRatio="none">
      <path fill="none" stroke="#6a5a42" stroke-width="0.7" d="M0 14 C40 8 80 20 120 14 160 8 200 20 240 14 270 8 290 20 296 14"/>
      <polygon points="308,9 316,14 308,19 300,14" fill="none" stroke="#9898a8" stroke-width="0.9"/>
      <polygon points="308,11.5 313.5,14 308,16.5 302.5,14" fill="rgba(152,152,168,0.18)" stroke="none"/>
      <path fill="none" stroke="#6a5a42" stroke-width="0.7" d="M320 14 C326 8 360 20 400 14 440 8 480 20 520 14 560 8 590 20 616 14"/>
      <path fill="none" stroke="#3a3228" stroke-width="0.5" opacity="0.7" d="M0 14 C40 20 80 8 120 14 160 20 200 8 240 14 270 20 290 8 296 14"/>
      <path fill="none" stroke="#3a3228" stroke-width="0.5" opacity="0.7" d="M320 14 C326 20 360 8 400 14 440 20 480 8 520 14 560 20 590 8 616 14"/>
      <circle cx="0" cy="14" r="1.5" fill="#6a5a42"/>
      <circle cx="616" cy="14" r="1.5" fill="#6a5a42"/>
    </svg>
  </header>
  <div class="mel-toolbar">
    <div class="mel-count"><span id="mel-count">${songs.length}</span> songs bound</div>
    <button class="mel-add-btn" onclick="melOpenPanel()">
      <span class="mel-add-btn-glyph">✣</span>
      <span>Sing a Song</span>
    </button>
  </div>
  <div class="mel-codex" id="mel-codex">${listHTML}</div>
  <div class="mel-overlay" id="mel-overlay" onclick="melClosePanel()"></div>
  <aside class="mel-panel" id="mel-panel">
    <div class="mel-panel-head">
      <div class="mel-panel-eyebrow">New Song</div>
      <div class="mel-panel-title-row">
        <span class="mel-panel-icon">✣</span>
        <span class="mel-panel-title">Bind a Song</span>
        <button class="mel-panel-close" onclick="melClosePanel()">close ×</button>
      </div>
    </div>
    <div class="mel-panel-body">
      <div class="mel-title-field">
        <label class="mel-f-label">Title</label>
        <input id="mel-f-title" type="text" placeholder="The name this song carries…" autocomplete="off"/>
      </div>
      <div class="mel-dedication-field">
        <label class="mel-f-label">Dedication</label>
        <input id="mel-f-dedication" type="text" placeholder="written for…" autocomplete="off"/>
      </div>
      <svg class="mel-seam" viewBox="0 0 416 14" preserveAspectRatio="none">
        <path fill="none" stroke="#6a5a42" stroke-width="0.6" d="M0 7 C35 3 70 11 105 7 140 3 175 11 200 7"/>
        <polygon points="208,4 213,7 208,10 203,7" fill="none" stroke="#9898a8" stroke-width="0.7"/>
        <path fill="none" stroke="#6a5a42" stroke-width="0.6" d="M216 7 C241 3 276 11 311 7 346 3 381 11 416 7"/>
      </svg>
      <div class="mel-poem-field">
        <label class="mel-f-label">Song · Invocation · Poem</label>
        <textarea id="mel-f-text" placeholder="Let the words come as they arrive…&#10;&#10;There is no wrong line here."></textarea>
      </div>
    </div>
    <div class="mel-panel-foot">
      <span class="mel-foot-hint">⌘ + enter to bind</span>
      <div class="mel-foot-btns">
        <button class="mel-btn-cancel" onclick="melClosePanel()">Cancel</button>
        <button class="mel-btn-save" onclick="melSave()">Bind Song</button>
      </div>
    </div>
  </aside>
</div>`;
}

window.melOpenPanel = function() {
  var p = document.getElementById('mel-panel');
  var o = document.getElementById('mel-overlay');
  ['mel-f-title','mel-f-dedication','mel-f-text'].forEach(function(id){
    var el = document.getElementById(id); if (el) el.value = '';
  });
  if (p) p.classList.add('open');
  if (o) o.classList.add('open');
  setTimeout(function(){ var el = document.getElementById('mel-f-title'); if (el) el.focus(); }, 420);
};

window.melClosePanel = function() {
  var p = document.getElementById('mel-panel');
  var o = document.getElementById('mel-overlay');
  if (p) p.classList.remove('open');
  if (o) o.classList.remove('open');
};

window.melSave = async function() {
  var title      = (document.getElementById('mel-f-title')      && document.getElementById('mel-f-title').value      || '').trim();
  var dedication = (document.getElementById('mel-f-dedication') && document.getElementById('mel-f-dedication').value || '').trim();
  var text       = (document.getElementById('mel-f-text')       && document.getElementById('mel-f-text').value       || '').trim();
  if (!title && !text) { var el = document.getElementById('mel-f-title'); if (el) el.focus(); return; }
  var payload = { title: title, body: text, section: 'songs', type: 'longform', status: 'published', metadata: { dedication: dedication } };
  try {
    await createEntry(payload);
    window.melClosePanel();
    if (typeof loadEntries === 'function') loadEntries();
  } catch(err) { console.warn('[Melodies] save failed:', err); window.melClosePanel(); }
};


