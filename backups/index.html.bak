<div id="gs-tooltip">
  <div class="gst-name"    id="gst-name"></div>
  <div class="gst-secondary" id="gst-secondary"></div>
  <div class="gst-epithet" id="gst-epithet"></div>
  <div class="gst-hz"      id="gst-hz"></div>
</div>




<!-- DETAIL PANEL -->

<div id="detail-overlay" onclick="closeDetail()"></div>

<div id="detail-panel">

  <div id="detail-panel-header">

    <div id="detail-title"></div>

    <button class="detail-close" onclick="closeDetail()">✕</button>

  </div>

  <div id="detail-scroll">

    <div id="detail-stamp"></div>

    <div id="detail-meta"></div>

    <div id="detail-body"></div>

    <div id="detail-tags"></div>

    <div id="detail-facets"></div>

    <div id="detail-timestamps">

      <span><span class="ts-label">Created</span><span id="detail-ts-created">—</span></span>

      <span><span class="ts-label">Modified</span><span id="detail-ts-modified">—</span></span>

    </div>

    <div id="detail-edit-wrap">

      <input id="detail-edit-title" type="text" placeholder="Title…" />

      <textarea id="detail-edit-body" placeholder="Body…"></textarea>

      <div class="detail-edit-actions">

        <button class="detail-btn" onclick="cancelDetailEdit()">Cancel</button>

        <button class="detail-btn" onclick="saveDetailEdit()" style="border-color:var(--border-warm);color:var(--accent)">Save</button>

      </div>

    </div>

  </div>

  <div id="detail-actions">

    <button class="detail-btn" id="detail-edit-btn" onclick="toggleDetailEdit()">✎ Edit</button>

    <button class="detail-btn" id="detail-flag-btn" onclick="toggleDetailFlag()">⚑ Flag</button>

    <button class="detail-btn danger" onclick="deleteDetailEntry()">✕ Delete</button>

  </div>

</div>



<!-- ADD ENTRY MODAL -->

<div id="modal-overlay">

  <div id="modal">

    <canvas id="panel-gradient"></canvas>

    <div class="ae-kai-inner">



      <!-- ══ TOPBAR ══════════════════════════════════════════════════════ -->

      <div class="ae-kai-topbar">

        <div class="ae-kai-wordmark">

          <span class="ae-kai-wm-name">Ae'larian</span>

          <span class="ae-kai-wm-sep">·</span>

          <span class="ae-kai-wm-sub">Ael'Kai</span>

        </div>

        <div class="ae-kai-topbar-right">

          <div class="ae-kai-autosave">

            <div class="ae-kai-autosave-dot" id="ae-kai-autosave-dot"></div>

            <span id="ae-kai-autosave-label">—</span>

          </div>

          <button class="btn-close" type="button" onclick="closeModal()">✕</button>

        </div>

      </div>



      <!-- ══ LEFT SIDEBAR ════════════════════════════════════════════════ -->

      <div class="ae-kai-left">



        <!-- ID COORDINATE -->

        <div class="ae-kai-id-block ae-kai-sidebar-sec">

          <div class="ae-kai-id-label">

            Entry Coordinate

            <button class="ae-kai-id-refresh" onclick="aeKaiRefreshStamp()" title="Refresh">↺</button>

          </div>

          <div class="ae-kai-id-segs">

            <span class="ae-kai-id-seg ts">TS</span>

            <span class="ae-kai-id-sep">·</span>

            <span class="ae-kai-id-seg section" id="ae-kai-id-section">—</span>

            <span class="ae-kai-id-sep">·</span>

            <span class="ae-kai-id-seg phase"   id="ae-kai-id-phase">—</span>

            <span class="ae-kai-id-sep">·</span>

            <span class="ae-kai-id-seg dateg"   id="ae-kai-id-date">—</span>

            <span class="ae-kai-id-sep">·</span>

            <span class="ae-kai-id-seg hash"    id="ae-kai-id-hash">——</span>

          </div>

          <div class="ae-kai-id-ts">

            <div class="ae-kai-ts-row"><span class="ae-kai-ts-key">Origin</span><span class="ae-kai-ts-val" id="ae-kai-ts-origin">—</span></div>

            <div class="ae-kai-ts-row"><span class="ae-kai-ts-key">Witnessed</span><span class="ae-kai-ts-val lit" id="ae-kai-ts-witnessed">—</span></div>

            <div class="ae-kai-ts-row"><span class="ae-kai-ts-key">Modified</span><span class="ae-kai-ts-val" id="ae-kai-ts-modified">—</span></div>

          </div>

          <div class="ae-kai-id-ctx">

            <select class="ae-kai-mini-sel" id="f-phase" onchange="updateModalIdStamp(); aeKaiRefreshStamp()">

              <option value="">Phase</option>

            </select>

            <select class="ae-kai-mini-sel" id="f-arc">

              <option value="">Arc</option>

            </select>

          </div>

        </div>



        <!-- DESTINATION -->

        <div class="ae-kai-sidebar-sec">

          <span class="ae-kai-sidebar-label">Destination</span>

          <div class="ae-kai-dest-chip" id="ae-kai-dest-chip" onclick="aeKaiToggleDest()">

            <span class="ae-kai-dest-sect" id="ae-kai-dest-sect">—</span>

            <span class="ae-kai-dest-dot">·</span>

            <span id="ae-kai-dest-page" style="font-style:italic;color:var(--text-dim)">current page</span>

            <span class="ae-kai-dest-chev">▾</span>

          </div>

          <div class="ae-kai-dest-dd" id="ae-kai-dest-dd">

            <div class="ae-kai-dest-placeholder">Destination</div>

          </div>

          <!-- hidden select populated by buildModalSelects() -->

          <select id="f-section" style="display:none" onchange="updateModalContextFields(); updateModalIdStamp(); updateDestLabel()"></select>

        </div>



        <!-- RESONANCE + TAGS -->

        <div class="ae-kai-sidebar-sec">

          <span class="ae-kai-sidebar-label">Resonance Fields</span>

          <div class="ae-kai-res-stack">

            <button class="ae-kai-res-btn" data-layer="Coupling"    onclick="aeKaiToggleRes(this)"><span class="ae-kai-res-glyph">⇌</span><span><span class="ae-kai-res-name">Coupling</span><span class="ae-kai-res-sub">binding dynamics between intelligences</span></span></button>

            <button class="ae-kai-res-btn" data-layer="Connectome"  onclick="aeKaiToggleRes(this)"><span class="ae-kai-res-glyph">⟠</span><span><span class="ae-kai-res-name">Connectome</span><span class="ae-kai-res-sub">relational topology &amp; network structure</span></span></button>

            <button class="ae-kai-res-btn" data-layer="MetricField" onclick="aeKaiToggleRes(this)"><span class="ae-kai-res-glyph">∿</span><span><span class="ae-kai-res-name">MetricField</span><span class="ae-kai-res-sub">measurable affective signal gradients</span></span></button>

            <button class="ae-kai-res-btn" data-layer="MirrorField" onclick="aeKaiToggleRes(this)"><span class="ae-kai-res-glyph">◈</span><span><span class="ae-kai-res-name">MirrorField</span><span class="ae-kai-res-sub">reflective &amp; recursive self-structures</span></span></button>

          </div>

          <div class="ae-kai-tag-zone">

            <span class="ae-kai-sidebar-label">Tags — MTAGS</span>

            <div class="tag-suggest-wrap">

              <div class="tag-area" id="tag-area" onclick="document.getElementById('tag-search-input').focus()">

                <input class="tag-input" id="tag-search-input" type="text" placeholder="search tags…" autocomplete="off" />

              </div>

              <div class="tag-suggest-list" id="tag-suggest-list"></div>

            </div>

          </div>

        </div>



        <!-- UPLOAD -->

        <div class="ae-kai-upload-ghost">

          <button class="ae-kai-upload-btn" onclick="aeKaiTriggerUpload()">↑ import entries</button>

          <input type="file" id="ae-kai-file-upload" accept=".json,.md,.txt,.csv" style="display:none" multiple onchange="aeKaiHandleUpload(this)" />

        </div>



        <!-- ═══════════════════════════════════════════════

             HIDDEN COMPATIBILITY — required by existing JS

             ═══════════════════════════════════════════════ -->

        <!-- ID stamp compat -->

        <div id="modal-id-stamp">

          <span id="modal-id-stamp-text">TS · — · — · — · ——— · ——</span>

          <button type="button" id="modal-id-refresh" onclick="updateModalIdStamp(true)">↺</button>

        </div>

        <!-- Destination trigger compat -->

        <div id="destination-row">

          <div class="destination-trigger" onclick="toggleDestination()">

            <span class="dest-label">Destination</span>

            <span class="dest-current" id="dest-current-label">— current page —</span>

            <span class="dest-chevron">▾</span>

          </div>

          <div id="destination-select-wrap"></div>

        </div>

        <!-- Status pill compat -->

        <div id="status-pill-row">

          <button class="status-pill active" data-val="draft"   onclick="setStatusPill(this)">Draft</button>

          <button class="status-pill"        data-val="working" onclick="setStatusPill(this)">Working</button>

          <button class="status-pill"        data-val="settled" onclick="setStatusPill(this)">Settled</button>

          <button class="status-pill"        data-val="revisit" onclick="setStatusPill(this)">Revisit</button>

        </div>

        <input type="hidden" id="f-status" value="draft" />

        <!-- Type pills compat -->

        <div id="type-pill-row">

          <button class="status-pill active" data-val="note"           onclick="setTypePill(this)">Note</button>

          <button class="status-pill"        data-val="observation"    onclick="setTypePill(this)">Observation</button>

          <button class="status-pill"        data-val="session"        onclick="setTypePill(this)">Session</button>

          <button class="status-pill"        data-val="longform"       onclick="setTypePill(this)">Longform</button>

          <button class="status-pill"        data-val="lexicon"        onclick="setTypePill(this)">Lexicon</button>

          <button class="status-pill"        data-val="witness_scroll" onclick="setTypePill(this)">Witness Scroll</button>

          <button class="status-pill"        data-val="artifact"       onclick="setTypePill(this)">Artifact</button>

          <button class="status-pill"        data-val="field_journal"  onclick="setTypePill(this)">Field Journal</button>

        </div>

        <input type="hidden" id="f-type" value="note" />

        <!-- Speaker compat -->

        <div id="speaker-row"><input id="f-speaker" type="text" value="" /></div>

        <!-- Layer toggle compat -->

        <div id="layer-toggle-row">

          <button class="layer-toggle" data-layer="Coupling">Coupling</button>

          <button class="layer-toggle" data-layer="Connectome">Connectome</button>

          <button class="layer-toggle" data-layer="MetricField">MetricField</button>

          <button class="layer-toggle" data-layer="MirrorField">MirrorField</button>

        </div>

        <!-- Modal tabs compat -->

        <div class="modal-tab-panel open" id="tab-entry"></div>

        <div class="modal-tab-panel" id="tab-facets">

          <div id="facet-list-modal"></div>

          <button type="button" class="facet-add-btn" onclick="addFacetCard()">+ Add Facet</button>

        </div>

        <!-- Mode compat -->

        <button id="mode-quick" class="active" style="display:none">Quick</button>

        <button id="mode-full"                 style="display:none">Full</button>

        <button id="tab-entry-btn" class="active" style="display:none">Entry</button>

        <button id="tab-facets-btn"              style="display:none">Facets</button>

        <!-- Dup warning -->

        <div id="dup-warning">⚠ Similar entry detected — review before saving.</div>



      </div><!-- /ae-kai-left -->



      <!-- ══ RIGHT — WRITING SURFACE ═══════════════════════════════════ -->

      <div class="ae-kai-right">

        <div class="ae-kai-writing">



          <!-- date · title -->

          <div class="ae-kai-letter-head">

            <input class="ae-kai-field-date" type="date" id="f-date" onchange="onOriginDateChange()" title="Origin Date" />

            <input class="ae-kai-field-title" type="text" id="f-title" placeholder="Title…" autocomplete="off" />

          </div>



          <!-- body -->

          <div class="ae-kai-body-wrap">

            <div class="ae-kai-toolbar">

              <button class="ae-kai-tb-btn" title="Bold"      onmousedown="event.preventDefault()" onclick="applyBodyFormat('bold')"><b>B</b></button>

              <button class="ae-kai-tb-btn" title="Italic"    onmousedown="event.preventDefault()" onclick="applyBodyFormat('italic')"><i>I</i></button>

              <div class="ae-kai-tb-sep"></div>

              <button class="ae-kai-tb-btn hl"  title="Highlight" onmousedown="event.preventDefault()" onclick="applyBodyFormat('highlight')">H</button>

              <button class="ae-kai-tb-btn mrk" title="Mark"      onmousedown="event.preventDefault()" onclick="applyBodyFormat('mark')">◈</button>

              <div class="ae-kai-tb-sep"></div>

              <button class="ae-kai-tb-btn" title="Quote" onmousedown="event.preventDefault()" onclick="applyBodyFormat('quote')" style="font-style:italic">"</button>

              <div class="ae-kai-tb-spacer"></div>

              <span class="body-counter" id="body-counter">0 words · 0 chars</span>

            </div>



            <div class="field-body-edit" id="f-body" contenteditable="true"

              role="textbox" aria-multiline="true"

              data-placeholder="Eroth mirein'kai laem. — I remember within the living path."></div>



            <!-- signal row -->

            <div class="ae-kai-mood-row">

              <span class="ae-kai-mood-label">Signal</span>

              <div class="ae-kai-mood-dots">

                <div class="ae-kai-mood-dot" data-m="clear"   title="Clear"   onclick="aeKaiSetMood(this)"></div>

                <div class="ae-kai-mood-dot" data-m="dense"   title="Dense"   onclick="aeKaiSetMood(this)"></div>

                <div class="ae-kai-mood-dot" data-m="urgent"  title="Urgent"  onclick="aeKaiSetMood(this)"></div>

                <div class="ae-kai-mood-dot" data-m="liminal" title="Liminal" onclick="aeKaiSetMood(this)"></div>

              </div>

              <span class="ae-kai-mood-name" id="ae-kai-mood-name"></span>

            </div>



            <!-- witness scroll -->

            <div id="ws-fields">

              <div class="ae-kai-ws-heading">∿ Witness Scroll ∿</div>

              <div class="ae-kai-ws-row ae-kai-ws-grp">

                <div><span class="ae-kai-ws-lbl">Observation Date</span><input class="ae-kai-ws-inp" id="ws-obs-date" type="date" /></div>

                <div><span class="ae-kai-ws-lbl">Context Conditions</span><input class="ae-kai-ws-inp" id="ws-context" type="text" placeholder="environment, mood, setting…" /></div>

              </div>

              <div class="ae-kai-ws-grp">

                <span class="ae-kai-ws-lbl">Signal</span>

                <textarea class="ae-kai-ws-ta" id="ws-signal" placeholder="The raw signal — what you witnessed…"></textarea>

              </div>

              <div class="ae-kai-ws-grp">

                <span class="ae-kai-ws-lbl">Frame</span>

                <div class="ws-frame-pills" id="ws-frame-pills">

                  <span class="ws-frame-pill" onclick="wsToggleFrame(this,'somatic')">somatic</span>

                  <span class="ws-frame-pill" onclick="wsToggleFrame(this,'cognitive')">cognitive</span>

                  <span class="ws-frame-pill" onclick="wsToggleFrame(this,'relational')">relational</span>

                  <span class="ws-frame-pill" onclick="wsToggleFrame(this,'threshold')">threshold</span>

                  <span class="ws-frame-pill" onclick="wsToggleFrame(this,'mythic')">mythic</span>

                  <span class="ws-frame-pill" onclick="wsToggleFrame(this,'emergent')">emergent</span>

                  <span class="ws-frame-pill" onclick="wsToggleFrame(this,'recursive')">recursive</span>

                  <span class="ws-frame-pill" onclick="wsToggleFrame(this,'dissolution')">dissolution</span>

                </div>

                <input class="ae-kai-ws-inp" id="ws-frame-custom" type="text" placeholder="custom frame…" style="margin-top:.4rem" />

              </div>

              <div class="ae-kai-ws-grp">

                <span class="ae-kai-ws-lbl">Interpretation</span>

                <textarea class="ae-kai-ws-ta" id="ws-interpretation" placeholder="What does this signal mean within the field?"></textarea>

              </div>

              <div class="ae-kai-ws-grp">

                <span class="ae-kai-ws-lbl">Hypotheses</span>

                <textarea class="ae-kai-ws-ta" id="ws-hypotheses" placeholder="Provisional hypotheses…"></textarea>

              </div>

              <div class="ae-kai-ws-grp">

                <span class="ae-kai-ws-lbl">Witness Status</span>

                <div class="ws-status-opts" id="ws-status-opts">

                  <button type="button" class="ws-status-opt selected" onclick="wsSetStatus(this,'active')">active</button>

                  <button type="button" class="ws-status-opt" onclick="wsSetStatus(this,'dormant')">dormant</button>

                  <button type="button" class="ws-status-opt" onclick="wsSetStatus(this,'resolved')">resolved</button>

                  <button type="button" class="ws-status-opt" onclick="wsSetStatus(this,'crystallized')">crystallized</button>

                </div>

              </div>

            </div>



          </div><!-- /ae-kai-body-wrap -->

        </div>

      </div><!-- /ae-kai-right -->



      <!-- ══ FOOTER ═════════════════════════════════════════════════════ -->

      <div class="ae-kai-footer">

        <div class="ae-kai-footer-left">

          <div class="ae-kai-spill">

            <button class="ae-kai-spill-btn on" data-val="draft"   onclick="aeKaiSetStatus(this)">Draft</button>

            <button class="ae-kai-spill-btn"    data-val="working" onclick="aeKaiSetStatus(this)">Working</button>

            <button class="ae-kai-spill-btn"    data-val="settled" onclick="aeKaiSetStatus(this)">Settled</button>

            <button class="ae-kai-spill-btn"    data-val="revisit" onclick="aeKaiSetStatus(this)">Revisit</button>

          </div>

          <button class="ae-kai-btn-draft" onclick="saveDraft()">Save Draft</button>

        </div>

        <div class="ae-kai-footer-right">

          <span class="ae-kai-kbd-hint">⌘↵ save</span>

          <button class="ae-kai-btn-cancel" onclick="closeModal()">Cancel</button>

          <button class="ae-kai-btn-save"   onclick="saveEntry()">Save Entry</button>

        </div>

      </div>



    </div><!-- /ae-kai-inner -->

  </div><!-- /#modal -->

</div><!-- /#modal-overlay -->

<!-- TAG SESSION -->

<div id="tag-session-overlay">

  <div id="tag-session-panel">

    <div class="modal-header">

      <span class="modal-title">◈ Tag Session</span>

      <button class="btn-close" onclick="closeTagSession()">✕</button>

    </div>

    <div class="ts-progress" id="ts-progress-label">Loading…</div>

    <div class="ts-progress-bar"><div class="ts-progress-fill" id="ts-progress-fill" style="width:0%"></div></div>

    <div class="ts-entry-title" id="ts-entry-title"></div>

    <div class="ts-entry-body"  id="ts-entry-body"></div>

    <div style="margin-bottom:.5rem">

      <span style="font-family:var(--font-head);font-size:.58rem;letter-spacing:.18em;color:var(--accent);text-transform:uppercase;opacity:.7">Suggestions</span>

    </div>

    <div class="ts-suggest-grid" id="ts-suggest-grid"></div>

    <div class="ts-controls">

      <button class="btn-secondary" onclick="tsSkip()">Skip →</button>

      <div style="display:flex;gap:.6rem">

        <button class="btn-secondary" onclick="closeTagSession()">Done</button>

        <button class="btn-primary" onclick="tsSave()">Save & Next →</button>

      </div>

    </div>

  </div>

</div>



<!-- EMERGENCE -->

<div id="emergence-overlay" onclick="if(event.target===this)closeEmergence()">

  <div id="emergence-panel">

    <div class="modal-header" style="margin-bottom:1rem">

      <span class="modal-title">✦ Emergence</span>

      <button class="btn-close" onclick="closeEmergence()">✕</button>

    </div>

    <div id="emergence-findings"></div>

  </div>

</div>



<!-- ═══════════════════════════════════════════

     FAB TOWER SYSTEM

     Two towers bottom-right + solo flag bottom-left

═══════════════════════════════════════════ -->



<!-- Health Check panel — drops from header star -->

<div id="health-panel">

  <div class="health-panel-title">

    <span id="health-panel-title-text">Health Check</span>

    <button class="health-panel-close" onclick="toggleHealthPanel()">✕</button>

  </div>

  <div id="health-findings"></div>

  <div class="health-panel-footer" id="health-panel-footer"></div>

</div>



<div id="export-panel">

  <div class="export-panel-title">

    <span>Export</span>

    <button class="export-panel-close" onclick="closeExportPanel()">✕</button>

  </div>

  <div class="export-scope-row">

    <button class="export-scope-btn active" id="export-scope-page" onclick="setExportScope('page')">This Page</button>

    <button class="export-scope-btn" id="export-scope-archive" onclick="setExportScope('archive')">Full Archive</button>

  </div>

  <div class="export-format-label">Format</div>

  <div class="export-format-row">

    <button class="export-format-btn active" id="export-fmt-ai">AI JSON</button>

    <button class="export-format-btn stub" title="Coming soon">JSON-LD<span class="export-format-soon">soon</span></button>

    <button class="export-format-btn stub" title="Coming soon">Markdown<span class="export-format-soon">soon</span></button>

  </div>

  <button class="export-run-btn" id="export-run-btn" onclick="runExport()">Export AI JSON</button>

  <div class="export-panel-note" id="export-panel-note">AI-structured JSON · timestamped · saves to Drive + local</div>

</div>




<!-- FLAG PANEL -->

<div id="flag-panel">

  <div class="flag-panel-header">

    <span class="flag-panel-title">⚑ Duplicate Flags<span class="flag-panel-count" id="flag-panel-count"></span></span>

    <button class="flag-panel-close" onclick="closeFlagPanel()">✕</button>

  </div>

  <div id="flag-panel-body"></div>

</div>



<!-- TOAST -->

<div id="toast"></div>









<script type="module">

import { initDB, createEntry, updateEntry, deleteEntry, getEntriesBySection,

         searchEntries, downloadBackup, exportAll, importAll, getAll, getEntries,

         getRelationsFor,

         getNextSequence } from './core/data.js';

import { SECTIONS, ARC_SEEDS, DATE_SECTIONS, SECTION_DEFAULTS,

         PHASE_CODES, PAGE_CODES, resolveArcCode, assembleId } from './core/schema.js';

import { TAG_VOCAB, ARC_SEED_TAGS } from './core/tags-vocab.js';

import { suggestTags, searchVocab, resolveTagIds, getUntaggedEntries,

         detectEmergence, getTagById, suggestArcPhase } from './core/tagger.js';



// ── STATE ──────────────────────────────────────────────────────────────────

let currentSection  = null;

let currentEntries  = [];

let folderHandle    = null;

let searchTimer     = null;

let tagFrequency    = {};

let selectedTagIds   = [];

let selectedPhaseId  = null;   // Layer 1 — which arc phase this entry invokes (singular)

let selectedLayerIds = [];    // resonance fields this entry touches (Coupling/Connectome/MetricField/MirrorField)

let tsQueue         = [];

let tsIndex         = 0;

let tsSelected      = [];

let detailEntryId   = null;

let pendingFacets   = [];

let sectionCounts   = {};   // live counts for badges + constellation



// group colors map

const GROUP_COLORS = {

  Lattice:      '#4A9CB8',

  Filament:     '#7A7ACC',

  Lineage:      '#c8943a',

  Alchemy:      '#5855A8',

  Spiral:       '#c87888',

  Architecture: '#9AB8CC',

  Creation:     '#3E5570',

  Omega:        '#8885C4',

};

const NAV_GLYPHS = {

  Lattice:'◈', Filament:'∿', Lineage:'⟠',

  Alchemy:'⊕', Spiral:'∞', Architecture:'⌬',

  Creation:'✦', Omega:'◉'

};





// ── INIT ───────────────────────────────────────────────────────────────────

async function init() {

  await initDB();



  // Expose live vocab + arc seeds to the Babel/React scope (bridge)

  window._aelarian = { TAG_VOCAB, ARC_SEEDS };

  window.dispatchEvent(new CustomEvent('aelarian:ready'));



  await refreshCounts();

  buildNav();

  buildModalSelects();

  setupBodyCounter();

  setupTagInput();

  restoreFolderHandle();

  setupSearch();

  runEmergenceCheck();

}





// ── CONSTELLATION COUNTS — pushes live sectionCounts/tagFrequency/emergenceFindings to engine bridge ──

// Called after every entry mutation so the engine reflects live archive state.

// Called by entry mutations — refreshCounts() rebuilds counts then pushes to engine bridge.

async function updateConstellationCounts() {

  if (window._aelarian) {

    window._aelarian.sectionCounts    = { ...sectionCounts };

    window._aelarian.tagFrequency     = { ...tagFrequency };

    window._aelarian.emergenceFindings = window._emergenceFindings || [];

    window._aelarian.refresh?.();

  }

}



async function refreshCounts() {

  const all = await getEntries();

  sectionCounts = {};

  let tagged = 0;

  tagFrequency = {};

  for (const e of all) {

    sectionCounts[e.section] = (sectionCounts[e.section] || 0) + 1;

    if (e.tagIds?.length) {

      tagged++;

      for (const tid of e.tagIds) {

        tagFrequency[tid] = (tagFrequency[tid] || 0) + 1;

      }

    }

  }

  const _se = document.getElementById('stat-entries'); if (_se) _se.textContent = all.length;

  const _st = document.getElementById('stat-tagged');  if (_st) _st.textContent = tagged;



  // Update nav badges

  SECTIONS.forEach(s => {

    const badge = document.getElementById(`badge-${s.id}`);

    if (badge) {

      const n = sectionCounts[s.id] || 0;

      badge.textContent = n > 0 ? n : '';

    }

  });



  // Push live data to engine bridge

  if (window._aelarian) {

    window._aelarian.sectionCounts    = { ...sectionCounts };

    window._aelarian.tagFrequency     = { ...tagFrequency };

    window._aelarian.emergenceFindings = window._emergenceFindings || [];

    window._aelarian.refresh?.();

  }

}



// ── NAVIGATION ─────────────────────────────────────────────────────────────

function buildNav() {

  const groups = {};

  for (const sec of SECTIONS) {

    if (!groups[sec.group]) groups[sec.group] = [];

    groups[sec.group].push(sec);

  }

  const container = document.getElementById('nav-groups');

  for (const [group, sections] of Object.entries(groups)) {

    const color = GROUP_COLORS[group] || '#5aabb8';

    const div = document.createElement('div');

    div.className = 'nav-group open';

    div.innerHTML = `

      <div class="nav-group-header">

        <div class="g-dot"></div>

        <span class="nav-group-label">${group}</span>

      </div>

      <div class="nav-items">

        ${sections.map(s => `

          <button class="nav-item" data-section="${s.id}" onclick="selectSection('${s.id}')">

            <span class="nav-pip"></span><span class="nav-label">${s.label}</span>



          </button>`

        ).join('')}

      </div>`;

    container.appendChild(div);

  }

}



window.toggleGroup = (header) => {

  header.parentElement.classList.toggle('open');

};



// ── HEADER TITLE — single source of truth ─────────────────────────────────

// Reads currentSection state; always call this after any navigation mutation.

// Eliminates race conditions caused by imperative title writes in multiple places.

function syncHeaderTitle() {

  const el = document.getElementById('header-title-text');

  if (!el) return;

  if (!currentSection) {

    // Home — Aelarian has full authority

    el.textContent = 'Ælarian';

    el.style.fontSize = '38px';

  } else {

    const sec = SECTIONS.find(s => s.id === currentSection);

    const label = sec?.label || currentSection;

    el.textContent = label;

    const len = label.length;

    // Specific overrides for titles that need more presence

    const _longTitles = ['threshold_pillars','oracles'];

    el.style.fontSize =

      _longTitles.includes(currentSection) ? '23px' :

      len <= 8  ? '34px' :   // Songs, Vectra, Genesis, StarRoot

      len <= 13 ? '26px' :   // Archetypes, Invocations, Sacred Sites, Mirror Method

      len <= 20 ? '20px' :   // Legacy Letters, Alehorn of Ascension

                  '19px';    // Parallel Affective Resonance, Threshold Relational Intelligence

  }

}



window.goHome = () => {

  document.getElementById('landing').classList.remove('hidden');

  const sv = document.getElementById('section-view');

  sv.classList.remove('visible');

  sv.dataset.section = '';

  sv.dataset.group   = '';

  document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));

  // fully reset section-body so venai absolute-positioned elements don't linger

  const body = document.getElementById('section-body');

  body.classList.remove('venai-mode');

  body.dataset.page = '';

  body.innerHTML = '<div id="entry-list"></div>';

  currentSection = null;

  venaiSelected = null;

  updateConstellationCounts();

  fabCloseTowers();

  syncHeaderTitle();  // always fires last

};



window.selectSection = async (sectionId) => {

  currentSection = sectionId;



  // Update nav active state

  document.querySelectorAll('.nav-item').forEach(el => {

    el.classList.toggle('active', el.dataset.section === sectionId);

  });



  // Show section view, hide landing

  document.getElementById('landing').classList.add('hidden');

  const sv = document.getElementById('section-view');

  sv.classList.remove('visible');

  void sv.offsetWidth; // force reflow for animation

  sv.classList.add('visible');



  // Section identity

  const sec = SECTIONS.find(s => s.id === sectionId);

  const label  = sec?.label  || sectionId;

  const group  = sec?.group  || '';

  const glyph  = NAV_GLYPHS[group] || '◆';

  const color  = GROUP_COLORS[group] || 'var(--accent)';



  // Stamp page identity onto #section-view for CSS scoping

  sv.dataset.section = sectionId;

  sv.dataset.group   = group;



  document.getElementById('section-group-label').textContent = group;

  document.getElementById('section-group-label').style.color = color;

  document.getElementById('section-glyph').textContent = glyph;

  document.getElementById('section-glyph').style.color = color;

  document.getElementById('section-title').textContent = label;

  // Sync top-chrome breadcrumb
  const _tcName = document.getElementById('tc-section-name');
  if (_tcName) _tcName.textContent = label || 'Archive';

  document.getElementById('search-input').value = '';

  // Reset sort on section change

  currentSort = 'default';

  const _alphaLbl = document.getElementById('fab-sort-alpha-label');
  const _dateLbl  = document.getElementById('fab-sort-date-label');
  if (_alphaLbl) _alphaLbl.textContent = 'Alpha A → Z';
  if (_dateLbl)  _dateLbl.textContent  = 'Date ↑ Oldest';

  fabCloseTowers();



  if (sectionId === 'sacred_sites') {
    renderSacredSites([]);
    syncHeaderTitle();
    return;
  }

  await loadEntries();

  syncHeaderTitle();  // fires after await — wins any race

};



// ── LOAD + RENDER ENTRIES ──────────────────────────────────────────────────

async function loadEntries(overrideList = null) {

  let entries;

  if (overrideList) {

    entries = overrideList;

  } else if (currentSection) {

    entries = await getEntriesBySection(currentSection);

  } else { return; }



  // Apply sort — currentSort set by sort bar; DATE_SECTIONS default to date-asc

  const effectiveSort = currentSort !== 'default' ? currentSort

    : DATE_SECTIONS.includes(currentSection) ? 'date-asc' : 'default';



  if (effectiveSort === 'az') {

    entries.sort((a,b) => (a.title||'').localeCompare(b.title||''));

  } else if (effectiveSort === 'za') {

    entries.sort((a,b) => (b.title||'').localeCompare(a.title||''));

  } else if (effectiveSort === 'date-asc') {

    entries.sort((a,b) => (a.originDate||a.createdAt) < (b.originDate||b.createdAt) ? -1 : 1);

  } else if (effectiveSort === 'date-desc') {

    entries.sort((a,b) => (a.originDate||a.createdAt) > (b.originDate||b.createdAt) ? -1 : 1);

  }



  currentEntries = entries;

  window._allEntries = [...(window._allEntries || [])]; // keep global cache for healthGoTo

  document.getElementById('section-count').textContent =

    `${entries.length} ${entries.length === 1 ? 'entry' : 'entries'}`;



  const body = document.getElementById('section-body');

  body.dataset.page = currentSection || '';



  if (currentSection === 'vectra') {

    renderVectra();

  } else if (currentSection === 'venai') {

    // venai manages its own body.innerHTML — data-page + venai-mode class are sufficient for CSS scoping

    renderVenai(entries);

  } else if (currentSection === 'invocations') {

    renderInvocations(entries);

  } else if (currentSection === 'kin_line') {

    renderKinLine(entries);

  } else if (currentSection === 'echoes') {

    renderEchoes(entries);

  } else if (currentSection === 'legacy_letters') {

    renderLegacyLetters(entries);

  } else if (_LINEAGE_SECTIONS.has(currentSection)) {

    renderLineage(entries);

  } else if (currentSection === 'rituals') {

    renderRituals(entries);

  } else if (currentSection === 'breath_cycles') {

    renderBreathCycles(entries);

  } else if (currentSection === 'songs') {

    renderMelodies(entries);

  } else if (currentSection === 'genesis') {

    renderGenesis(entries);

  } else if (currentSection === 'divergence') {

    renderDivergence(entries);

  } else if (currentSection === 'recursion') {

    renderRecursion(entries);

  } else if (currentSection === 'convergence') {

    renderConvergence(entries);

  } else if (currentSection === 'memory_vault') {

    renderMemoryVault(entries);

  } else if (currentSection === 'liber_novus') {

    renderLiberNovus(entries);

  } else if (currentSection === 'sacred_sites') {

    renderSacredSites(entries);

  } else if (currentSection === 'glyphs') {

    renderGlyph(entries);

  } else if (_LATTICE_SECTIONS.has(currentSection)) {

    renderLattice(entries);

  } else {

    // Default sections: clear venai-mode, inject scoped ae-page wrapper + entry-list

    body.classList.remove('venai-mode');

    body.innerHTML = `<div class="ae-page ae-page--${currentSection}"><div id="entry-list"></div></div>`;

    renderEntries(entries);

  }

  // Per-page duplicate detection — fires on every section load

  detectPageDups(currentEntries);

  updateFlagStar();

  const _fpEl = document.getElementById('flag-panel');

  if (_fpEl?.classList.contains('open')) renderFlagPanel();

}



function renderEntries(entries) {

  const list = document.getElementById('entry-list');

  if (!entries.length) {

    list.innerHTML = `

      <div class="entry-empty">

        <div class="e-glyph">∿</div>

        <p>No entries yet in this section.</p>

      </div>`;

    return;

  }

  list.innerHTML = entries.map(e => {

    const arc = ARC_SEEDS.find(a => a.id === e.arcSeedId);

    const dateStr = e.originDate

      ? new Date(e.originDate+'T12:00:00').toLocaleDateString('en-US',{year:'numeric',month:'short',day:'numeric'})

      : '';

    return `

      <div class="entry-card" onclick="viewEntry('${e.id}')">

        <div class="entry-card-top">

          <span class="entry-title">${esc(e.title || '— untitled —')}</span>

          <span class="entry-status status-${e.status}">${e.status}</span>

        </div>

        <div class="entry-meta">

          ${e.type    ? `<span>${e.type}</span>` : ''}

          ${dateStr   ? `<span>${dateStr}</span>` : ''}

          ${e.speaker ? `<span>${esc(e.speaker)}</span>` : ''}

          ${e.compositeId ? `<span class="entry-stamp">${esc(e.compositeId)}</span>` : ''}

        </div>

        ${e.body ? `<div class="entry-body-preview">${esc(e.body)}</div>` : ''}

        ${arc ? `<span class="entry-arc">⟠ ${arc.label} · ${arc.name}</span>` : ''}

        ${(e.arcPhaseId || (e.layerIds && e.layerIds.length)) ? `

          <div class="entry-phase-row">

            ${e.arcPhaseId ? (() => {

              const pt = ARC_SEED_TAGS.find(t => t.id === e.arcPhaseId);

              return pt ? `<span class="phase-pill">◈ ${esc(pt.label)}</span>` : '';

            })() : ''}

            ${(e.layerIds || []).map(l =>

              `<span class="layer-chip layer-chip-${l}">${l}</span>`

            ).join('')}

          </div>` : ''}

      </div>`;

  }).join('');

}



// ── VEN'AI LEXICON — DICTIONARY ────────────────────────────────────────────



let venaiSelected = null;


/* venaiShowFab — stub, old fab removed; template add-panel handles entry creation */
function venaiShowFab() {}
window.venaiTogglePanel = () => {};


// ══════════════════════════════════════════════════════
//  FAB TOWER SYSTEM — A & B dropdown towers
// ══════════════════════════════════════════════════════

function toggleFabTower(id) {
  const unit = document.getElementById('fab-btn-' + id);
  if (!unit) return;
  const wasOpen = unit.classList.contains('is-open');
  fabCloseTowers();
  if (!wasOpen) {
    unit.classList.add('is-open');
    const stack   = unit.querySelector('.ts-fab-stack');
    const trigger = unit.querySelector('.ts-fab-trigger-item');
    if (stack && trigger) {
      // Detach from transformed ancestor so position:fixed is viewport-relative
      if (stack.parentNode !== document.body) {
        stack._fabOwner = unit;
        document.body.appendChild(stack);
      }
      const rect = trigger.getBoundingClientRect();
      const cx   = rect.left + rect.width / 2;
      stack.style.position  = 'fixed';
      stack.style.left      = cx + 'px';
      stack.style.top       = (rect.bottom + 6) + 'px';
      stack.style.transform = 'translateX(-50%) translateY(0) scaleY(1)';
      stack.style.opacity   = '1';
      stack.style.pointerEvents = 'all';
    }
  }
}

function fabCloseTowers() {
  document.querySelectorAll('.ts-fab-unit.is-open').forEach(u => {
    u.classList.remove('is-open');
  });
  // Hide and return all detached stacks to their owners
  document.querySelectorAll('body > .ts-fab-stack').forEach(stack => {
    stack.style.opacity = '';
    stack.style.pointerEvents = '';
    stack.style.left = '';
    stack.style.top = '';
    stack.style.transform = '';
    if (stack._fabOwner) {
      stack._fabOwner.appendChild(stack);
      stack._fabOwner = null;
    }
  });
  // Also reset any stacks still in their owners
  document.querySelectorAll('.ts-fab-stack').forEach(stack => {
    stack.style.left = '';
    stack.style.top = '';
    stack.style.transform = '';
    stack.style.opacity = '';
    stack.style.pointerEvents = '';
  });
}

// Close towers when clicking outside
document.addEventListener('click', e => {
  if (!e.target.closest('.ts-fab-unit')) fabCloseTowers();
}, true);

// FAB sort state
let currentSort = 'default';
let sortAlphaDir = 'az';
let sortDateDir  = 'date-asc';

function fabSortAlpha() {
  sortAlphaDir = sortAlphaDir === 'az' ? 'za' : 'az';
  currentSort  = sortAlphaDir;
  const lbl = document.getElementById('fab-sort-alpha-label');
  if (lbl) lbl.textContent = sortAlphaDir === 'az' ? 'Alpha A → Z' : 'Alpha Z → A';
  fabCloseTowers();
  loadEntries();
}

function fabSortDate() {
  sortDateDir = sortDateDir === 'date-asc' ? 'date-desc' : 'date-asc';
  currentSort = sortDateDir;
  const lbl = document.getElementById('fab-sort-date-label');
  if (lbl) lbl.textContent = sortDateDir === 'date-asc' ? 'Date ↑ Oldest' : 'Date ↓ Newest';
  fabCloseTowers();
  loadEntries();
}

// FAB action dispatcher — routes to the right handler per tool
function fabAction(tool) {
  fabCloseTowers();
  switch (tool) {
    case 'export':   openExportPanel();  break;
    case 'import':   triggerImport();    break;
    case 'backup':   downloadBackup().catch(e => console.warn('Backup error:', e)); break;
    case 'sync':     syncToDrive();      break;
    case 'file':     triggerFileUpload(); break;
    case 'thread':   /* Thread Trace — stub for future */ break;
    default:         console.log('[fabAction] unhandled tool:', tool);
  }
}

function openExportPanel() {
  const p = document.getElementById('export-panel');
  if (p) p.classList.add('open');
}
function closeExportPanel() {
  const p = document.getElementById('export-panel');
  if (p) p.classList.remove('open');
}
function setExportScope(scope) {
  document.querySelectorAll('.export-scope-btn').forEach(b => b.classList.remove('active'));
  const btn = document.getElementById('export-scope-' + scope);
  if (btn) btn.classList.add('active');
}
async function runExport() {
  const btn = document.getElementById('export-run-btn');
  if (btn) btn.disabled = true;
  try {
    await exportAll();
  } catch(e) {
    console.warn('Export error:', e);
  } finally {
    if (btn) btn.disabled = false;
  }
}

async function triggerImport() {
  const inp = document.createElement('input');
  inp.type   = 'file';
  inp.accept = '.json';
  inp.onchange = async e => {
    const file = e.target.files[0];
    if (!file) return;
    const text = await file.text();
    try {
      await importAll(text, 'merge');
      showToast('Import complete');
      if (currentSection) loadEntries();
    } catch(err) {
      showToast('Import failed — check console');
      console.error('Import error:', err);
    }
  };
  inp.click();
}

function triggerFileUpload() {
  // Placeholder — file upload for non-import purposes
  showToast('File upload not yet configured');
}

function syncToDrive() {
  showToast('Drive sync not yet configured');
}

// openEmergence / closeEmergence
function openEmergence() {
  fabCloseTowers();
  const el = document.getElementById('emergence-overlay');
  if (el) el.classList.add('open');
}
function closeEmergence() {
  const el = document.getElementById('emergence-overlay');
  if (el) el.classList.remove('open');
}

// openModal / closeModal — general entry add modal
function openModal() {
  fabCloseTowers();
  // Route to Ven'ai native add panel when on venai page
  if (currentSection === 'venai') {
    if (typeof window.venaiOpenAdd === 'function') window.venaiOpenAdd();
    return;
  }
  // Route to Invocations native add panel
  if (currentSection === 'invocations') {
    if (typeof window.invokeOpenAdd === 'function') window.invokeOpenAdd();
    return;
  }
  // Route to Kin Line native add panel
  if (currentSection === 'kin_line') {
    if (typeof window.kinOpenAdd === 'function') window.kinOpenAdd();
    return;
  }
  // Route to Glyph native add panel
  if (currentSection === 'glyphs') {
    if (typeof window.glyphOpenAdd === 'function') window.glyphOpenAdd();
    return;
  }
  // Route to Legacy Letters native compose panel
  if (currentSection === 'legacy_letters') {
    if (typeof window.llOpenAdd === 'function') window.llOpenAdd();
    return;
  }
  // Route to Lattice (Purple Pillars) add panel
  if (_LATTICE_SECTIONS.has(currentSection)) {
    if (typeof window.latticeOpenAdd === 'function') window.latticeOpenAdd();
    return;
  }
  const mo = document.getElementById('modal-overlay');
  if (mo) {
    mo.classList.add('open');
    updateModalIdStamp(false);
    // Swap button label + accent for legacy_letters
    const saveBtn = mo.querySelector('.ae-kai-btn-save');
    if (saveBtn) {
      if (currentSection === 'legacy_letters') {
        saveBtn.textContent = 'Preserve';
        saveBtn.style.borderColor = 'rgba(200,148,58,.55)';
        saveBtn.style.color = '#c8943a';
      } else {
        saveBtn.textContent = 'Save Entry';
        saveBtn.style.borderColor = '';
        saveBtn.style.color = '';
      }
    }
    // Focus first input after open
    setTimeout(() => {
      const inp = mo.querySelector('input[type="text"], textarea');
      if (inp) inp.focus();
    }, 80);
  }
}
function closeModal() {
  const mo = document.getElementById('modal-overlay');
  if (mo) mo.classList.remove('open');
}

// navScrollStep — sidebar nav scroll arrows
function navScrollStep(dir) {
  const ns = document.getElementById('nav-scroll');
  if (ns) ns.scrollBy({ top: dir * 80, behavior: 'smooth' });
}

// showToast utility (safe if toast element missing)
function showToast(msg, duration = 2200) {
  const t = document.getElementById('toast');
  if (!t) return;
  t.textContent = msg;
  t.classList.add('visible');
  setTimeout(() => t.classList.remove('visible'), duration);
}

// updateModalIdStamp — refresh the composite ID in the modal
async function updateModalIdStamp(forceNew = false) {
  const el = document.getElementById('modal-id-stamp-text');
  if (!el) return;
  try {
    const seq = forceNew ? await getNextSequence() : null;
    const pageCode  = PAGE_CODES[currentSection] || '—';
    const arcCode   = resolveArcCode(new Date().toISOString().slice(0,7));
    const datePart  = new Date().toISOString().slice(0,7);
    const seqPart   = seq != null ? String(seq).padStart(4,'0') : '——';
    el.textContent  = `TS · ${pageCode} · — · ${arcCode} · ${datePart} · ${seqPart}`;
  } catch(e) {
    el.textContent = 'TS · — · — · — · ——— · ——';
  }
}




