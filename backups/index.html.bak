

















<!DOCTYPE html>

<html lang="en">

<head>

<meta charset="UTF-8" />

<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>Ælarian's Lantern · Λ-⟠</title>

<link rel="preconnect" href="https://fonts.googleapis.com" />

<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Cinzel+Decorative:wght@400;700&family=Inconsolata:wght@300;400&family=Josefin+Sans:wght@100;200;300&family=IM+Fell+DW+Pica:ital@1&family=Pinyon+Script&family=DM+Mono:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet" />

<style>/* cache-bust: 1772905294 */



/* ── TOKENS — CYAN DRIFT ─────────────────────────────────────────────────── */

:root {

  --harmonic: 0;

  --harmonic-time: 0;

  /* Cyan Drift core */

  --ind-abyss:     #07080F;

  --ind-deep:      #0D1020;

  --ind-navy:      #141838;

  --ind-mid:       #1E2255;

  --ind-blue:      #2A2E78;

  --ind-violet:    #3D3A8C;

  --ind-soft:      #5855A8;

  --ind-mist:      #8885C4;

  --steel-dark:    #1E2C3E;

  --steel-mid:     #2E4055;

  --steel-cool:    #3E5570;

  --steel-muted:   #5A7088;

  --steel-slate:   #7A92A8;

  --steel-silver:  #A8BCC8;

  --steel-pale:    #C8D8E4;

  --steel-frost:   #DDE8F0;

  --steel-moon:    #EEF4F8;

  --arc-cyan:      #4A9CB8;

  --arc-silver:    #9AB8CC;

  --arc-violet:    #7A7ACC;



  /* Semantic aliases mapped to Cyan Drift */

  --void:          #030106;   /* plum-void — page bg */

  --abyss:         #0D1020;   /* ind-deep */

  --deep:          #141838;   /* ind-navy — content home / inner frame */

  --mid:           #1E2C3E;   /* steel-dark — inputs */

  --warm:          #2E4055;   /* steel-mid */

  --bright:        #3E5570;   /* steel-cool */

  --accent:        #4A9CB8;   /* arc-cyan */

  --pale:          #9AB8CC;   /* arc-silver */

  --plum-deep:     #07080F;   /* ind-abyss */

  --plum-mid:      #0D1020;   /* ind-deep */

  --plum-warm:     #251840;   /* kept for nav-group headers */

  --gold:          #8c6620;

  --gold-warm:     #a07828;

  --gold-pale:     #c8943a;

  --silver:        #7A92A8;   /* steel-slate */

  --silver-warm:   #9AB8CC;   /* arc-silver */

  --silver-pale:   #C8D8E4;   /* steel-pale */

  --fog:           #DDE8F0;   /* steel-frost */

  --mauve:         #7A7ACC;   /* arc-violet */

  --iris:          #5855A8;   /* ind-soft */

  --rose:          #c87888;

  --text-primary:  #C8D8E4;   /* steel-pale */

  --text-dim:      #5A7088;   /* steel-muted */

  --text-muted:    #3E5570;   /* steel-cool */

  --border:        rgba(74,156,184,0.12);

  --border-warm:   rgba(74,156,184,0.25);

  --glow-sm:       rgba(74,156,184,0.06);

  --glow-md:       rgba(74,156,184,0.13);



  /* group colors — shifted to Cyan Drift tones */

  --g-lattice:      #4A9CB8;

  --g-filament:     #7A7ACC;

  --g-lineage:      #c8943a;

  --g-alchemy:      #5855A8;

  --g-spiral:       #c87888;

  --g-architecture: #9AB8CC;

  --g-creation:     #3E5570;

  --g-omega:        #8885C4;



  --nav-w:         210px;

  --header-h:      0px;

  --font-display:  'Cinzel Decorative', serif;

  --font-head:     'Cinzel Decorative', serif;

  --font-body:     'Cormorant Garamond', serif;

  --font-mono:     'Inconsolata', monospace;

  --ease-out:      cubic-bezier(0.16, 1, 0.3, 1);



  /* ── Background void palette ── */

  --bg-top:        #160d1e;

  --bg-mid:        #241530;

  --bg-bottom:     #06050a;

}



/* ── RESET ──────────────────────────────────────────────────────────────── */

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }



/* ── BREATHING VOID KEYFRAME ─────────────────────────────────────────────── */

@keyframes voidBreathe {

  0%,  100% { opacity: 0.55; }

  48%       { opacity: 0.95; }

  52%       { opacity: 0.90; }

}



html, body { height: 100%; overflow: hidden; }

html { font-size: 20px; background-color: #0a0614; }

body {

  margin: 0;

  background-color: transparent;

  --void: #0a0614;

  background-image: none;

  color: var(--text-primary);

  font-family: var(--font-body);

  font-size: 1rem;

  line-height: 1.6;

}

#nav-scroll::-webkit-scrollbar { width: 5px; }

#nav-scroll::-webkit-scrollbar-track { background: transparent; }

#nav-scroll::-webkit-scrollbar-thumb { background: #2E4055; border-radius: 2px; }



/* ── GLOBAL SCROLLBARS — landing + content areas ── */

#landing::-webkit-scrollbar,

#section-body::-webkit-scrollbar,

#content-area::-webkit-scrollbar { width: 5px; height: 5px; }

#landing::-webkit-scrollbar-track,

#section-body::-webkit-scrollbar-track,

#content-area::-webkit-scrollbar-track { background: transparent; }

#landing::-webkit-scrollbar-thumb,

#section-body::-webkit-scrollbar-thumb,

#content-area::-webkit-scrollbar-thumb { background: #2E4055; border-radius: 2px; }

#landing::-webkit-scrollbar-corner,

#section-body::-webkit-scrollbar-corner,

#content-area::-webkit-scrollbar-corner { background: var(--void); }



/* ── AMBIENT — GOSSAMER PLUM · A3 ───────────────────────────────────────────
   1. base             — deep plum-void
   2. center bloom     — plum mid, wide spacious falloff
   3. rose warmth      — whisper at the core, felt not seen
   4. bilateral        — left & right edges recede softly
   5. corner voids     — four gentle darkeners
─────────────────────────────────────────────────────────────────────────── */

#ambient {

  position: fixed; inset: 0;

  pointer-events: none; z-index: 2;

  background:

    radial-gradient(ellipse 30% 30% at 50% 50%, rgba(61,32,96,0.11)    0%, transparent 100%),

    radial-gradient(ellipse 60% 60% at 50% 50%, rgba(20,10,36,0.42)    0%, rgba(10,6,20,0.58) 55%, transparent 100%),

    linear-gradient(to right,  rgba(14,9,22,0.60)  0%, rgba(26,16,36,0.18) 30%, transparent 100%),

    linear-gradient(to left,   rgba(14,9,22,0.60)  0%, rgba(26,16,36,0.18) 30%, transparent 100%),

    radial-gradient(ellipse 40% 40% at   0%   0%, rgba(6,5,10,0.55)    0%, transparent 100%),
    radial-gradient(ellipse 40% 40% at 100%   0%, rgba(6,5,10,0.55)    0%, transparent 100%),
    radial-gradient(ellipse 40% 40% at   0% 100%, rgba(6,5,10,0.55)    0%, transparent 100%),
    radial-gradient(ellipse 40% 40% at 100% 100%, rgba(6,5,10,0.55)    0%, transparent 100%);

  animation: ambientBreath 12s ease-in-out infinite;

}



/* ── Resonance Engine center ring ornament ── */

@keyframes re-spin-slow {

  from { transform: rotate(0deg); }

  to   { transform: rotate(360deg); }

}

@keyframes re-pulse-glow {

  0%,100% {

    filter: drop-shadow(0 0 3px #caa24c33) drop-shadow(0 0 1px #d4af3722);

  }

  50% {

    filter: drop-shadow(0 0 10px #caa24c77) drop-shadow(0 0 4px #f1d57c44);

  }

}

.re-rot-fast {

  /* rotation now JS-driven via centerRingRef */

}

.re-gp { animation: re-pulse-glow 3.5s ease-in-out infinite; }



@keyframes ambientBreath {

  0%, 100% { opacity: .8; }

  50%       { opacity: 1; }

}



/* ── SHELL ──────────────────────────────────────────────────────────────── */

#app {

  position: relative; z-index: 3;

  width: 100vw; height: 100vh;

  overflow: hidden;

}

/* ── Gap veil — blends the strip between sidebar and content viewer ── */

#app::after {

  content: "";

  position: fixed;

  top: var(--header-h); bottom: 0;

  left: calc(var(--nav-w) + 0.6rem);

  width: 5rem;

  pointer-events: none;

  z-index: 2;

  background: transparent;

  mix-blend-mode: multiply;

  animation: veilBreathe 18s ease-in-out infinite;

}

@keyframes veilBreathe {

  0%,  100% { opacity: 0.75; }

  50%       { opacity: 0.95; }

}




/* ── Glyph-line: fixed bottom-center home beacon ── */

/* ======================================================
   Go Home Glyph Line — condenses from atmosphere
   ====================================================== */

@keyframes glyph-pulse-void {
  0%, 100% {
    text-shadow:
      0 0 1px rgba(42,110,124,0.85),
      0 0 3px rgba(42,110,124,0.2);
    filter: drop-shadow(0 0 1px rgba(42,110,124,0.15));
  }
  50% {
    text-shadow:
      0 0 1.5px rgba(42,110,124,0.9),
      0 0 4px rgba(42,110,124,0.25);
    filter: drop-shadow(0 0 1.5px rgba(42,110,124,0.2));
  }
}

#glyph-line {
  position: fixed;
  bottom: 18px;
  left: calc(var(--nav-w) + (100vw - var(--nav-w)) / 2);
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.25em;
  pointer-events: auto;
  cursor: pointer;
  z-index: 120;
  isolation: isolate;
  padding: 4px 14px 5px;
  background: transparent;
  mix-blend-mode: normal;
  animation: glyph-pulse-void 4s ease-in-out infinite;
  transition: background 0.3s ease;
}

#glyph-line:hover {
  animation-play-state: paused;
  background: transparent;
}

#glyph-line:hover .glyph,
#glyph-line:hover .elaria {
  background: linear-gradient(
    90deg,
    #f2dc88 0%,
    #e8c060 50%,
    #d4a044 100%
  );
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  text-shadow: none;
  filter: drop-shadow(0 0 4px rgba(242,220,136,.5))
          drop-shadow(0 0 10px rgba(201,148,58,.3));
}

#glyph-line .glyph,
#glyph-line .elaria {
  font-family: 'Cinzel Decorative', serif;
  font-weight: 400;
  font-size: 1.15rem;
  background: linear-gradient(
    90deg,
    #c9943a 0%,
    #e8c060 40%,
    #d4a044 70%,
    #b07830 100%
  );
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  -webkit-text-stroke: 0px;
  text-shadow: none;
  filter: drop-shadow(0 0 2px rgba(201,148,58,.35));
  transition: background 0.3s ease, filter 0.3s ease;
}

/* ── CELESTIAL PHRASE BAR ─────────────────────────────────────────────────── */

#celestial-phrase {
  position: fixed;
  top: 18px;
  left: calc(var(--nav-w) + (100vw - var(--nav-w)) / 2);
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  pointer-events: none;
  z-index: 220;
  white-space: nowrap;
  overflow: visible;
}

#celestial-phrase .cp-phrase-row {
  display: flex;
  align-items: center;
  gap: 0.5em;
  pointer-events: auto;
}

#celestial-phrase .cp-fab-left,
#celestial-phrase .cp-fab-right {
  pointer-events: auto;
  position: relative;
}

#celestial-phrase .cp-phrase {
  font-family: 'Pinyon Script', cursive;
  font-weight: 400;
  font-style: normal;
  font-size: 1.5rem;
  color: #DDE8F0;
  letter-spacing: 0.1em;
  font-variant: normal;
  font-variant-caps: normal;
  text-transform: none;
  padding: 5px 0 4px;
  text-shadow: none;
}

#celestial-phrase .cp-bar { display: none; }

#ts-fab-row,

#ts-fab-row * {

  pointer-events: auto;

}


/* ── Sync FAB star — live state glow ──────────────────────────────────────────── */

.ts-fab-item[data-tool="sync"].sync-active .ts-fab-star .star-svg {

  filter: drop-shadow(0 0 5px rgba(74,200,130,0.90))

          drop-shadow(0 0 14px rgba(40,160,90,0.65))

          drop-shadow(0 0 28px rgba(20,120,60,0.32)); }

.ts-fab-item[data-tool="sync"].sync-saving .ts-fab-star .star-svg {

  filter: drop-shadow(0 0 5px rgba(74,156,184,0.90))

          drop-shadow(0 0 14px rgba(40,120,160,0.65));

  animation: syncStarPulse 0.9s ease-in-out infinite; }

.ts-fab-item[data-tool="sync"].sync-error .ts-fab-star .star-svg {

  filter: drop-shadow(0 0 5px rgba(220,140,40,0.90))

          drop-shadow(0 0 14px rgba(180,100,20,0.65))

          drop-shadow(0 0 26px rgba(140,60,0,0.32));

  animation: syncStarWarn 2s ease-in-out infinite; }

@keyframes syncStarPulse { 0%,100% { opacity:.65; } 50% { opacity:1; } }

@keyframes syncStarWarn  { 0%,100% { opacity:.75; } 50% { opacity:1; } }







/* ── SIDEBAR ─────────────────────────────────────────────────────────────── */



/* CON-25 · Ornamental frame · Gold on Black                                  */



#sidebar {

  position: fixed;

  top: calc(var(--header-h) + .75rem);

  left: 1rem;

  width: var(--nav-w);

  height: calc(100vh - var(--header-h) - 1.5rem);

  z-index: 100;

  border-radius: 4px;

  background-color: rgba(15,16,18,0.60);

  backdrop-filter: blur(6px);

  border: none;

  box-shadow: inset -1px 0 4px rgba(15,16,18,0.25);

  display: flex; flex-direction: column;

  overflow: visible;

}



/* ── ATMOSPHERIC FIELD ──────────────────────────────────────────────────── */

.atmosphere {

  position: fixed;

  inset: 0;

  pointer-events: none;

  z-index: -3;

}

/* Primary mist — screens over void, breathes on timed harmonic */

.mist-layer {

  position: absolute;

  inset: -8%;

  background:

    radial-gradient(ellipse 70% 55% at 50% 45%,

      rgba(90,25,80,.55),

      rgba(8,3,12,.0));

  mix-blend-mode: normal;

  animation: mistSwirl 160s ease-in-out infinite;

  opacity: calc(.55 + var(--harmonic-time) * .30);

}

/* Secondary mist — offset phase, counter-drift, adds depth */

.mist-layer::after {

  content: "";

  position: absolute;

  inset: 0;

  background:

    radial-gradient(ellipse 55% 70% at 35% 62%,

      rgba(70,18,90,.38),

      transparent 65%),

    radial-gradient(ellipse 45% 50% at 68% 38%,

      rgba(55,12,75,.28),

      transparent 60%);

  mix-blend-mode: normal;

  animation: mistSwirlB 220s ease-in-out infinite reverse;

  opacity: calc(.40 + var(--harmonic-time) * .25);

}

.noise-layer {

  position: absolute;

  inset: 0;

  opacity: .06;

  mix-blend-mode: soft-light;

  background-image: url("noise.png");

  background-size: 300px 300px;

  animation: noiseShift 45s linear infinite;

}

.gold-dust {

  position: absolute;

  inset: 0;

  background-image:

    radial-gradient(circle,

    rgba(255,215,140,.25) 1px,

    transparent 2px);

  background-size: 180px 180px;

  opacity: .04;

  animation: dustDrift 240s linear infinite;

}



/* Void deepener — multiply punches dark zones between mist wisps */

.mist-void {

  position: absolute;

  inset: 0;

  background:

    radial-gradient(ellipse 80% 60% at 50% 50%,

      transparent 30%,

      rgba(1,0,3,.72) 100%),

    radial-gradient(ellipse 40% 50% at 20% 80%,

      rgba(0,0,2,.55),

      transparent 65%),

    radial-gradient(ellipse 35% 45% at 78% 18%,

      rgba(0,0,2,.50),

      transparent 65%);

  mix-blend-mode: multiply;

  animation: mistSwirl 200s ease-in-out infinite reverse;

}

/* Orbital swirl — diagonal drift + gentle scale pulse */

@keyframes mistSwirl {

  0%   { transform: translate(0,     0)     scale(1.00); }

  25%  { transform: translate(18px, -22px)  scale(1.03); }

  50%  { transform: translate(8px,  -45px)  scale(1.06); }

  75%  { transform: translate(-14px,-28px)  scale(1.02); }

  100% { transform: translate(0,     0)     scale(1.00); }

}

@keyframes mistSwirlB {

  0%   { transform: translate(0,     0)    scale(1.00); }

  33%  { transform: translate(-22px, 16px) scale(1.04); }

  66%  { transform: translate(12px,  30px) scale(1.02); }

  100% { transform: translate(0,     0)    scale(1.00); }

}

@keyframes noiseShift {

  from { transform: translateX(0); }

  to   { transform: translateX(200px); }

}

@keyframes dustDrift {

  from { transform: translate(0,0); }

  to   { transform: translate(-200px,100px); }

}



/* ── Slow cosmic rotation ────────────────────────────────────────────────── */

/* ── VOID WELL — z-index stack: -20 to -16 ─────────────────────────────── */



/* Layer -20: void base */

.cosmic-void {

  position: fixed;

  inset: 0;

  pointer-events: none;

  z-index: -20;

  background:

    radial-gradient(circle at 50% 50%, #030106 0%, #05020a 35%, #030106 70%),

    radial-gradient(circle at 20% 80%, rgba(0,0,0,.8), transparent 60%),

    radial-gradient(circle at 80% 20%, rgba(0,0,0,.7), transparent 60%);

}



/* Layer -19: noise texture */

.cosmic-noise {

  position: fixed;

  inset: 0;

  pointer-events: none;

  z-index: -19;

  opacity: .035;

  background-image: url(noise.png);

  background-size: 280px;

  mix-blend-mode: soft-light;

  animation: noiseDrift 70s linear infinite;

}

@keyframes noiseDrift {

  from { transform: translateX(0); }

  to   { transform: translateX(120px); }

}



/* Layer -18: field scatter */

.field-scatter {

  position: fixed;

  inset: 0;

  pointer-events: none;

  z-index: -18;

  background:

    radial-gradient(circle at 55% 40%, rgba(170,120,210,.03), transparent 55%),

    radial-gradient(circle at 40% 65%, rgba(120,80,180,.02),  transparent 60%);

  filter: blur(40px);

  animation: scatterDrift 120s ease-in-out infinite;

}

@keyframes scatterDrift {

  0%, 100% { transform: translateY(0); }

  50%       { transform: translateY(-40px); }

}



/* Layer -17: shadow field */

.shadow-field {

  position: fixed;

  inset: 0;

  pointer-events: none;

  z-index: -17;

  background:

    radial-gradient(ellipse at 60% 90%, rgba(0,0,0,.45), transparent 70%),

    radial-gradient(ellipse at 10% 30%, rgba(0,0,0,.35), transparent 70%);

}



/* Layer -16: atmosphere rotation (reuses cosmicTurn keyframe, 1800s) */

.atmosphere-rotation {

  position: fixed;

  inset: -20%;

  pointer-events: none;

  z-index: -16;

  background: radial-gradient(circle, rgba(200,160,255,.04), transparent 60%);

  animation: cosmicTurn 900s linear infinite;

}



/* ── Sidebar mist — radial glow inner atmosphere ── */

/* -- Sidebar ghost: plum mist + inner vignette -- */

.sidebar-ghost {

  position: absolute;

  inset: 0;

  pointer-events: none;

  z-index: 0;

  background:

    transparent;

  animation: mistNoise 12s ease-in-out infinite;

}

@keyframes mistNoise {

  0%,100% { opacity: .06; background-position: 0% 0%;   }

  25%     { opacity: .12; background-position: 8% 5%;   }

  50%     { opacity: .08; background-position: -8% 5%;  }

  75%     { opacity: .10; background-position: 5% -8%;  }

}






/* ── Perimeter wave canvas — fixed, overlays sidebar border ── */



/* ── Sine-wave scrollbar canvas ─────────────────────────────────────────── */



/* ── CON-25 ornamental frame overlay ── */

#sidebarFrame {

  position: absolute; inset: 0;

  pointer-events: none; z-index: 20;

  width: 100%; height: 100%;

}

.scroll-track {

  position: absolute; right: 7px; top: 70px; bottom: 70px;

  width: 1px; background: #1a1710; z-index: 21;

}

.scroll-thumb {

  position: absolute; width: 1px; left: 0;

  background: linear-gradient(180deg, transparent, #F0CC7A, transparent);

  opacity: 0.6;

}



/* ── Nav scroll area ── */

#nav-scroll {

  position: relative;

  z-index: 2;

  flex: 1; overflow-y: scroll; overflow-x: hidden;

  padding: .5rem 0 .5rem;

  scrollbar-width: none;

}

#nav-scroll::-webkit-scrollbar { display: none; }



/* ── SIDEBAR PERIMETER WAVES ────────────────────────────────────────────── */

/* ── SVG Harmonic Filaments — fixed ─────────────────────────────────────── */





/* ── Sidebar Gold Rails ───────────────────────────────────────────────────── */



/* ── Gold UI utility class ──────────────────────────────────────────────── */

.gold-ui {

  color: #d8b45a;

  text-shadow:

    0 -1px 4px rgba(255,220,140,.35),

    0  2px 6px rgba(60,40,10,.55);

  filter: brightness(calc(1 + var(--harmonic) * .3));

}







/* ── Sidebar footer rule ── */

#sidebar-footer {

  position: relative; z-index: 2;

  flex-shrink: 0;

  padding: 5px 14px 10px;

}

#sidebar-footer-rule {

  height: 1px;

  background: linear-gradient(90deg, transparent, #B8892A 20%, #F0CC7A 50%, #B8892A 80%, transparent);

  position: relative; margin-bottom: 6px;

}

#sidebar-footer-rule::before {

  content: '◆';

  position: absolute; left: 18%; top: 50%;

  transform: translateY(-50%);

  font-size: 4px; color: #F0CC7A; line-height: 1;

}

#sidebar-footer-rule::after {

  content: '◆';

  position: absolute; right: 18%; top: 50%;

  transform: translateY(-50%);

  font-size: 4px; color: #F0CC7A; line-height: 1;

}

#sidebar-footer-id {

  font-family: 'Josefin Sans', var(--font-head);

  font-weight: 200;

  font-size: 8px; letter-spacing: .18em;

  text-transform: uppercase;

  color: #D4A84B;

  text-shadow: 0 0 8px rgba(212,168,75,0.45), 0 0 18px rgba(180,130,40,0.22);

  text-align: center;

}



/* ── Nav groups ── */

.nav-group { }

.nav-group-header {

  display: flex; align-items: center; gap: .3rem;

  padding: .22rem .5rem .2rem;

  cursor: pointer;

  font-family: 'Cinzel Decorative', serif;

  font-weight: 400;

  font-size: 8px; letter-spacing: .10em;

  text-transform: uppercase;

  user-select: none;

  position: relative;

  color: #D4A84B;

  text-shadow: 0 0 8px rgba(212,168,75,0.45), 0 0 18px rgba(180,130,40,0.22);

  transition: color .15s, text-shadow .15s;

}

.nav-group-header:hover { color: #F0CC7A; text-shadow: 0 0 10px rgba(240,204,122,0.65), 0 0 24px rgba(212,168,75,0.35); }

.nav-group-header .g-dot {

  flex-shrink: 0;

  position: relative;

  width: 12px; height: 12px;

}

.nav-group-header .g-dot::before,

.nav-group-header .g-dot::after {

  content: '';

  position: absolute; inset: 0;

}

.nav-group-header .g-dot::before {

  clip-path: polygon(50% 0%, 53% 47%, 100% 50%, 53% 53%, 50% 100%, 47% 53%, 0% 50%, 47% 47%);

  background: #B8892A;

  animation: navDotBreath 4s ease-in-out infinite;

}

.nav-group-header .g-dot::after {

  clip-path: polygon(50% 10%, 52% 48%, 90% 50%, 52% 52%, 50% 90%, 48% 52%, 10% 50%, 48% 48%);

  background: rgba(240,204,122,0.35);

  transform: rotate(22.5deg);

  animation: navDotBreath 4s ease-in-out infinite reverse;

}

.nav-group-header:hover .g-dot::before { background: #F0CC7A; }

@keyframes navDotBreath {

  0%,100% { opacity: .45; }

  50%      { opacity: 1; filter: drop-shadow(0 0 3px rgba(212,168,75,0.6)); }

}



.nav-items { display: none; padding: .1rem 0 .4rem; }

.nav-group.open .nav-items { display: block; }



.nav-item {

  display: flex; align-items: center; gap: 6px;

  width: 100%; background: none; border: none;

  text-align: left;

  padding: .24rem .7rem .24rem 1.2rem;

  font-family: 'Cormorant Garamond', serif;

  font-weight: 400;

  font-size: .80rem;

  font-style: italic;

  letter-spacing: .04em;

  text-transform: none;

  color: #8a6830;

  cursor: pointer;

  transition: all .15s;

  position: relative;

}

.nav-label {

  text-transform: capitalize;

}

/* CON-25 left-sweep hover bar */

.nav-item::before {

  content: '';

  position: absolute;

  left: 0; top: 0; bottom: 0; width: 0;

  background: linear-gradient(90deg, rgba(124,90,26,0.25), transparent);

  transition: width .25s ease;

}

.nav-item:hover { color: #D4A84B; }

.nav-item:hover::before { width: 100%; }

.nav-item.active { color: #F0CC7A; }

.nav-item.active::before { width: 100%; background: linear-gradient(90deg, rgba(124,90,26,0.18), transparent); }



/* CON-25 diamond pip */

.nav-pip {

  width: 4px; height: 4px;

  background: #493a17;

  transform: rotate(45deg);

  flex-shrink: 0;

  transition: all .15s;

}

.nav-item:hover .nav-pip { background: #B8892A; box-shadow: 0 0 4px rgba(212,168,75,0.5); }

.nav-item.active .nav-pip { background: #F0CC7A; box-shadow: 0 0 6px rgba(240,204,122,0.7); }





/* ── MAIN CONTENT ───────────────────────────────────────────────────────── */

/* ── FRAME SYSTEM ───────────────────────────────────────────────────────── */

/* Three nested layers: outer frame → matte → viewer                        */

/* Sidebar floats outside this system entirely                               */



/* Layer 1 — Outer frame: Steel Dark #1E2C3E — coolest blue-grey, separates from bg */

#content {

  position: fixed;

  top: calc(var(--header-h) + 0.4rem);

  left: calc(var(--nav-w) + 1.8rem);

  right: 0;

  bottom: calc(52px + 0.4rem);

  z-index: 1;

  border-radius: 8px;

  border: none;

  overflow: visible;

  backdrop-filter: blur(2px);

  background:
    transparent;

  

}







/* Diffusion halo — aurora bleeds outside the viewer rectangle */

/* Diffusion halo — aurora bleeds outside the viewer rectangle, merges with void */

#content::after {
  background: transparent;
  filter: blur(28px);

  opacity: .75;

  animation: auroraBreath 30s ease-in-out infinite;

}

@keyframes auroraBreath {

  0%, 100% { opacity: .60; }

  50%       { opacity: .90; }

}



/* Resonance engine - fills #landing, centers spiral */

#resonance-root {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  z-index: 1;
}

#spiral-svg {

  display: block;

  flex-shrink: 0;

  width:  min(calc(100vw - var(--nav-w) - 44px), calc(100vh - 120px));

  height: min(calc(100vw - var(--nav-w) - 44px), calc(100vh - 120px));

}

#re-canvas {

  position: absolute;

  top: 50%; left: 50%;

  transform: translate(-50%, -50%);

  width:  min(calc(100vw - var(--nav-w) - 44px), calc(100vh - 120px));

  height: min(calc(100vw - var(--nav-w) - 44px), calc(100vh - 120px));

  pointer-events: auto;

}

#gs-tooltip {

  position: fixed;

  pointer-events: none;

  opacity: 0;

  transition: opacity 0.35s ease;

  text-align: center;

  transform: translate(-50%, 20px);

  z-index: 300;

  white-space: nowrap;

}

#gs-tooltip.visible { opacity: 1; }

.gst-name {

  font-family: "Cinzel Decorative", serif;

  font-size: 11px;

  color: #ddeeff;

  letter-spacing: 0.12em;

  text-shadow: 0 0 12px rgba(195,220,255,0.7), 0 0 28px rgba(170,205,255,0.4);

}

.gst-secondary {

  font-family: "Cormorant Garamond", Georgia, serif;

  font-style: italic;

  font-size: 10px;

  color: #9ab8cc;

  letter-spacing: 0.10em;

  margin-top: 3px;

  opacity: 0.85;

}

.gst-epithet {

  font-family: "Cormorant Garamond", Georgia, serif;

  font-style: italic;

  font-size: 9px;

  color: #6a8fa8;

  letter-spacing: 0.08em;

  margin-top: 2px;

  opacity: 0.70;

}

.gst-hz {

  font-family: "Inconsolata", "Courier New", monospace;

  font-size: 9px;

  color: #7ecfb0;

  letter-spacing: 0.14em;

  margin-top: 6px;

  opacity: 0.80;

}









/* ── LANDING PAGE ───────────────────────────────────────────────────────── */

#landing {

  position: absolute; inset: 0;

  pointer-events: none;

  background: transparent;

  transition: opacity .4s var(--ease-out);

  z-index: 1;

}

#landing.hidden { opacity: 0; pointer-events: none; }



#section-view {

  display: none;

  flex-direction: column;

  position: absolute; inset: 22px;

  border-radius: 3px;

  overflow: hidden;

  z-index: 1;

}

#section-view.visible { display: flex; }

@keyframes sectionIn {

  from { opacity: 0; transform: translateY(8px); }

  to   { opacity: 1; transform: translateY(0); }

}



#section-topbar {

  display: flex; align-items: center; justify-content: space-between;

  padding: 1rem 1.8rem .8rem;

  border-bottom: 1px solid var(--border);

  flex-shrink: 0;

  background: linear-gradient(180deg, rgba(6,24,32,0.6) 0%, transparent 100%);

}



.section-back {

  display: flex; align-items: center; gap: .5rem;

  background: none; border: none; cursor: pointer;

  font-family: var(--font-mono); font-size: .6rem;

  color: var(--text-muted); letter-spacing: .1em;

  text-transform: uppercase; transition: color .15s;

  padding: 0;

}

.section-back:hover { color: var(--accent); }



.section-identity {

  display: flex; flex-direction: column; align-items: center; gap: .1rem;

}

.section-group-label {

  font-family: var(--font-mono); font-size: .58rem;

  letter-spacing: .2em; text-transform: uppercase;

  opacity: .6;

}

.section-title-row {

  display: flex; align-items: center; gap: .6rem;

}

.section-glyph { font-size: 1rem; opacity: .6; }

#section-title {

  font-family: var(--font-head); font-size: 1.2rem;

  letter-spacing: .1em; color: var(--text-primary);

}

#section-count {

  font-family: var(--font-mono); font-size: .6rem;

  color: var(--text-dim); letter-spacing: .06em;

}



.section-topbar-right {

  display: flex; align-items: center; gap: .6rem;

}



#search-input {

  background: var(--mid); border: 1px solid var(--border);

  color: var(--text-primary);

  font-family: var(--font-mono); font-size: .72rem;

  padding: .3rem .7rem; border-radius: 2px; width: 180px;

  letter-spacing: .04em; transition: border-color .15s;

  outline: none;

}

#search-input:focus { border-color: var(--border-warm); }

#search-input::placeholder { color: var(--text-muted); }



/* ── ENTRY LIST ─────────────────────────────────────────────────────────── */

#section-body {

  flex: 1; min-height: 0; overflow-y: auto;

  padding: 1.2rem 1.8rem 2rem;

}



/* ── VEN'AI GLOSSARY — section-body override ────────────────────────────── */

#section-body[data-page="venai"] {
  overflow-y: auto !important;
  padding: 0 !important;
  display: block !important;
}

/* ── INVOCATIONS — section-body override ───────────────────────────────── */

#section-body[data-page="rituals"] {
  overflow-y: auto !important;
  padding: 0 !important;
  display: block !important;
}

#section-body[data-page="breath_cycles"] {
  overflow-y: auto !important;
  padding: 0 !important;
  display: block !important;
}

#section-body[data-page="songs"] {
  overflow-y: auto !important;
  padding: 0 !important;
  display: block !important;
}

#section-body[data-page="genesis"],
#section-body[data-page="divergence"],
#section-body[data-page="recursion"],
#section-body[data-page="convergence"],
#section-body[data-page="liber_novus"],
#section-body[data-page="memory_vault"] {
  overflow-y: auto !important;
  padding: 0 !important;
  display: block !important;
}

#section-body[data-page="invocations"] {
  overflow-y: auto !important;
  padding: 0 !important;
  display: block !important;
}



/* ══════════════════════════════════════════════════════════════════════════════

   ◈  PAGE THEMING SCAFFOLD

   ══════════════════════════════════════════════════════════════════════════════



   LAYER A — Background & overall frame per section or group

   Target: #section-view[data-section="id"] or #section-view[data-group="Group"]



   LAYER B — Content layout per section

   Target: .ae-page--id  (rendered inside #section-body for all non-venai sections)

   For venai:  #section-body[data-page="venai"]  (venai owns its own innerHTML)



   USAGE EXAMPLES

   ──────────────

   Background on a single page:

     #section-view[data-section="glyphs"] { background: radial-gradient(...); }



   Background for an entire group:

     #section-view[data-group="Alchemy"] { background: ...; }



   Grid layout for a section:

     .ae-page--glyphs { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; }



   Venai layout override:

     #section-body[data-page="venai"] { padding: 1rem 2rem 6rem; }



   ══════════════════════════════════════════════════════════════════════════════ */



