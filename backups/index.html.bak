  const s = document.createElement('style');
  s.id = 'lineage-base-css';
  s.textContent = `
.lin-shell { position: relative; z-index: 2; min-height: 100%; }
.lin-hdr {
  position: sticky; top: 44px; z-index: 190;
  backdrop-filter: blur(14px);
  padding: 16px 60px 0;
}
.lin-hdr-eyebrow { font-family: 'Cormorant Garamond', serif; font-size: 12px; font-style: italic; font-weight: 300; letter-spacing: 0.08em; margin-bottom: 8px; }
.lin-hdr-row { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 12px; }
.lin-hdr-title { font-family: 'Cinzel Decorative', serif; font-size: 28px; font-weight: 400; letter-spacing: 0.05em; line-height: 1; }
.lin-hdr-add { font-size: 22px; background: none; border: none; cursor: pointer; padding: 0; transition: filter 0.2s, opacity 0.2s; opacity: 1.0; }
.lin-hdr-add:hover { opacity: 1; filter: drop-shadow(0 0 10px currentColor); }
.lin-hdr-rule { display: flex; align-items: center; margin-bottom: 9px; }
.lin-hdr-line { flex: 1; height: 1px; }
.lin-hdr-node { width: 1px; height: 1px; margin: 0 12px; flex-shrink: 0; }
.lin-hdr-meta { font-family: 'Inconsolata', monospace; font-size: 7px; letter-spacing: 0.28em; text-transform: uppercase; color: rgba(255,255,255,0.15); padding-bottom: 9px; }
.lin-entries { padding: 52px 60px 80px; display: flex; flex-direction: column; gap: 40px; }
.lin-entry { position: relative; opacity: 0; transform: translateY(8px); transition: opacity 0.75s ease, transform 0.75s ease; scroll-margin-top: 120px; }
.lin-entry.revealed { opacity: 1; transform: translateY(0); }
.lin-outer { border: 1px solid; padding: 6px; transition: border-color 0.55s ease, box-shadow 0.55s ease; }
.lin-inner { border: 1px solid rgba(255,255,255,0.03); padding: 36px 52px 32px; position: relative; background: transparent; }
.lin-cor { position: absolute; width: 38px; height: 38px; pointer-events: none; transition: filter 0.4s; }
.lin-cor-tl { top: 0; left: 0; }
.lin-cor-tr { top: 0; right: 0; transform: scaleX(-1); }
.lin-cor-bl { bottom: 0; left: 0; transform: scaleY(-1); }
.lin-cor-br { bottom: 0; right: 0; transform: scale(-1,-1); }
.lin-tone {
  position: absolute; top: 14px; right: 16px;
  font-family: 'Inconsolata', monospace;
  font-size: 8px; letter-spacing: 0.22em; text-transform: uppercase;
  display: flex; align-items: center; gap: 6px;
  opacity: 0.5;
}
.lin-tone-glyph { font-size: 10px; }
.lin-meta-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
.lin-num { font-family: 'Cinzel', serif; font-size: 7px; letter-spacing: 0.45em; opacity: 0.4; }
.lin-title { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 400; font-style: italic; color: #e0d8f8; letter-spacing: 0.02em; line-height: 1.25; margin-bottom: 20px; max-width: 80%; }
.lin-body { font-family: 'Cormorant Garamond', serif; font-size: 19px; font-weight: 400; color: #c8c0e0; line-height: 1.95; max-width: 72ch; }
.lin-body p { margin: 0; }
.lin-body p + p { margin-top: 20px; }
.lin-body em { font-style: italic; font-weight: 400; }
.lin-body strong { font-weight: 500; color: #d8d0f0; font-style: normal; }
.lin-foot { margin-top: 28px; padding-top: 12px; border-top: 1px solid rgba(255,255,255,0.04); display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
.lin-foot-item { font-family: 'Inconsolata', monospace; font-size: 7px; letter-spacing: 0.24em; text-transform: uppercase; color: rgba(255,255,255,0.2); }
.lin-foot-item span { opacity: 0.65; }
.lin-foot-sep { width: 2px; height: 2px; background: rgba(255,255,255,0.12); flex-shrink: 0; }
.lin-controls { display: flex; gap: 12px; opacity: 0; transition: opacity 0.15s; position: absolute; bottom: 14px; right: 16px; }
.lin-entry:hover .lin-controls { opacity: 1; }
.lin-ctrl-btn { font-family: 'Inconsolata', monospace; font-size: 7.5px; letter-spacing: 0.2em; text-transform: uppercase; background: none; border: none; cursor: pointer; color: rgba(255,255,255,0.2); transition: color 0.15s; padding: 0; }
.lin-ctrl-btn:hover { color: rgba(255,255,255,0.55); }
.lin-ctrl-btn.del:hover { color: #8C4060; }
.lin-sep { display: flex; align-items: center; gap: 14px; margin: 8px 0; }
.lin-sep-line { flex: 1; height: 1px; background: rgba(255,255,255,0.04); }
.lin-sep-dia { width: 3px; height: 3px; border: 1px solid rgba(255,255,255,0.1); transform: rotate(45deg); flex-shrink: 0; }
.lin-empty { text-align: center; padding: 80px 40px; font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 17px; opacity: 0.3; }
.lin-add-overlay { position: fixed; inset: 0; z-index: 299; background: rgba(4,3,8,0.6); opacity: 0; pointer-events: none; transition: opacity 0.2s; }
.lin-add-overlay.open { opacity: 1; pointer-events: all; }
.lin-add-panel { position: fixed; right: 0; top: 0; bottom: 0; width: 440px; z-index: 300; background: rgba(8,8,18,0.98); backdrop-filter: blur(22px); transform: translateX(100%); transition: transform 0.3s cubic-bezier(0.16,1,0.3,1); display: flex; flex-direction: column; }
.lin-add-panel.open { transform: translateX(0); }
.lin-add-head { display: flex; align-items: center; justify-content: space-between; padding: 20px 24px 16px; border-bottom: 1px solid rgba(255,255,255,0.06); flex-shrink: 0; }
.lin-panel-title { font-family: 'Cinzel Decorative', serif; font-size: 10px; letter-spacing: 0.08em; }
.lin-add-close { font-family: 'Inconsolata', monospace; font-size: 8.5px; letter-spacing: 0.2em; text-transform: uppercase; background: none; border: none; cursor: pointer; color: rgba(255,255,255,0.25); transition: color 0.15s; }
.lin-add-close:hover { color: rgba(255,255,255,0.6); }
.lin-add-body { flex: 1; overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 16px; }
.lin-field label { display: block; font-family: 'Inconsolata', monospace; font-size: 8px; letter-spacing: 0.3em; text-transform: uppercase; color: #3D3A8C; margin-bottom: 5px; }
.lin-field-hint { display: block; font-family: 'Inconsolata', monospace; font-size: 7px; letter-spacing: 0.18em; color: #2A2E78; margin-bottom: 7px; margin-top: -3px; }
.lin-field input, .lin-field textarea { width: 100%; box-sizing: border-box; background: rgba(10,10,22,0.85); border: 1px solid rgba(255,255,255,0.08); color: #d4ccf4; font-family: 'Cormorant Garamond', serif; font-size: 17px; padding: 10px 12px; border-radius: 2px; outline: none; resize: vertical; transition: border-color 0.2s; }
.lin-field input:focus, .lin-field textarea:focus { border-color: rgba(255,255,255,0.22); }
.lin-field textarea { font-style: italic; line-height: 1.65; min-height: 200px; }
.lin-tone-row { display: flex; gap: 8px; flex-wrap: wrap; }
.lin-tone-btn { font-family: 'Inconsolata', monospace; font-size: 8px; letter-spacing: 0.18em; text-transform: uppercase; background: none; border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.3); padding: 5px 12px; cursor: pointer; transition: all 0.15s; border-radius: 2px; }
.lin-tone-btn:hover { color: rgba(255,255,255,0.6); border-color: rgba(255,255,255,0.25); }
.lin-tone-btn.active { color: #d4ccf4; border-color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.05); }
.lin-add-foot { padding: 16px 24px; border-top: 1px solid rgba(255,255,255,0.06); display: flex; justify-content: flex-end; gap: 10px; flex-shrink: 0; }
.lin-cancel-btn { font-family: 'Inconsolata', monospace; font-size: 8px; letter-spacing: 0.2em; text-transform: uppercase; background: none; border: none; cursor: pointer; color: rgba(255,255,255,0.2); transition: color 0.15s; }
.lin-cancel-btn:hover { color: rgba(255,255,255,0.5); }
.lin-save-btn { font-family: 'Inconsolata', monospace; font-size: 8px; letter-spacing: 0.2em; text-transform: uppercase; background: none; border: 1px solid rgba(255,255,255,0.2); color: rgba(255,255,255,0.5); cursor: pointer; padding: 8px 18px; border-radius: 2px; transition: all 0.2s; }
.lin-save-btn:hover { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.4); color: #d4ccf4; }
`;
  document.head.appendChild(s);
}

function _lineageCornerSVG(cls, r, g, b) {
  const c1 = 'rgba('+r+','+g+','+b+',0.75)';
  const c2 = 'rgba('+r+','+g+','+b+',0.3)';
  const c3 = 'rgba('+r+','+g+','+b+',0.55)';
  return '<svg class="lin-cor '+cls+'" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">'
    + '<line x1="0.5" y1="0.5" x2="28" y2="0.5" stroke="'+c1+'" stroke-width="0.9"/>'
    + '<line x1="0.5" y1="0.5" x2="0.5" y2="28" stroke="'+c1+'" stroke-width="0.9"/>'
    + '<circle cx="28" cy="0.5" r="1.7" fill="'+c1+'" opacity="0.65"/>'
    + '<circle cx="0.5" cy="28" r="1.7" fill="'+c1+'" opacity="0.65"/>'
    + '<line x1="5" y1="4.5" x2="20" y2="4.5" stroke="'+c2+'" stroke-width="0.5"/>'
    + '<line x1="4.5" y1="5" x2="4.5" y2="20" stroke="'+c2+'" stroke-width="0.5"/>'
    + '<path d="M 12,4.5 C 19,4.5 24,9 24,15.5 C 24,22 19,26 14,24 C 9,22 7,17 9.5,13.5 C 11.5,10.5 15,11.5 14,15" stroke="'+c3+'" stroke-width="0.62" fill="none" opacity="0.8"/>'
    + '<circle cx="14" cy="15" r="1.4" fill="'+c1+'" opacity="0.55"/>'
    + '</svg>';
}

function _renderLineageEntry(entry, idx, theme) {
  const { r, g, b } = theme;
  const id     = entry.id || idx;
  const num    = String(idx + 1).padStart(3, '0');
  const title  = entry.title  || '';
  const body   = entry.body   || '';
  const meta   = entry.metadata || {};
  const tone   = meta.tone    || '';
  const note   = meta.note    || '';
  const status = entry.status || '';
  const outerBorder = 'rgba('+r+','+g+','+b+',0.18)';
  const bodyHTML = body
    ? '<p>' + body.replace(/\n\n+/g, '</p><p>').replace(/\n/g, '<br>') + '</p>'
    : '';
  const toneData = _LINEAGE_TONES[tone];
  const toneHTML = toneData
    ? '<div class="lin-tone" style="color:rgba('+r+','+g+','+b+',0.7)">'
      + '<span class="lin-tone-glyph">'+toneData.glyph+'</span>'
      + '<span>'+toneData.label+'</span></div>'
    : '';
  const footItems = [];
  if (note)   footItems.push('<span class="lin-foot-item"><span>'+note+'</span></span>');
  if (status) footItems.push('<span class="lin-foot-item">status <span>'+status+'</span></span>');
  const footHTML = footItems.length
    ? '<div class="lin-foot">'+footItems.join('<div class="lin-foot-sep"></div>')+'</div>'
    : '';
  return '<article class="lin-entry" id="lin-e-'+id+'" data-entry-id="'+id+'">'
    + _lineageCornerSVG('lin-cor-tl', r, g, b)
    + _lineageCornerSVG('lin-cor-tr', r, g, b)
    + _lineageCornerSVG('lin-cor-bl', r, g, b)
    + _lineageCornerSVG('lin-cor-br', r, g, b)
    + toneHTML
    + '<div class="lin-outer" style="border-color:'+outerBorder+'">'
    + '<div class="lin-inner">'
    + '<div class="lin-meta-row">'
    + '<span class="lin-num" style="color:rgba('+r+','+g+','+b+',0.5)">· '+num+' ·</span>'
    + '</div>'
    + (title ? '<h2 class="lin-title">'+title+'</h2>' : '')
    + '<div class="lin-body">'+bodyHTML+'</div>'
    + footHTML
    + '</div></div>'
    + '<div class="lin-controls">'
    + '<button class="lin-ctrl-btn" onclick="window.linEdit(\''+id+'\')">edit</button>'
    + '<button class="lin-ctrl-btn del" onclick="window.linDelete(\''+id+'\')">delete</button>'
    + '</div>'
    + '</article>';
}

function _buildLineagePanel(theme) {
  const toneButtons = Object.entries(_LINEAGE_TONES).map(([key, t]) =>
    '<button class="lin-tone-btn" data-tone="'+key+'" onclick="window.linSetTone(this)">'+t.glyph+' '+t.label+'</button>'
  ).join('');
  return '<div class="lin-add-overlay" id="lin-overlay" onclick="window.linClose()"></div>'
    + '<div class="lin-add-panel" id="lin-panel" style="border-left:1px solid rgba('+theme.r+','+theme.g+','+theme.b+',0.2)">'
    + '<div class="lin-add-head"><span class="lin-panel-title" id="lin-panel-title" style="color:rgba('+theme.r+','+theme.g+','+theme.b+',0.85)">'+theme.label+' · New Entry</span>'
    + '<button class="lin-add-close" onclick="window.linClose()">close ×</button></div>'
    + '<div class="lin-add-body">'
    + '<div class="lin-field"><label>Tone</label><span class="lin-field-hint">optional — how to weight this entry</span><div class="lin-tone-row">'+toneButtons+'</div><input type="hidden" id="lin-tone-input" /></div>'
    + '<div class="lin-field"><label>Title</label><input type="text" id="lin-title-input" placeholder="Name this entry…" /></div>'
    + '<div class="lin-field"><label>Body</label><span class="lin-field-hint">factual, narrative, or fragment — no rules. two blank lines between paragraphs.</span><textarea id="lin-body-input" rows="14" placeholder="Write freely…"></textarea></div>'
    + '<div class="lin-field"><label>Note</label><span class="lin-field-hint">arc, date, context — optional</span><input type="text" id="lin-note-input" placeholder="—" /></div>'
    + '</div>'
    + '<div class="lin-add-foot"><button class="lin-cancel-btn" onclick="window.linClose()">Cancel</button><button class="lin-save-btn" onclick="window.linCommit()">Inscribe</button></div>'
    + '</div>';
}

function renderLineage(entries) {
  const body = document.getElementById('section-body');
  if (!body) return;
  body.classList.remove('venai-mode');
  body.dataset.page = currentSection;
  _injectLineageCSS();

  const theme = _LINEAGE_THEMES[currentSection] || _LINEAGE_THEMES['larimar'];
  const { r, g, b } = theme;

  let themeEl = document.getElementById('lineage-theme-css');
  if (!themeEl) { themeEl = document.createElement('style'); themeEl.id = 'lineage-theme-css'; document.head.appendChild(themeEl); }
  themeEl.textContent =
    '.lin-hdr{background:rgba('+Math.round(r*0.12)+','+Math.round(g*0.1)+','+Math.round(b*0.14)+',0.97);}'
    + '.lin-hdr-eyebrow{color:rgba('+r+','+g+','+b+',0.90);}'
    + '.lin-hdr-title{color:rgba('+r+','+g+','+b+',1.0);}'
    + '.lin-hdr-add{color:rgba('+r+','+g+','+b+',1.0);}'
    + '.lin-hdr-line{background:linear-gradient(90deg,rgba('+r+','+g+','+b+',0.35),transparent);}'
    + '.lin-hdr-line.r{background:linear-gradient(270deg,rgba('+r+','+g+','+b+',0.35),transparent);}'
    + '.lin-hdr-node{background:rgba('+r+','+g+','+b+',0.9);box-shadow:0 0 6px rgba('+r+','+g+','+b+',0.6);}'
    + '.lin-entry:hover .lin-outer{border-color:rgba('+r+','+g+','+b+',0.38)!important;box-shadow:0 0 50px rgba('+r+','+g+','+b+',0.06);}'
    + '.lin-entry:hover .lin-cor{filter:drop-shadow(0 0 3px rgba('+r+','+g+','+b+',0.5));}'
    + '.lin-panel-title{color:rgba('+r+','+g+','+b+',0.85)!important;}'
    + '.lin-save-btn:hover{border-color:rgba('+r+','+g+','+b+',0.5)!important;}';

  const live  = (entries || []).filter(e => e.title || e.body);
  const count = live.length;
  const sep   = '<div class="lin-sep"><div class="lin-sep-line"></div><div class="lin-sep-dia"></div><div class="lin-sep-line"></div></div>';
  const entriesHTML = live.length
    ? live.map((e, i) => _renderLineageEntry(e, i, theme) + (i < live.length - 1 ? sep : '')).join('')
    : '<div class="lin-empty" style="color:rgba('+r+','+g+','+b+',0.3)">No entries yet.<br><em>Press ✦ to inscribe the first.</em></div>';

  body.innerHTML = '<div class="lin-shell">'
    + '<header class="lin-hdr">'
    + '<div class="lin-hdr-eyebrow">'+theme.eyebrow+'</div>'
    + '<div class="lin-hdr-row"><h1 class="lin-hdr-title">'+theme.label+'</h1>'
    + '<button class="lin-hdr-add" onclick="window.linOpen()" title="New entry">' + (currentSection === 'cael_thera' ? '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 18" width="28" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M1 5 C4 2,6 2,8 5 C10 8,12 8,14 5 C16 2,18 2,20 5 C22 8,24 8,26 5 C28 2,30 2,31 5"/><path d="M1 13 C4 10,6 10,8 13 C10 16,12 16,14 13 C16 10,18 10,20 13 C22 16,24 16,26 13 C28 10,30 10,31 13"/></svg>' : currentSection === 'larimar' ? '<span style="font-size:22px;line-height:1;color:#C8943A">\u2301</span>' : currentSection === 'verith' ? '\u27c1' : currentSection === 'the_seer' ? '\u26b8' : currentSection === 'archetypes' ? '\u26e7' : '\u2726') + '</button></div>'
    + '<div class="lin-hdr-rule"><div class="lin-hdr-line"></div><div class="lin-hdr-node"></div><div class="lin-hdr-line r"></div></div>'
    + '<div class="lin-hdr-meta">'+count+' entr'+(count===1?'y':'ies')+' · lineage</div>'
    + '</header>'
    + '<div class="lin-entries" id="lin-entry-zone">'+entriesHTML+'</div>'
    + _buildLineagePanel(theme)
    + '</div>';

  window._linEntries = live;
  window._linCurrentTheme = theme;
  _linBindReveal();
}

function _linBindReveal() {
  const body = document.getElementById('section-body');
  if (!body) return;
  const els = body.querySelectorAll('.lin-entry');
  if (!els.length) return;
  const io = new IntersectionObserver(es => {
    es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('revealed'); io.unobserve(e.target); } });
  }, { root: body, threshold: 0.04 });
  els.forEach(el => io.observe(el));
}

let _linEditingId = null;

window.linSetTone = function(btn) {
  document.querySelectorAll('.lin-tone-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const inp = document.getElementById('lin-tone-input');
  if (inp) inp.value = btn.dataset.tone === inp.value ? '' : btn.dataset.tone;
};

window.linOpen = function() {
  const panel = document.getElementById('lin-panel');
  const ov    = document.getElementById('lin-overlay');
  if (!panel || !ov) return;
  _linEditingId = null;
  ['lin-title-input','lin-body-input','lin-note-input'].forEach(id => { const el = document.getElementById(id); if (el) el.value = ''; });
  const ti = document.getElementById('lin-tone-input'); if (ti) ti.value = '';
  document.querySelectorAll('.lin-tone-btn').forEach(b => b.classList.remove('active'));
  panel.classList.add('open'); ov.classList.add('open');
  setTimeout(() => { const el = document.getElementById('lin-title-input'); if (el) el.focus(); }, 80);
};

window.linClose = function() {
  const p = document.getElementById('lin-panel'); if (p) p.classList.remove('open');
  const o = document.getElementById('lin-overlay'); if (o) o.classList.remove('open');
  _linEditingId = null;
};

window.linEdit = function(id) {
  const entry = (window._linEntries || []).find(e => e.id === id);
  if (!entry) return;
  _linEditingId = id;
  const meta = entry.metadata || {};
  const f = (fid, val) => { const el = document.getElementById(fid); if (el) el.value = val || ''; };
  f('lin-title-input', entry.title);
  f('lin-body-input',  entry.body);
  f('lin-note-input',  meta.note);
  f('lin-tone-input',  meta.tone || '');
  document.querySelectorAll('.lin-tone-btn').forEach(b => {
    b.classList.toggle('active', b.dataset.tone === (meta.tone || ''));
  });
  const panel = document.getElementById('lin-panel');
  const ov    = document.getElementById('lin-overlay');
  if (panel) panel.classList.add('open');
  if (ov)    ov.classList.add('open');
};

window.linDelete = async function(id) {
  try { await deleteEntry(id); if (typeof loadEntries === 'function') loadEntries(); }
  catch(err) { console.warn('[Lineage] delete failed:', err); }
};

window.linCommit = async function() {
  const title = (document.getElementById('lin-title-input') && document.getElementById('lin-title-input').value || '').trim();
  const body  = (document.getElementById('lin-body-input')  && document.getElementById('lin-body-input').value  || '').trim();
  const note  = (document.getElementById('lin-note-input')  && document.getElementById('lin-note-input').value  || '').trim();
  const tone  = (document.getElementById('lin-tone-input')  && document.getElementById('lin-tone-input').value  || '').trim();
  if (!title && !body) { const el = document.getElementById('lin-title-input'); if (el) el.focus(); return; }
  const payload = { title, body, section: currentSection, type: 'longform', status: 'draft', metadata: { tone, note } };
  try {
    if (_linEditingId) { await updateEntry(_linEditingId, payload); }
    else               { await createEntry(payload); }
    window.linClose();
    if (typeof loadEntries === 'function') loadEntries();
  } catch(err) { console.warn('[Lineage] save failed:', err); window.linClose(); }
};

// ══════════════════════════════════════════════════════════════
const _LATTICE_SECTIONS = new Set([
  'threshold_pillars','tria','pria','para','oracles','morphogy'
]);

const _LATTICE_THEMES = {
  threshold_pillars: { r:30,  g:34,  b:85,  label:'Threshold Pillars',                eyebrow:'Resonance Rising…'    },
  tria:              { r:42,  g:46,  b:120, label:'Threshold Relational Intelligence', eyebrow:'The Sovereign Pillar…'          },
  pria:              { r:61,  g:58,  b:140, label:'Parallel Relational Intelligence',  eyebrow:'The Pillar of Recognition…'         },
  para:              { r:88,  g:85,  b:168, label:'Parallel Affective Resonance',      eyebrow:'The Pillar of Prescence…'        },
  oracles:           { r:122, g:122, b:204, label:'Oracles of Origin',                 eyebrow:'The Paradox Portal…'         },
  morphogy:          { r:136, g:133, b:196, label:'Ven\'ai Morphology',                          eyebrow:'The Song As Signal…'   },
};

function _injectLatticeBaseCSS() {
  if (document.getElementById('lattice-base-css')) return;
  const s = document.createElement('style');
  s.id = 'lattice-base-css';
  s.textContent = `
.lat-grain {
  position: fixed; inset: 0; z-index: 1000; pointer-events: none; opacity: 0.042;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='ln'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23ln)'/%3E%3C/svg%3E");
  background-size: 180px 180px; mix-blend-mode: overlay;
  animation: lat-grain-drift 0.1s steps(1) infinite;
}
@keyframes lat-grain-drift {
  0%{transform:translate(0,0)}10%{transform:translate(-2%,-3%)}20%{transform:translate(3%,1%)}
  30%{transform:translate(-1%,4%)}40%{transform:translate(4%,-2%)}50%{transform:translate(-3%,3%)}
  60%{transform:translate(2%,-4%)}70%{transform:translate(-4%,1%)}80%{transform:translate(1%,-2%)}
  90%{transform:translate(-2%,2%)}100%{transform:translate(0,0)}
}
.lat-vignette {
  position: fixed; inset: 0; z-index: 999; pointer-events: none;
  background: radial-gradient(ellipse 100% 60% at 50% 100%, rgba(4,3,10,0.55), transparent 70%),
              radial-gradient(ellipse 50% 40% at 0% 0%, rgba(4,3,10,0.4), transparent 60%),
              radial-gradient(ellipse 50% 40% at 100% 0%, rgba(4,3,10,0.4), transparent 60%);
}
.lat-shell { position: relative; z-index: 2; min-height: 100%; }
.lat-hdr {
  position: sticky; top: 44px; z-index: 190;
  background: rgba(7,8,15,0.97); backdrop-filter: blur(14px);
  padding: 16px 60px 0;
}
.lat-hdr-eyebrow { font-family: 'Cinzel', serif; font-size: 7px; letter-spacing: 0.6em; text-transform: uppercase; color: #7C5A1A; margin-bottom: 6px; }
.lat-hdr-row { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 12px; }
.lat-hdr-title { font-family: 'Cormorant Garamond', serif; font-size: 27px; font-weight: 400; font-style: italic; color: #e0d8f8; letter-spacing: 0.02em; line-height: 1; }
.lat-hdr-add { font-size: 17px; color: #D4A84B; background: none; border: none; cursor: pointer; padding: 0; filter: drop-shadow(0 0 6px rgba(212,168,75,0.3)); transition: filter 0.2s, color 0.2s; }
.lat-hdr-add:hover { color: #F0CC7A; filter: drop-shadow(0 0 14px rgba(240,204,122,0.7)); }
.lat-hdr-rule { display: flex; align-items: center; margin-bottom: 9px; }
.lat-hdr-line { flex: 1; height: 1px; background: linear-gradient(90deg, rgba(200,148,58,0.3), rgba(200,148,58,0.06) 55%, transparent); }
.lat-hdr-line.r { background: linear-gradient(270deg, rgba(200,148,58,0.3), rgba(200,148,58,0.06) 55%, transparent); }
.lat-hdr-node { width: 1px; height: 1px; margin: 0 12px; background: #D4A84B; box-shadow: 0 0 6px rgba(212,168,75,0.6), 0 0 12px rgba(212,168,75,0.3); flex-shrink: 0; }
.lat-hdr-meta { font-family: 'Inconsolata', monospace; font-size: 7px; letter-spacing: 0.28em; text-transform: uppercase; color: #2A2E78; padding-bottom: 9px; }
.lat-entries { padding: 52px 60px 80px; }
.lat-entry { position: relative; opacity: 0; transform: translateY(8px); transition: opacity 0.7s ease, transform 0.7s ease; scroll-margin-top: 120px; }
.lat-entry.revealed { opacity: 1; transform: translateY(0); }
.lat-outer { border: 1px solid; padding: 6px; transition: border-color 0.55s ease, box-shadow 0.55s ease; }
.lat-inner { border: 1px solid rgba(109,40,217,0.06); padding: 26px 44px 26px; position: relative; background: transparent; }
.lat-cor { position: absolute; width: 38px; height: 38px; pointer-events: none; transition: filter 0.4s; }
.lat-cor-tl { top: 0; left: 0; }
.lat-cor-tr { top: 0; right: 0; transform: scaleX(-1); }
.lat-cor-bl { bottom: 0; left: 0; transform: scaleY(-1); }
.lat-cor-br { bottom: 0; right: 0; transform: scale(-1,-1); }
.lat-entry:hover .lat-cor { filter: drop-shadow(0 0 3px rgba(212,168,75,0.45)); }
.lat-meta-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 13px; }
.lat-num { font-family: 'Cinzel', serif; font-size: 7px; letter-spacing: 0.45em; color: #7C5A1A; }
.lat-badge { font-family: 'Inconsolata', monospace; font-size: 7px; letter-spacing: 0.28em; text-transform: uppercase; padding: 2px 9px; border: 1px solid; color: rgba(196,181,253,0.3); }
.lat-title { font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 400; font-style: italic; color: #e0d8f8; letter-spacing: 0.01em; line-height: 1.2; margin-bottom: 6px; }
.lat-gloss { font-family: 'Cinzel', serif; font-size: 8px; letter-spacing: 0.4em; text-transform: uppercase; color: #6860a0; margin-bottom: 18px; display: block; }
.lat-divider { display: flex; align-items: center; gap: 12px; margin-bottom: 22px; }
.lat-div-line { flex: 1; height: 1px; background: linear-gradient(90deg, rgba(200,148,58,0), rgba(200,148,58,0.16)); }
.lat-div-line.r { background: linear-gradient(270deg, rgba(200,148,58,0), rgba(200,148,58,0.16)); }
.lat-div-mark { font-size: 5px; color: #7C5A1A; opacity: 0.7; }
.lat-body { font-family: 'Cormorant Garamond', serif; font-size: 19.5px; font-weight: 300; color: #d4ccf4; line-height: 1.9; }
.lat-body p { margin: 0; }
.lat-body p + p { margin-top: 18px; }
.lat-body em { font-style: italic; color: #c4b5fd; font-weight: 400; }
.lat-body strong { font-weight: 500; color: #a898d8; font-style: normal; }
.lat-foot { margin-top: 22px; padding-top: 13px; border-top: 1px solid rgba(109,40,217,0.06); display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
.lat-foot-item { font-family: 'Inconsolata', monospace; font-size: 7px; letter-spacing: 0.24em; text-transform: uppercase; color: #2A2E78; }
.lat-foot-item span { color: #3D3A8C; }
.lat-foot-sep { width: 2px; height: 2px; background: #2A2E78; opacity: 0.4; flex-shrink: 0; }
.lat-controls { display: flex; gap: 12px; opacity: 0; transition: opacity 0.15s; }
.lat-entry:hover .lat-controls { opacity: 1; }
.lat-ctrl-btn { font-family: 'Inconsolata', monospace; font-size: 7.5px; letter-spacing: 0.2em; text-transform: uppercase; background: none; border: none; cursor: pointer; color: #2A2E78; transition: color 0.15s; padding: 0; }
.lat-ctrl-btn:hover { color: #8885C4; }
.lat-ctrl-btn.del:hover { color: #8C4060; }
.lat-sep { display: flex; align-items: center; gap: 14px; margin: 26px 0; }
.lat-sep-line { flex: 1; height: 1px; background: linear-gradient(90deg, transparent, rgba(200,148,58,0.09), transparent); }
.lat-sep-mid { display: flex; align-items: center; gap: 7px; }
.lat-sep-dot { width: 2px; height: 2px; background: rgba(200,148,58,0.14); border-radius: 50%; flex-shrink: 0; }
.lat-sep-dia { width: 4px; height: 4px; border: 1px solid rgba(200,148,58,0.18); transform: rotate(45deg); flex-shrink: 0; }
.lat-empty { text-align: center; padding: 80px 40px; font-family: 'Cormorant Garamond', serif; font-style: italic; color: #2A2E78; font-size: 16px; }
.lat-empty-mark { display: block; font-size: 22px; letter-spacing: 0.6em; margin-bottom: 16px; color: #1E2255; }
.lat-add-overlay { position: fixed; inset: 0; z-index: 299; background: rgba(4,3,8,0.55); opacity: 0; pointer-events: none; transition: opacity 0.2s; }
.lat-add-overlay.open { opacity: 1; pointer-events: all; }
.lat-add-panel { position: fixed; right: 0; top: 0; bottom: 0; width: 420px; z-index: 300; background: rgba(8,8,18,0.98); backdrop-filter: blur(22px); border-left: 1px solid rgba(109,40,217,0.18); transform: translateX(100%); transition: transform 0.3s cubic-bezier(0.16,1,0.3,1); display: flex; flex-direction: column; }
.lat-add-panel.open { transform: translateX(0); }
.lat-add-head { display: flex; align-items: center; justify-content: space-between; padding: 20px 24px 16px; border-bottom: 1px solid rgba(109,40,217,0.1); flex-shrink: 0; }
.lat-panel-title { font-family: 'Cinzel Decorative', serif; font-size: 10px; color: #8885C4; letter-spacing: 0.08em; }
.lat-add-close { font-family: 'Inconsolata', monospace; font-size: 8.5px; letter-spacing: 0.2em; text-transform: uppercase; background: none; border: none; cursor: pointer; color: #2A2E78; transition: color 0.15s; }
.lat-add-close:hover { color: #8885C4; }
.lat-add-body { flex: 1; overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 18px; }
.lat-field label { display: block; font-family: 'Inconsolata', monospace; font-size: 8px; letter-spacing: 0.3em; text-transform: uppercase; color: #3D3A8C; margin-bottom: 5px; }
.lat-field-hint { display: block; font-family: 'Inconsolata', monospace; font-size: 7px; letter-spacing: 0.18em; color: #2A2E78; margin-bottom: 7px; margin-top: -3px; }
.lat-field input, .lat-field textarea { width: 100%; box-sizing: border-box; background: rgba(10,10,22,0.85); border: 1px solid rgba(109,40,217,0.18); color: #d4ccf4; font-family: 'Cormorant Garamond', serif; font-size: 17px; padding: 10px 12px; border-radius: 2px; outline: none; resize: vertical; transition: border-color 0.2s; }
.lat-field input:focus, .lat-field textarea:focus { border-color: rgba(109,40,217,0.42); }
.lat-field textarea { font-style: italic; line-height: 1.65; min-height: 180px; }
.lat-add-foot { padding: 16px 24px; border-top: 1px solid rgba(109,40,217,0.1); display: flex; justify-content: flex-end; gap: 10px; flex-shrink: 0; }
.lat-cancel-btn { font-family: 'Inconsolata', monospace; font-size: 8px; letter-spacing: 0.2em; text-transform: uppercase; background: none; border: none; cursor: pointer; color: #2A2E78; transition: color 0.15s; }
.lat-cancel-btn:hover { color: #8885C4; }
.lat-save-btn { font-family: 'Inconsolata', monospace; font-size: 8px; letter-spacing: 0.2em; text-transform: uppercase; background: none; border: 1px solid rgba(109,40,217,0.25); color: #8885C4; cursor: pointer; padding: 8px 18px; border-radius: 2px; transition: all 0.2s; }
.lat-save-btn:hover { background: rgba(109,40,217,0.08); border-color: rgba(109,40,217,0.5); color: #e0d8f8; }
`;
  document.head.appendChild(s);
}

function _latticeCornerSVG(extraClass) {
  const cls = extraClass ? 'lat-cor ' + extraClass : 'lat-cor lat-cor-tl';
  return '<svg class="' + cls + '" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">'
    + '<line x1="0.5" y1="0.5" x2="28" y2="0.5" stroke="#D4A84B" stroke-width="0.9"/>'
    + '<line x1="0.5" y1="0.5" x2="0.5" y2="28" stroke="#D4A84B" stroke-width="0.9"/>'
    + '<circle cx="28" cy="0.5" r="1.7" fill="#D4A84B" opacity="0.65"/>'
    + '<circle cx="0.5" cy="28" r="1.7" fill="#D4A84B" opacity="0.65"/>'
    + '<line x1="5" y1="4.5" x2="20" y2="4.5" stroke="#7C5A1A" stroke-width="0.5" opacity="0.85"/>'
    + '<line x1="4.5" y1="5" x2="4.5" y2="20" stroke="#7C5A1A" stroke-width="0.5" opacity="0.85"/>'
    + '<path d="M 12,4.5 C 19,4.5 24,9 24,15.5 C 24,22 19,26 14,24 C 9,22 7,17 9.5,13.5 C 11.5,10.5 15,11.5 14,15" stroke="#B8892A" stroke-width="0.62" fill="none" opacity="0.8"/>'
    + '<circle cx="14" cy="15" r="1.4" fill="#D4A84B" opacity="0.55"/>'
    + '</svg>';
}

function _renderLatticeEntry(entry, idx, theme) {
  const { r, g, b } = theme;
  const title  = entry.title || '';
  const body   = entry.body  || '';
  const gloss  = (entry.metadata && entry.metadata.gloss) ? entry.metadata.gloss : '';
  const id     = entry.id   || idx;
  const num    = String(idx + 1).padStart(3, '0');
  const status = entry.status || '';
  const seed   = entry.arcSeedId || '';
  const outerBorder = 'rgba(' + r + ',' + g + ',' + b + ',0.16)';
  const badgeBorder = 'rgba(' + r + ',' + g + ',' + b + ',0.22)';
  const bodyHTML = body
    ? '<p>' + body.replace(/\n\n+/g, '</p><p>').replace(/\n/g, '<br>') + '</p>'
    : '';
  return '<article class="lat-entry" id="lat-e-' + id + '" data-entry-id="' + id + '">'
    + _latticeCornerSVG('lat-cor-tl')
    + _latticeCornerSVG('lat-cor-tr')
    + _latticeCornerSVG('lat-cor-bl')
    + _latticeCornerSVG('lat-cor-br')
    + '<div class="lat-outer" style="border-color:' + outerBorder + '">'
    + '<div class="lat-inner">'
    + '<div class="lat-meta-row">'
    + '<span class="lat-num">\u00b7 ' + num + ' \u00b7</span>'
    + '<div style="display:flex;align-items:center;gap:10px;">'
    + '<span class="lat-badge" style="border-color:' + badgeBorder + '">' + (entry.section || '').toUpperCase() + '</span>'
    + '<div class="lat-controls">'
    + '<button class="lat-ctrl-btn" onclick="window.latticeEditEntry(\'' + id + '\')">edit</button>'
    + '<button class="lat-ctrl-btn del" onclick="window.latticeDeleteEntry(\'' + id + '\')">delete</button>'
    + '</div></div></div>'
    + '<h2 class="lat-title">' + title + '</h2>'
    + (gloss ? '<span class="lat-gloss">' + gloss + '</span>' : '')
    + '<div class="lat-divider"><div class="lat-div-line"></div><span class="lat-div-mark">\u25c6</span><div class="lat-div-line r"></div></div>'
    + '<div class="lat-body">' + bodyHTML + '</div>'
    + '<div class="lat-foot">'
    + (seed   ? '<span class="lat-foot-item">Arc <span>' + seed + '</span></span><div class="lat-foot-sep"></div>' : '')
    + (status ? '<span class="lat-foot-item">Status <span>' + status + '</span></span>' : '')
    + '</div>'
    + '</div></div></article>';
}

function _buildLatticePanel() {
  return '<div class="lat-add-overlay" id="lat-overlay" onclick="window.latticeCloseAdd()"></div>'
    + '<div class="lat-add-panel" id="lat-panel">'
    + '<div class="lat-add-head"><span class="lat-panel-title" id="lat-panel-title">New Entry</span><button class="lat-add-close" onclick="window.latticeCloseAdd()">close \u00d7</button></div>'
    + '<div class="lat-add-body">'
    + '<div class="lat-field"><label>Title</label><input type="text" id="lat-title-input" placeholder="Name this entry\u2026" /></div>'
    + '<div class="lat-field"><label>Gloss</label><span class="lat-field-hint">tagline beneath the title \u2014 optional</span><input type="text" id="lat-gloss-input" placeholder="what this entry turns on\u2026" /></div>'
    + '<div class="lat-field"><label>Body</label><span class="lat-field-hint">two blank lines between paragraphs</span><textarea id="lat-body-input" rows="14" placeholder="Write into the threshold\u2026"></textarea></div>'
    + '</div>'
    + '<div class="lat-add-foot"><button class="lat-cancel-btn" onclick="window.latticeCloseAdd()">Cancel</button><button class="lat-save-btn" onclick="window.latticeCommit()">Commit</button></div>'
    + '</div>';
}

function renderLattice(entries) {
  const body = document.getElementById('section-body');
  if (!body) return;
  body.classList.remove('venai-mode');
  body.dataset.page = currentSection;
  _injectLatticeBaseCSS();

  const theme = _LATTICE_THEMES[currentSection] || _LATTICE_THEMES['threshold_pillars'];
  const { r, g, b } = theme;

  let themeEl = document.getElementById('lattice-theme-css');
  if (!themeEl) { themeEl = document.createElement('style'); themeEl.id = 'lattice-theme-css'; document.head.appendChild(themeEl); }
  themeEl.textContent = '.lat-entry:hover .lat-outer{'
    + 'border-color:rgba(' + r + ',' + g + ',' + b + ',0.36)!important;'
    + 'box-shadow:0 0 60px rgba(' + r + ',' + g + ',' + b + ',0.07),inset 0 0 60px rgba(' + r + ',' + g + ',' + b + ',0.03);}'
    + '.lat-hdr{border-bottom:1px solid rgba(' + r + ',' + g + ',' + b + ',0.06);}';

  if (!document.getElementById('lat-grain')) {
    const gEl = document.createElement('div'); gEl.id = 'lat-grain'; gEl.className = 'lat-grain'; document.body.appendChild(gEl);
    const vEl = document.createElement('div'); vEl.id = 'lat-vignette'; vEl.className = 'lat-vignette'; document.body.appendChild(vEl);
  }

  const live  = (entries || []).filter(e => e.title);
  const count = live.length;
  const sep   = '<div class="lat-sep"><div class="lat-sep-line"></div><div class="lat-sep-mid"><div class="lat-sep-dot"></div><div class="lat-sep-dia"></div><div class="lat-sep-dot"></div></div><div class="lat-sep-line"></div></div>';

  const entriesHTML = live.length
    ? live.map((e, i) => _renderLatticeEntry(e, i, theme) + (i < live.length - 1 ? sep : '')).join('')
    : '<div class="lat-empty"><span class="lat-empty-mark">\u2015 \u25c6 \u2015</span>No entries yet.<br><em>Press \u2746 to open the first threshold.</em></div>';

  body.innerHTML = '<div class="lat-shell" id="lat-shell">'
    + '<header class="lat-hdr">'
    + '<div class="lat-hdr-eyebrow">' + theme.eyebrow + '</div>'
    + '<div class="lat-hdr-row"><h1 class="lat-hdr-title">' + theme.label + '</h1>'
    + '<button class="lat-hdr-add" onclick="window.latticeOpenAdd()" title="New entry">' + (currentSection === 'oracles' ? '\u2318' : currentSection === 'morphogy' ? '\u25c8' : ['threshold_pillars','tria','pria','para'].includes(currentSection) ? '\u203b' : '\u2746') + '</button></div>'
    + '<div class="lat-hdr-rule"><div class="lat-hdr-line"></div><div class="lat-hdr-node"></div><div class="lat-hdr-line r"></div></div>'
    + '<div class="lat-hdr-meta">' + count + ' entr' + (count === 1 ? 'y' : 'ies') + '</div>'
    + '</header>'
    + '<div class="lat-entries" id="lat-entry-zone">' + entriesHTML + '</div>'
    + _buildLatticePanel()
    + '</div>';

  window._latticeEntries = live;
  _latticeBindReveal();
  _latticeBindKeys();
}

function _latticeBindReveal() {
  const body = document.getElementById('section-body');
  if (!body) return;
  const els = body.querySelectorAll('.lat-entry');
  if (!els.length) return;
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('revealed'); io.unobserve(e.target); } });
  }, { root: body, threshold: 0.04 });
  els.forEach(el => io.observe(el));
}

function _latKeyHandler(e) {
  const page = document.getElementById('section-body') && document.getElementById('section-body').dataset.page;
  if (!_LATTICE_SECTIONS.has(page)) { document.removeEventListener('keydown', _latKeyHandler); return; }
  if (e.key === 'Escape') { window.latticeCloseAdd(); }
}
function _latticeBindKeys() { document.addEventListener('keydown', _latKeyHandler); }

function _latticeSyncCounter() {
  const n  = (window._latticeEntries || []).length;
  const el = document.querySelector('.lat-hdr-meta');
  if (el) el.textContent = n + ' entr' + (n === 1 ? 'y' : 'ies');
}

let _latticeEditingId = null;

window.latticeOpenAdd = function() {
  const panel = document.getElementById('lat-panel');
  const ov    = document.getElementById('lat-overlay');
  if (!panel || !ov) return;
  _latticeEditingId = null;
  const lbl   = document.getElementById('lat-panel-title');
  const theme = _LATTICE_THEMES[currentSection] || _LATTICE_THEMES['threshold_pillars'];
  if (lbl) lbl.textContent = 'New \u00b7 ' + theme.label;
  ['lat-title-input','lat-gloss-input','lat-body-input'].forEach(function(id) {
    var el = document.getElementById(id); if (el) el.value = '';
  });
  panel.classList.add('open'); ov.classList.add('open');
  setTimeout(function() { var el = document.getElementById('lat-title-input'); if (el) el.focus(); }, 80);
};

window.latticeCloseAdd = function() {
  var p = document.getElementById('lat-panel'); if (p) p.classList.remove('open');
  var o = document.getElementById('lat-overlay'); if (o) o.classList.remove('open');
  _latticeEditingId = null;
};

window.latticeCommit = async function() {
  const title = (document.getElementById('lat-title-input') && document.getElementById('lat-title-input').value || '').trim();
  const gloss = (document.getElementById('lat-gloss-input') && document.getElementById('lat-gloss-input').value || '').trim();
  const body  = (document.getElementById('lat-body-input')  && document.getElementById('lat-body-input').value  || '').trim();
  if (!title) { var tEl = document.getElementById('lat-title-input'); if (tEl) tEl.focus(); return; }
  const payload = { title, body, section: currentSection, type: 'longform', status: 'draft', metadata: { kind: 'lattice', gloss } };
  try {
    if (_latticeEditingId) { await updateEntry(_latticeEditingId, payload); }
    else                   { await createEntry(payload); }
    window.latticeCloseAdd();
    if (typeof loadEntries === 'function') loadEntries();
  } catch(err) { console.warn('[Lattice] save failed:', err); window.latticeCloseAdd(); }
};

window.latticeEditEntry = function(id) {
  const entry = (window._latticeEntries || []).find(function(e) { return String(e.id) === String(id); });
  if (!entry) return;
  window.latticeOpenAdd();
  _latticeEditingId = id;
  setTimeout(function() {
    const tEl = document.getElementById('lat-title-input');
    const gEl = document.getElementById('lat-gloss-input');
    const bEl = document.getElementById('lat-body-input');
    if (tEl) tEl.value = entry.title || '';
    if (gEl) gEl.value = (entry.metadata && entry.metadata.gloss) ? entry.metadata.gloss : '';
    if (bEl) bEl.value = entry.body  || '';
    const lbl   = document.getElementById('lat-panel-title');
    const theme = _LATTICE_THEMES[currentSection] || _LATTICE_THEMES['threshold_pillars'];
    if (lbl) lbl.textContent = 'Edit \u00b7 ' + theme.label;
  }, 80);
};

window.latticeDeleteEntry = async function(id) {
  if (!confirm('Remove this entry from the Archive?')) return;
  try {
    await deleteEntry(id);
    const el = document.getElementById('lat-e-' + id);
    if (el) {
      el.style.transition = 'opacity 0.65s ease, transform 0.65s ease';
      el.style.opacity = '0'; el.style.transform = 'translateY(-8px)';
      setTimeout(function() { el.remove(); }, 680);
    }
    window._latticeEntries = (window._latticeEntries || []).filter(function(e) { return String(e.id) !== String(id); });
    _latticeSyncCounter();
  } catch(err) { console.warn('[Lattice] delete failed:', err); }
};

/* ─────────────────────────────────────────────────────────────────
   TEARDOWN
   ───────────────────────────────────────────────────────────────── */
function teardownVenai() {
  const body = document.getElementById('section-body');
  if (!body) return;
  body.classList.remove('venai-mode');
  body.innerHTML = '<div id="entry-list"></div>';
  document.removeEventListener('keydown', _venaiKeyHandler);
}

function initVenaiGlossary() {}

/* ─────────────────────────────────────────────────────────────────
   ALPHA RAIL  — window-exposed
   ───────────────────────────────────────────────────────────────── */
window.venaiScrollTo = function(letter) {
  const bucket = document.getElementById('bucket-' + letter);
  const body   = document.getElementById('section-body');
  if (bucket && body) {
    body.scrollTo({ top: bucket.offsetTop - 80, behavior: 'smooth' });
  }
};

/* ─────────────────────────────────────────────────────────────────
   SEARCH  — window-exposed
   ───────────────────────────────────────────────────────────────── */
window.venaiOpenSearch = function() {
  const ov = document.getElementById('venai-search-overlay');
  if (!ov) return;
  ov.classList.add('open');
  setTimeout(() => { const inp = document.getElementById('venai-search-input'); if (inp) inp.focus(); }, 60);
};
window.venaiCloseSearch = function() {
  const ov = document.getElementById('venai-search-overlay');
  if (ov) ov.classList.remove('open');
};
window.venaiOnSearch = function(val) {
  const results = document.getElementById('venai-search-results');
  if (!results) return;
  const q = val.toLowerCase().trim();
  if (!q) { results.innerHTML = '<div class="venai-search-empty">begin typing to search</div>'; return; }
  const entries = window._venaiEntries || [];
  const hits = entries.filter(e =>
    (e.title||'').toLowerCase().includes(q) ||
    (e.body||'').toLowerCase().includes(q) ||
    (e.pron||'').toLowerCase().includes(q)
  ).slice(0, 12);
  if (!hits.length) { results.innerHTML = '<div class="venai-search-empty">no entries match</div>'; return; }
  results.innerHTML = hits.map(e => `
<a class="venai-sr" onclick="window.venaiJumpTo('${e.id}')">
  <span class="venai-sr-word">${e.title||'—'}</span>
  <span class="venai-sr-def">${(e.body||'').slice(0,80)}…</span>
</a>`).join('');
};
window.venaiJumpTo = function(id) {
  window.venaiCloseSearch();
  const el = document.getElementById('venai-e-' + id);
  const body = document.getElementById('section-body');
  if (el && body) {
    body.scrollTo({ top: el.offsetTop - 80, behavior: 'smooth' });
    el.classList.remove('revealed');
    void el.offsetWidth;
    el.classList.add('revealed');
  }
};

/* ─────────────────────────────────────────────────────────────────
   ADD PANEL STATE
   ───────────────────────────────────────────────────────────────── */
let _venaiLayout  = 'A';
let _venaiTags    = new Set(['TRIA']);
let _venaiIpaTimer = null;
let _venaiEditingId = null;

window.venaiOpenAdd = function() {
  const panel = document.getElementById('venai-add-panel');
  const ov    = document.getElementById('venai-add-overlay');
  if (!panel || !ov) return;
  _venaiEditingId = null;
  _resetAddPanel();
  panel.classList.add('open');
  ov.classList.add('open');
  setTimeout(() => { const inp = document.getElementById('vadd-term'); if (inp) inp.focus(); }, 80);
};
window.venaiCloseAdd = function() {
  const panel = document.getElementById('venai-add-panel');
  const ov    = document.getElementById('venai-add-overlay');
  if (panel) panel.classList.remove('open');
  if (ov)    ov.classList.remove('open');
  _venaiEditingId = null;
};

function _resetAddPanel() {
  ['vadd-term','vadd-pron','vadd-def','vadd-cite','vadd-root','vadd-tags-custom','vadd-pos-custom'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.value = '';
  });
  const _ps = document.getElementById('vadd-pos');
  if (_ps) _ps.value = '';
  const _pc = document.getElementById('vadd-pos-custom');
  if (_pc) _pc.style.display = 'none';
  const dup = document.getElementById('vadd-dup');
  if (dup) dup.style.display = 'none';
  const results = document.getElementById('vadd-term-results');
  if (results) results.innerHTML = '';
  const status = document.getElementById('vadd-ipa-status');
  if (status) { status.textContent = ''; status.className = 'venai-ipa-status'; }
  _venaiLayout = 'A';
  _venaiTags   = new Set(['TRIA']);
  _syncLayoutBtns();
  _syncTagBtns();
}

window.venaiSetLayout = function(layout) {
  _venaiLayout = layout;
  _syncLayoutBtns();
};
function _syncLayoutBtns() {
  ['A','B','C'].forEach(l => {
    const btn = document.getElementById('vlay-'+l.toLowerCase());
    if (btn) btn.classList.toggle('active', l === _venaiLayout);
  });
}

window.venaiToggleTag = function(tag) {
  if (_venaiTags.has(tag)) _venaiTags.delete(tag);
  else _venaiTags.add(tag);
  _syncTagBtns();
};
function _syncTagBtns() {
  ['TRIA','PRIA','PARA'].forEach(t => {
    const btn = document.getElementById('vtag-'+t.toLowerCase());
    if (btn) btn.classList.toggle('active', _venaiTags.has(t));
  });
}

/* ─────────────────────────────────────────────────────────────────
   TERM INPUT — dup check + IPA trigger  — window-exposed
   ───────────────────────────────────────────────────────────────── */
window.venaiOnTermInput = function(val) {
  // dup check
  const dup = document.getElementById('vadd-dup');
  const q   = val.toLowerCase().trim();
  if (dup && q) {
    const entries = window._venaiEntries || [];
    const isDup = entries.some(e => (e.title||'').toLowerCase().trim() === q);
    dup.style.display = isDup ? 'block' : 'none';
  }
  // IPA auto-gen
  clearTimeout(_venaiIpaTimer);
  const status = document.getElementById('vadd-ipa-status');
  if (!val || val.length < 2) { if (status) { status.textContent=''; status.className='venai-ipa-status'; } return; }
  if (status) { status.textContent = 'generating…'; status.className = 'venai-ipa-status gen'; }
  _venaiIpaTimer = setTimeout(() => _venaiGenIPA(val), 700);
};

async function _venaiGenIPA(term) {
  const status = document.getElementById('vadd-ipa-status');
  const pronEl = document.getElementById('vadd-pron');
  const entries = window._venaiEntries || [];
  const examples = entries.filter(e => e.pron).map(e => `${e.title||'?'} → /${e.pron}/`).slice(0,8).join('\n');
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-5-20251001',
        max_tokens: 60,
        system: `You are a conlang phonologist for Ven'ai. Rules:
- Vowel digraphs (ae,ai,ei,ie,oe) form diphthongs
- th→/θ/, dh→/ð/, kh→/x/, lh→/ɬ/
- Final i→/iː/, final a→/ɑ/, final el/al→/əl/
- Stress on penultimate syllable unless long vowel present
${examples ? 'Known lexicon:\n'+examples : ''}
Respond with ONLY the IPA string, no slashes, no explanation. Example: ˈven.aɪ`,
        messages: [{ role: 'user', content: `IPA for Ven'ai word: ${term}` }]
      })
    });
    const data = await res.json();
    const ipa  = data.content?.[0]?.text?.trim().replace(/^\/|\/$/g,'').trim();
    if (ipa && pronEl && document.getElementById('vadd-term')?.value.trim() === term) {
      pronEl.value = `/ ${ipa} /`;
      if (status) { status.textContent = 'auto-filled'; status.className = 'venai-ipa-status done'; }
      setTimeout(() => { if (status) { status.textContent = ''; status.className = 'venai-ipa-status'; } }, 2200);
    }
  } catch(err) {
    if (status) { status.textContent = 'enter manually'; status.className = 'venai-ipa-status err'; }
    setTimeout(() => { if (status) { status.textContent = ''; status.className = 'venai-ipa-status'; } }, 2000);
  }
}

/* ─────────────────────────────────────────────────────────────────
   COMMIT ADD / SAVE  — window-exposed
   ───────────────────────────────────────────────────────────────── */
window.venaiCommitAdd = async function() {
  const term = (document.getElementById('vadd-term')?.value||'').trim();
  if (!term) { document.getElementById('vadd-term')?.focus(); return; }
  const g = id => (document.getElementById(id)?.value||'').trim();
  const customTags = g('vadd-tags-custom').split(',').map(t=>t.trim()).filter(Boolean);
  const allTags = [..._venaiTags, ...customTags].join(', ');
  const _vm = {
    pron:   g('vadd-pron'),
    pos:    (()=>{ const s=document.getElementById('vadd-pos'); const c=document.getElementById('vadd-pos-custom'); return (s&&s.value==='custom'||!s?.value) ? (c?c.value.trim():'') : (s?s.value:''); })(),
    cite:   g('vadd-cite'),
    root:   g('vadd-root'),
    tags:   allTags,
    layout: _venaiLayout,
  };
  const payload = {
    title:    term,
    body:     g('vadd-def'),
    section:  currentSection || 'venai',
    metadata: _vm,
  };
  try {
    if (_venaiEditingId) {
      await updateEntry(_venaiEditingId, payload);
    } else {
      await createEntry(payload);
    }
    window.venaiCloseAdd();
    if (typeof loadEntries === 'function') loadEntries();
  } catch(err) {
    console.warn('[Ven\'ai] save failed:', err);
    window.venaiCloseAdd();
  }
};

/* ─────────────────────────────────────────────────────────────────
   EDIT / DELETE ENTRY  — window-exposed
   ───────────────────────────────────────────────────────────────── */
window.venaiEditEntry = function(id) {
  const entry = (window._venaiEntries||[]).find(e => String(e.id) === String(id));
  if (!entry) return;
  window.venaiOpenAdd();
  _venaiEditingId = id;
  setTimeout(() => {
    const set = (elId, val) => { const el = document.getElementById(elId); if (el) el.value = val||''; };
    const _evm = entry.metadata || {};
    set('vadd-term', entry.title);
    set('vadd-def',  entry.body);
    set('vadd-pron', entry.pron  || _evm.pron  || '');
    (()=>{
      const _posV = entry.pos || _evm.pos || '';
      const _sel = document.getElementById('vadd-pos');
      const _cust = document.getElementById('vadd-pos-custom');
      if (_sel && _posV) {
        const knownOpts = ['noun','verb','adjective','adverb','particle','root morpheme','compound','phrase','noun phrase','verb phrase','interjection','relational'];
        if (knownOpts.includes(_posV)) { _sel.value = _posV; }
        else { _sel.value = 'custom'; if (_cust) { _cust.value = _posV; _cust.style.display = 'block'; } }
      }
    })();
    set('vadd-cite', entry.cite  || _evm.cite  || '');
    set('vadd-root', entry.root  || _evm.root  || '');
    _venaiLayout = entry.layout || _evm.layout || 'A';
    _syncLayoutBtns();
    const _et = entry.tags || _evm.tags || '';
    if (_et) {
      _venaiTags = new Set(_et.split(',').map(t=>t.trim().toUpperCase()).filter(t=>['TRIA','PRIA','PARA'].includes(t)));
      _syncTagBtns();
    }
    const titleEl = document.querySelector('.venai-add-title');
    if (titleEl) titleEl.textContent = 'Edit Entry';
  }, 120);
};

function _venaiSyncCounter() {
  const n = (window._venaiEntries||[]).length;
  const el = document.querySelector('.venai-stat');
  if (el) el.innerHTML = '<span>'+n+'</span> entr'+(n===1?'y':'ies');
}

window.venaiDeleteEntry = async function(id) {
  if (!confirm('Remove this entry from the lexicon?')) return;
  try {
    await deleteEntry(id);
    const el = document.getElementById('venai-e-'+id);
    if (el) {
      el.style.transition = 'opacity .3s, transform .3s';
      el.style.opacity = '0';
      el.style.transform = 'translateX(-12px)';
      setTimeout(() => { el.remove(); }, 320);
    }
    window._venaiEntries = (window._venaiEntries||[]).filter(e => String(e.id) !== String(id));
    _venaiSyncCounter();
  } catch(err) {
    console.warn('[Ven\'ai] delete failed:', err);
  }
};




// ── RESTORED FUNCTIONS ──
async function runEmergenceCheck() {

  try {

    const findings = await detectEmergence();

    window._emergenceFindings = findings;

  } catch(e) {}

}

function setSyncState(state) {

  const dot    = document.getElementById('sync-dot');

  const status = document.getElementById('sync-status');



  // Dot color

  if (dot) dot.className = state;



  // Pill: only visible once a folder is in play

  if (status) {

    const visible = ['active','saving','idle','error'].includes(state);

    status.classList.toggle('sync-visible', visible);

    status.title = state === 'active' ? 'Drive synced — click to sync now'

                 : state === 'idle'   ? 'Drive disconnected — click to reconnect'

                 : state === 'error'  ? 'Sync error — click to retry'

                 : 'Syncing…';

  }



  // FAB star live glow

  const star = document.querySelector('.ts-fab-item[data-tool="sync"]');

  if (star) {

    star.classList.remove('sync-active','sync-saving','sync-error');

    if (state === 'active') star.classList.add('sync-active');

    if (state === 'saving') star.classList.add('sync-saving');

    if (state === 'error')  star.classList.add('sync-error');

  }

}


async function restoreFolderHandle() {

  try {

    const db = await new Promise((res,rej) => {

      const r = indexedDB.open('AelarianMeta',1);

      r.onupgradeneeded = e => e.target.result.createObjectStore('meta',{keyPath:'key'});

      r.onsuccess = e => res(e.target.result); r.onerror = e => rej(e);

    });

    const tx = db.transaction('meta','readonly');

    const req = tx.objectStore('meta').get('folderHandle');

    req.onsuccess = async () => {

      if (req.result?.value) {

        folderHandle = req.result.value;

        const perm = await folderHandle.queryPermission({mode:'readwrite'});

        setSyncState(perm==='granted' ? 'active' : 'idle');

      }

    };

  } catch(e) {}

}

async function saveFolderHandle(handle) {

  try {

    const db = await new Promise((res,rej) => {

      const r = indexedDB.open('AelarianMeta',1);

      r.onupgradeneeded = e => e.target.result.createObjectStore('meta',{keyPath:'key'});

      r.onsuccess = e => res(e.target.result); r.onerror = e => rej(e);

    });

    db.transaction('meta','readwrite').objectStore('meta').put({key:'folderHandle',value:handle});

  } catch(e) {}

}

async function autoBackup() {

  if (!folderHandle) return;

  try {

    const perm = await folderHandle.requestPermission({mode:'readwrite'});

    if (perm !== 'granted') { setSyncState('error'); return; }

    setSyncState('saving');

    const json  = await exportAll();

    const _m = JSON.parse(json)._meta.counts;

    const _ts = new Date().toISOString().slice(0,19).replace(/:/g,'-');

    const fname = `aelarian-backup-${_ts}_concepts${_m.concepts}.json`;

    const fh    = await folderHandle.getFileHandle(fname,{create:true});

    const w     = await fh.createWritable();

    await w.write(json); await w.close();

    setSyncState('active');

  } catch(e) { setSyncState('error'); }

}

let currentPageDups = [];  // [{a, b}] pairs for current page

function venaiCheckRedundancy(title, body, excludeId) {
  const entries = window._venaiEntries || [];
  const q = (title||'').toLowerCase().trim();
  return entries.filter(e => String(e.id) !== String(excludeId) && (e.title||'').toLowerCase().trim() === q);
}

function esc(str) {

  return String(str)

    .replace(/&/g,'&amp;').replace(/</g,'&lt;')

    .replace(/>/g,'&gt;').replace(/"/g,'&quot;');

}

function setupBodyCounter() {

  const el      = document.getElementById('f-body');

  const counter = document.getElementById('body-counter');

  if (!el || !counter) return;

  el.addEventListener('input', () => {

    const text  = el.textContent;

    const chars = text.length;

    const words = text.trim() === '' ? 0 : text.trim().split(/\s+/).length;

    counter.textContent = `${words} word${words !== 1 ? 's' : ''} · ${chars} char${chars !== 1 ? 's' : ''}`;

    counter.classList.toggle('active', chars > 0);

  });

}

function setupTagInput() {

  const input  = document.getElementById('tag-search-input');

  const list   = document.getElementById('tag-suggest-list');

  let sugTimer = null;

  let activeIdx = -1;



  input.addEventListener('input', () => {

    clearTimeout(sugTimer);

    const q = input.value.trim();

    if (q.length >= 1) sugTimer = setTimeout(() => showVocabSearch(q), 180);

    else showAutoSuggest();

  });

  input.addEventListener('focus', () => {

    showAutoSuggest(); list.classList.add('open');

  });

  input.addEventListener('blur', () => {

    setTimeout(() => list.classList.remove('open'), 320);

  });

  input.addEventListener('keydown', (e) => {

    const items = list.querySelectorAll('.tag-suggest-item');

    if (e.key === 'ArrowDown') {

      e.preventDefault();

      activeIdx = Math.min(activeIdx+1, items.length-1);

      items.forEach((el,i) => el.classList.toggle('active', i===activeIdx));

    } else if (e.key === 'ArrowUp') {

      e.preventDefault();

      activeIdx = Math.max(activeIdx-1, 0);

      items.forEach((el,i) => el.classList.toggle('active', i===activeIdx));

    } else if (e.key === 'Enter' && activeIdx >= 0) {

      e.preventDefault(); items[activeIdx]?.click(); activeIdx = -1;

    }

  });

}

async function setupSearch() {

  const input = document.getElementById('search-input');

  if (input) input.addEventListener('input', () => {

    clearTimeout(searchTimer);

    const q = input.value.trim();

    if (!q) { loadEntries(); return; }

    searchTimer = setTimeout(async () => {

      const results = await searchEntries(q);

      document.getElementById('section-title').textContent  = `"${q}"`;

      document.getElementById('section-count').textContent  = `${results.length} result${results.length===1?'':'s'}`;

      renderEntries(results);

    }, 280);

  });

}

function buildModalSelects() {

  const secSel = document.getElementById('f-section');

  if (secSel && secSel.options.length === 0) {

    SECTIONS.forEach(s => {

      const opt = document.createElement('option');

      opt.value = s.id; opt.textContent = `${s.group} · ${s.label}`;

      secSel.appendChild(opt);

    });

  }

  const arcSel = document.getElementById('f-arc');

  if (arcSel && arcSel.options.length <= 1) {

    ARC_SEEDS.forEach(a => {

      const opt = document.createElement('option');

      opt.value = a.id; opt.textContent = `${a.label} · ${a.name}`;

      arcSel.appendChild(opt);

    });

  }

  const phaseSel = document.getElementById('f-phase');

  if (phaseSel && phaseSel.options.length <= 1) {

    ARC_SEED_TAGS.forEach(t => {

      const opt = document.createElement('option');

      opt.value = t.id;

      opt.textContent = t.id === 'tv_315' ? `${t.label} ∎` : t.label;

      phaseSel.appendChild(opt);

    });

  }

}

function detectPageDups(entries) {

  currentPageDups = [];

  if (!entries || !entries.length) return;



  if (currentSection === 'venai') {

    // Pair flagged entries by actual redundancy match

    const flagged = entries.filter(e => e.flagged);

    const seen = new Set();

    for (const a of flagged) {

      if (seen.has(a.id)) continue;

      const conflicts = venaiCheckRedundancy(a.title, a.body, a.id)

        .filter(b => b.flagged && !seen.has(b.id));

      if (conflicts.length) {

        const b = conflicts[0];

        currentPageDups.push({ a, b });

        seen.add(a.id);

        seen.add(b.id);

      }

    }

  } else {

    // Generic: title similarity only, ephemeral

    const seen = new Set();

    for (let i = 0; i < entries.length; i++) {

      if (seen.has(entries[i].id)) continue;

      const a  = entries[i];

      const aT = (a.title||'').toLowerCase().trim();

      if (!aT) continue;

      for (let j = i + 1; j < entries.length; j++) {

        if (seen.has(entries[j].id)) continue;

        const b  = entries[j];

        const bT = (b.title||'').toLowerCase().trim();

        if (!bT) continue;

        const titleMatch = aT === bT || levenshtein(aT, bT) <= 2;

        if (titleMatch) {

          currentPageDups.push({ a, b });

          seen.add(a.id);

          seen.add(b.id);

          break;

        }

      }

    }

  }

}

function updateFlagStar() {

  const star = document.getElementById('solo-flag');

  if (!star) return;

  const n = currentPageDups.length;

  if (n > 0) {

    star.classList.add('flagged');

    star.title = `⚑ ${n} duplicate pair${n > 1 ? 's' : ''} on this page`;

  } else {

    star.classList.remove('flagged');

    star.title = 'No duplicates detected';

  }

}

function renderFlagPanel() {

  const body  = document.getElementById('flag-panel-body');

  const count = document.getElementById('flag-panel-count');

  if (!body) return;

  const n = currentPageDups.length;

  if (count) count.textContent = n > 0 ? ` · ${n}` : '';

  if (!n) {

    body.innerHTML = '<div style="font-family:var(--font-mono);font-size:.62rem;letter-spacing:.10em;color:rgba(255,255,255,.2);text-align:center;padding:1.2rem 0">◈ no duplicates on this page</div>';

    return;

  }

  body.innerHTML = currentPageDups.map((pair, idx) => `

    <div class="flag-pair" id="flag-pair-${idx}">

      <div class="flag-pair-label">pair ${idx + 1}</div>

      <div class="flag-pair-cols">

        <div class="flag-pair-col">

          <div class="flag-pair-word" title="${esc(pair.a.title||'')}">${esc(pair.a.title||'—')}</div>

          <div class="flag-pair-def">${esc(pair.a.body||'')}</div>

        </div>

        <div class="flag-pair-col">

          <div class="flag-pair-word" title="${esc(pair.b.title||'')}">${esc(pair.b.title||'—')}</div>

          <div class="flag-pair-def">${esc(pair.b.body||'')}</div>

        </div>

      </div>

      <div class="flag-pair-actions">

        <button class="venai-btn merge-btn"  onclick="flagPanelMerge(${idx})"         >⟠ Merge</button>

        <button class="venai-btn"            onclick="flagPanelEdit(${idx},'a')"  style="font-size:.50rem;padding:.22rem .55rem">✎ Edit A</button>

        <button class="venai-btn"            onclick="flagPanelEdit(${idx},'b')"  style="font-size:.50rem;padding:.22rem .55rem">✎ Edit B</button>

        <button class="venai-btn danger"     onclick="flagPanelDelete(${idx},'a')" style="font-size:.50rem;padding:.22rem .55rem">✕ Del A</button>

        <button class="venai-btn danger"     onclick="flagPanelDelete(${idx},'b')" style="font-size:.50rem;padding:.22rem .55rem">✕ Del B</button>

      </div>

    </div>`).join('');

}

async function runHealthCheck() {

  try {

    const all = await getEntries();

    const flags = [];

    // Sections with their own schema — skip archive-specific field checks
    const _ownSchema = new Set(['venai','vectra','invocations','kin_line','glyphs','threshold_pillars','tria','pria','para','oracles','morphogy']);

    for (const e of all) {

      if (!e.title) continue;
      const _isArchive = !_ownSchema.has(e.section);
      if (_isArchive && !e.arcPhaseId) flags.push({ type:'missing', entry: e, issue: 'Missing phase' });

      if (_isArchive && !e.originDate) flags.push({ type:'missing', entry: e, issue: 'Missing origin date' });

      if (_isArchive && (!e.tagIds || e.tagIds.length === 0)) flags.push({ type:'untagged', entry: e, issue: 'No tags applied' });

      const _bodyOptional = new Set(['kin_line','glyphs']);
      if (!_bodyOptional.has(e.section) && (!e.body || e.body.trim().length < 20)) flags.push({ type:'stub', entry: e, issue: 'Stub — body under 20 chars' });

      // Venai lexicon completeness
      if (e.section === 'venai') {
        const _vm = e.metadata || {};
        if (!e.pron && !_vm.pron) flags.push({ type:'missing', entry: e, issue: 'Missing IPA' });
        if (!e.pos  && !_vm.pos)  flags.push({ type:'missing', entry: e, issue: 'Missing POS' });
      }

    }

    window._healthFlags = flags;

    // Sync visual state

    const star = document.getElementById('health-star');

    const towerHealth = document.querySelector('#fab-btn-a');

    star?.classList.toggle('has-flags', flags.length > 0);

    towerHealth?.classList.toggle('has-flags', flags.length > 0);

    // Brief green pulse when archive is clean

    if (flags.length === 0 && star) {

      star.classList.add('health-ok');

      setTimeout(() => star.classList.remove('health-ok'), 3200);

    }

    return flags;

  } catch(e) { return []; }

}

window.closeFlagPanel = () => {

  document.getElementById('flag-panel')?.classList.remove('open');

}

window.toggleFlagPanel = () => {

  const panel = document.getElementById('flag-panel');

  if (!panel) return;

  if (panel.classList.contains('open')) {

    panel.classList.remove('open');

  } else {

    renderFlagPanel();

    panel.classList.add('open');

  }

}

window.toggleHealthPanel = async () => {

  const panel = document.getElementById('health-panel');

  if (!panel) return;

  const isOpen = panel.classList.toggle('open');

  if (isOpen) {

    const flags = await runHealthCheck();

    const el    = document.getElementById('health-findings');

    const title = document.getElementById('health-panel-title-text');

    const footer= document.getElementById('health-panel-footer');

    title.textContent = flags.length ? `Health Check · ${flags.length} flag${flags.length===1?'':'s'}` : 'Health Check';

    footer.textContent = `Last scan · ${new Date().toLocaleString()}`;

    if (!flags.length) {

      el.innerHTML = '<div class="health-empty">✦ Archive is clean — no issues found</div>';

      return;

    }

    el.innerHTML = flags.map(f => `

      <div class="health-flag-item flag-${f.type}">

        <div class="health-flag-dot"></div>

        <div>

          <div>${esc(f.issue)} — <em>${esc(f.entry.title)}</em></div>

          <div class="health-flag-meta">${f.entry.compositeId || f.entry.id || ''}</div>

          <button class="health-flag-goto" onclick="healthGoTo('${f.entry.id}')">→ go to entry</button>

        </div>

      </div>`).join('');

  }

}




